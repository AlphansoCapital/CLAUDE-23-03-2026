{% comment %}
  Urban Trend — WhatsApp Payment Link for COD Orders
  Auto-sends payment link after COD order placed
  Include in order confirmation page
{% endcomment %}

<style>
.ut-wa-payment{background:rgba(37,211,102,0.06);border:1px solid rgba(37,211,102,0.2);padding:20px 24px;margin:24px 0}
.ut-wa-payment-title{font-family:'Cinzel',serif;font-size:12px;letter-spacing:.2em;color:#25D366;text-transform:uppercase;margin-bottom:8px}
.ut-wa-payment-desc{font-family:'Jost',sans-serif;font-size:13px;color:rgba(250,246,240,.6);line-height:1.6;margin-bottom:14px}
.ut-wa-pay-btn{background:#25D366;color:#fff;border:none;padding:14px 24px;font-family:'Jost',sans-serif;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:10px;text-decoration:none;width:fit-content;transition:background .2s}
.ut-wa-pay-btn:hover{background:#1ebe5d}
.ut-wa-pay-btn svg{width:20px;height:20px;fill:#fff;flex-shrink:0}
</style>

<div class="ut-wa-payment" id="ut-wa-payment">
  <div class="ut-wa-payment-title">📱 Pay & Get Faster Delivery</div>
  <div class="ut-wa-payment-desc">
    Click below to receive your payment link on WhatsApp. 
    Pay now and your order gets <strong style="color:rgba(250,246,240,.85);">priority dispatch within 4 hours</strong> — 
    vs 24-48 hours for COD.
  </div>
  <a class="ut-wa-pay-btn" id="ut-wa-pay-link" href="#" target="_blank" rel="noopener">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    Send Payment Link on WhatsApp
  </a>
</div>

<script>
(function(){
  var WA_NUMBER = '{{ settings.whatsapp_number | default: "919876543210" }}';

  function buildWALink(orderId, amount) {
    var msg = [
      'Hi! 🙏',
      '',
      'Your Urban Trend order *#' + orderId + '* is confirmed!',
      '',
      '💰 *Pay Online & Get Priority Dispatch:*',
      'Amount: ₹' + amount,
      '',
      'Benefits of paying online:',
      '✓ Priority dispatch within 4 hours',
      '✓ Extra ₹50 cashback on next order',
      '✓ Faster delivery',
      '',
      'Reply *PAY* to get your secure payment link.',
      '',
      '— Urban Trend Team 🌸'
    ].join('\n');

    return 'https://wa.me/' + WA_NUMBER.replace(/\D/g,'') + '?text=' + encodeURIComponent(msg);
  }

  // Set WhatsApp link
  var btn = document.getElementById('ut-wa-pay-link');
  if (btn) {
    // Get order details from page
    var orderId = document.querySelector('[data-order-id]') && 
                  document.querySelector('[data-order-id]').dataset.orderId || 
                  (window.Shopify && Shopify.checkout && Shopify.checkout.order_id) || 
                  'your order';
    var amount = document.querySelector('[data-order-total]') && 
                 document.querySelector('[data-order-total]').dataset.orderTotal ||
                 (window.Shopify && Shopify.checkout && Shopify.checkout.total_price / 100) ||
                 '';

    btn.href = buildWALink(orderId, amount);
  }
})();
</script>
