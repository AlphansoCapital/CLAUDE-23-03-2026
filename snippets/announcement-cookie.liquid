<!-- Announcement Bar -->
<style>
.ut-announcement { background:var(--ut-gold); color:var(--ut-bg); text-align:center; padding:9px 40px; font-family:'Cinzel',serif; font-size:9px; letter-spacing:0.35em; text-transform:uppercase; position:relative; }
.ut-announcement a { color:var(--ut-bg); text-decoration:none; }
.ut-announcement-close { position:absolute; right:14px; top:50%; transform:translateY(-50%); background:none; border:none; color:var(--ut-bg); font-size:16px; cursor:pointer; opacity:0.6; padding:4px; line-height:1; }
.ut-announcement-close:hover { opacity:1; }

/* Cookie */
.ut-cookie { position:fixed; bottom:24px; left:24px; right:24px; max-width:480px; background:var(--ut-bg-4); border:1px solid rgba(201,169,110,0.2); padding:20px 24px; z-index:99999; display:none; box-shadow:0 8px 40px rgba(0,0,0,0.5); }
.ut-cookie.visible { display:flex; gap:20px; align-items:center; flex-wrap:wrap; }
.ut-cookie p { font-family:'Jost',sans-serif; font-size:12px; color:rgba(250,246,240,0.6); line-height:1.6; margin:0; flex:1; min-width:200px; }
.ut-cookie p a { color:var(--ut-gold); text-decoration:none; }
.ut-cookie-btns { display:flex; gap:8px; flex-shrink:0; }
.ut-cookie-accept { background:var(--ut-gold); color:var(--ut-bg); border:none; font-family:'Cinzel',serif; font-size:8px; letter-spacing:0.3em; padding:10px 18px; cursor:pointer; text-transform:uppercase; transition:background 0.2s; white-space:nowrap; }
.ut-cookie-accept:hover { background:var(--ut-gold-light); }
.ut-cookie-decline { background:none; color:rgba(201,169,110,0.5); border:1px solid rgba(201,169,110,0.2); font-family:'Cinzel',serif; font-size:8px; letter-spacing:0.3em; padding:10px 14px; cursor:pointer; text-transform:uppercase; white-space:nowrap; }
</style>

<div class="ut-announcement" id="announcementBar">
  🌹 Free Shipping Above ₹999 &nbsp;|&nbsp; COD Available &nbsp;|&nbsp; New: Kashmir Saffron Mask
  <button class="ut-announcement-close" onclick="closeAnnouncement()" aria-label="Close">×</button>
</div>

<div class="ut-cookie" id="cookieBanner">
  <p>We use cookies to give you the best experience. By using our site, you agree to our <a href="/pages/privacy-policy">Privacy Policy</a>.</p>
  <div class="ut-cookie-btns">
    <button class="ut-cookie-accept" onclick="acceptCookie()">Accept</button>
    <button class="ut-cookie-decline" onclick="declineCookie()">Decline</button>
  </div>
</div>

<script>
(function(){
  if(!localStorage.getItem('ut-announce-closed')) {
    // already visible by default
  } else {
    var bar = document.getElementById('announcementBar');
    if(bar) bar.style.display = 'none';
  }
  if(!localStorage.getItem('ut-cookie-choice')) {
    setTimeout(function(){
      var banner = document.getElementById('cookieBanner');
      if(banner) banner.classList.add('visible');
    }, 2000);
  }
})();
function closeAnnouncement() {
  document.getElementById('announcementBar').style.display = 'none';
  localStorage.setItem('ut-announce-closed', '1');
}
function acceptCookie() {
  localStorage.setItem('ut-cookie-choice', 'accepted');
  document.getElementById('cookieBanner').style.display = 'none';
}
function declineCookie() {
  localStorage.setItem('ut-cookie-choice', 'declined');
  document.getElementById('cookieBanner').style.display = 'none';
}
</script>
