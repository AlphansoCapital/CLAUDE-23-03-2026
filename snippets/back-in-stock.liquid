{% comment %} Back in Stock — shown when variant is unavailable {% endcomment %}
<style>
.ut-bis-wrap{margin-top:16px;padding:20px;border:1px solid rgba(201,169,110,0.15);background:rgba(10,9,8,0.5)}
.ut-bis-title{font-family:'Cinzel',serif;font-size:10px;letter-spacing:.25em;color:var(--ut-gold);text-transform:uppercase;margin-bottom:12px}
.ut-bis-form{display:flex;gap:8px}
.ut-bis-input{flex:1;background:none;border:1px solid rgba(201,169,110,0.2);color:var(--ut-text);font-family:'Jost',sans-serif;font-size:13px;padding:12px 14px;outline:none;transition:border-color .2s}
.ut-bis-input:focus{border-color:rgba(201,169,110,0.5)}
.ut-bis-input::placeholder{color:rgba(250,246,240,.2)}
.ut-bis-btn{background:rgba(201,169,110,0.15);color:var(--ut-gold);border:1px solid rgba(201,169,110,0.3);font-family:'Cinzel',serif;font-size:8px;letter-spacing:.25em;text-transform:uppercase;padding:12px 16px;cursor:pointer;white-space:nowrap;transition:all .2s}
.ut-bis-btn:hover{background:var(--ut-gold);color:var(--ut-bg)}
.ut-bis-success{font-family:'Jost',sans-serif;font-size:12px;color:#4CAF7D;margin-top:8px;display:none}
</style>

<div class="ut-bis-wrap" id="ut-bis-{{ product.id }}">
  <div class="ut-bis-title">🔔 Notify Me When Available</div>
  <div class="ut-bis-form">
    <input class="ut-bis-input" type="email" placeholder="your@email.com" id="ut-bis-email-{{ product.id }}" autocomplete="email">
    <button class="ut-bis-btn" onclick="utBISSubmit('{{ product.id }}','{{ product.title | escape }}')">Notify Me</button>
  </div>
  <div class="ut-bis-success" id="ut-bis-ok-{{ product.id }}">✓ We'll email you when this is back in stock!</div>
</div>

<script>
function utBISSubmit(productId, productTitle) {
  var emailEl = document.getElementById('ut-bis-email-' + productId);
  var email = emailEl && emailEl.value.trim();
  if (!email || !email.includes('@')) {
    emailEl && (emailEl.style.borderColor = '#E57373');
    return;
  }
  // Store BIS request
  try {
    var requests = JSON.parse(localStorage.getItem('ut_bis_requests') || '[]');
    requests.push({ productId: productId, productTitle: productTitle, email: email, date: new Date().toISOString() });
    localStorage.setItem('ut_bis_requests', JSON.stringify(requests));
  } catch(e) {}

  // In production: POST to a webhook/metafield/email service
  // fetch('/apps/bis', { method: 'POST', body: JSON.stringify({ email, productId }) })

  emailEl.value = '';
  emailEl.style.borderColor = '';
  var ok = document.getElementById('ut-bis-ok-' + productId);
  if (ok) ok.style.display = 'block';
  setTimeout(function() { if (ok) ok.style.display = 'none'; }, 4000);

  if (typeof UT !== 'undefined' && UT.toast) {
    UT.toast('✓ Notification set for ' + productTitle, 'success');
  }
}
</script>
