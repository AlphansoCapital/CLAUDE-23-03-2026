<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
  <meta http-equiv="x-dns-prefetch-control" content="on">
  <meta name="format-detection" content="telephone=no">
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <meta http-equiv="X-UA-Compatible" content="IE=edge">

  {%- comment -%} ── CORE SEO ── {%- endcomment -%}
  <title>
    {%- if template.name == 'index' -%}
      Urban Trend — Premium Indian Beauty | Skincare, Makeup & Fragrance
    {%- elsif template.name == 'product' -%}
      {{ product.title }} | {{ product.type }} | Urban Trend
    {%- elsif template.name == 'collection' -%}
      {{ collection.title }} | Shop {{ collection.title }} Online | Urban Trend
    {%- elsif template.name == 'page' -%}
      {{ page.title }} | Urban Trend
    {%- elsif template.name == 'blog' -%}
      {{ blog.title }} | Beauty Tips & Trends | Urban Trend
    {%- elsif template.name == 'article' -%}
      {{ article.title }} | Urban Trend Beauty Blog
    {%- elsif template.name == 'search' -%}
      Search Results{% if search.performed %} for "{{ search.terms }}"{% endif %} | Urban Trend
    {%- elsif template.name == 'cart' -%}
      Shopping Bag | Urban Trend
    {%- else -%}
      {{ page_title }}{%- unless page_title contains shop.name %} | Urban Trend{%- endunless -%}
    {%- endif -%}
    {%- if current_page != 1 %} — Page {{ current_page }}{%- endif -%}
  </title>

  {%- comment -%} ── META DESCRIPTION ── {%- endcomment -%}
  {%- if template.name == 'index' -%}
    <meta name="description" content="Urban Trend — India's Beauty Problem Solver since 1975. 100% authentic skincare, makeup & fragrance. Dark spots, hair fall, wedding makeup, bridal skin — real solutions from a 50-year trusted family business. Free delivery ₹999+.">
  {%- elsif template.name == 'product' and product.description != blank -%}
    <meta name="description" content="{{ product.description | strip_html | truncate: 155 | escape }}">
  {%- elsif template.name == 'product' -%}
    <meta name="description" content="Buy genuine {{ product.title }} — 100% authentic, sourced direct. Free delivery ₹999+. 7-day returns. Urban Trend Est. 1975.">
  {%- elsif template.name == 'collection' and collection.description != blank -%}
    <meta name="description" content="{{ collection.description | strip_html | truncate: 155 | escape }}">
  {%- elsif template.name == 'collection' -%}
    <meta name="description" content="Shop {{ collection.title }} at Urban Trend. 100% authentic products sourced direct from brands. Free delivery ₹999+. 7-day returns. Est. 1975.">
  {%- elsif page_description != blank -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta name="description" content="Urban Trend — 50 years of trusted beauty expertise. 100% authentic skincare, makeup & fragrance. Real solutions for Indian skin concerns. Free delivery ₹999+. Est. 1975.">
  {%- endif -%}

  {%- comment -%} ── ROBOTS ── {%- endcomment -%}
  {%- if template.name == 'cart' or template.name == 'account' or template.suffix == 'password' -%}
    <meta name="robots" content="noindex, nofollow">
  {%- else -%}
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
  {%- endif -%}

  {%- comment -%} ── CANONICAL ── {%- endcomment -%}
  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} ── OPEN GRAPH ── {%- endcomment -%}
  <meta property="og:site_name" content="Urban Trend">
  <meta property="og:locale" content="en_IN">
  <meta property="og:url" content="{{ canonical_url }}">
  {%- if template.name == 'product' -%}
    <meta property="og:type" content="product">
    <meta property="og:title" content="{{ product.title | escape }} | Urban Trend">
    <meta property="og:description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
    {%- if product.featured_image -%}
      <meta property="og:image" content="https:{{ product.featured_image | img_url: '1200x630', crop: 'center' }}">
      <meta property="og:image:width" content="1200">
      <meta property="og:image:height" content="630">
      <meta property="og:image:alt" content="{{ product.featured_image.alt | escape }}">
    {%- endif -%}
    <meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
    <meta property="product:price:currency" content="{{ cart.currency.iso_code }}">
  {%- elsif template.name == 'collection' -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ collection.title | escape }} | Urban Trend">
    <meta property="og:description" content="Shop {{ collection.title }} at Urban Trend. {% if collection.description != blank %}{{ collection.description | strip_html | truncate: 150 | escape }}{% else %}Premium Indian beauty — dermatologist-tested, cruelty-free.{% endif %}">
    {%- if collection.image -%}
      <meta property="og:image" content="https:{{ collection.image | img_url: '1200x630', crop: 'center' }}">
    {%- endif -%}
  {%- elsif template.name == 'article' -%}
    <meta property="og:type" content="article">
    <meta property="og:title" content="{{ article.title | escape }} | Urban Trend">
    <meta property="og:description" content="{{ article.excerpt_or_content | strip_html | truncate: 200 | escape }}">
    {%- if article.image -%}
      <meta property="og:image" content="https:{{ article.image | img_url: '1200x630', crop: 'center' }}">
    {%- endif -%}
  {%- else -%}
    <meta property="og:type" content="website">
    <meta property="og:title" content="Urban Trend — Premium Indian Beauty">
    <meta property="og:description" content="India's premium beauty brand. Skincare, makeup & fragrance crafted for Indian skin. Dermatologist-tested. Free shipping above ₹999.">
    <meta property="og:image" content="{{ 'og-image.jpg' | asset_url }}">
  {%- endif -%}

  {%- comment -%} ── TWITTER CARD ── {%- endcomment -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@urbantrend">
  <meta name="twitter:creator" content="@urbantrend">
  {%- if template.name == 'product' -%}
    <meta name="twitter:title" content="{{ product.title | escape }} | Urban Trend">
    <meta name="twitter:description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
    {%- if product.featured_image -%}
      <meta name="twitter:image" content="https:{{ product.featured_image | img_url: '1200x628', crop: 'center' }}">
    {%- endif -%}
  {%- else -%}
    <meta name="twitter:title" content="{% if template.name == 'index' %}Urban Trend — Premium Indian Beauty{% else %}{{ page_title }} | Urban Trend{% endif %}">
    <meta name="twitter:description" content="India's premium beauty brand. Skincare, makeup & fragrance for Indian skin.">
  {%- endif -%}

  {%- comment -%} ── GLOBAL JSON-LD (Organisation + WebSite) ── {%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "{{ shop.url }}/#organization",
        "name": "Urban Trend",
        "url": "{{ shop.url }}",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ 'logo.png' | asset_url }}",
          "width": 200,
          "height": 60
        },
        "description": "India's premium beauty brand. Dermatologist-tested skincare, makeup for Indian skin tones, and luxury fragrances with Indian botanicals.",
        "foundingDate": "2010",
        "foundingLocation": "Mumbai, India",
        "sameAs": [
          "https://www.instagram.com/urbantrend",
          "https://www.facebook.com/urbantrend",
          "https://twitter.com/urbantrend",
          "https://www.youtube.com/urbantrend",
          "https://www.pinterest.com/urbantrend"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer support",
          "availableLanguage": ["English", "Hindi"],
          "areaServed": "IN"
        }
      },
      {
        "@type": "WebSite",
        "@id": "{{ shop.url }}/#website",
        "url": "{{ shop.url }}",
        "name": "Urban Trend",
        "description": "Premium Indian beauty brand",
        "publisher": {"@id": "{{ shop.url }}/#organization"},
        "potentialAction": {
          "@type": "SearchAction",
          "target": {"@type": "EntryPoint", "urlTemplate": "{{ shop.url }}/search?q={search_term_string}"},
          "query-input": "required name=search_term_string"
        }
      }
      {%- if template.name == 'product' -%}
      ,{
        "@type": "Product",
        "@id": "{{ canonical_url }}#product",
        "name": "{{ product.title | escape }}",
        "description": "{{ product.description | strip_html | truncate: 500 | escape }}",
        "brand": {"@type": "Brand", "name": "Urban Trend"},
        "category": "{{ product.type | escape }}",
        "sku": "{{ product.selected_or_first_available_variant.sku | escape }}",
        "url": "{{ canonical_url }}",
        {%- if product.featured_image -%}
        "image": ["https:{{ product.featured_image | img_url: '800x800', crop: 'center' }}"
          {%- for image in product.images limit: 5 -%}
            {%- unless image == product.featured_image -%}
            ,"https:{{ image | img_url: '800x800', crop: 'center' }}"
            {%- endunless -%}
          {%- endfor -%}
        ],
        {%- endif -%}
        "offers": {
          "@type": "Offer",
          "url": "{{ canonical_url }}",
          "priceCurrency": "INR",
          "price": "{{ product.price | money_without_currency }}",
          "priceValidUntil": "{{ 'now' | date: '%Y' | plus: 1 }}-12-31",
          "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
          "seller": {"@type": "Organization", "name": "Urban Trend"},
          "shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingRate": {"@type": "MonetaryAmount", "value": "0", "currency": "INR"},
            "shippingDestination": {"@type": "DefinedRegion", "addressCountry": "IN"},
            "doesNotShip": false
          },
          "hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
            "merchantReturnDays": 30,
            "returnMethod": "https://schema.org/ReturnByMail"
          }
        }
        {%- if product.metafields.reviews.rating -%}
        ,"aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "{{ product.metafields.reviews.rating.value }}",
          "reviewCount": "{{ product.metafields.reviews.rating_count.value }}",
          "bestRating": "5",
          "worstRating": "1"
        }
        {%- endif -%}
      }
      {%- endif -%}
      {%- if template.name == 'index' -%}
      ,{
        "@type": "Store",
        "@id": "{{ shop.url }}/#store",
        "name": "Urban Trend",
        "url": "{{ shop.url }}",
        "image": "{{ 'og-image.jpg' | asset_url }}",
        "description": "India's premium beauty brand — skincare, makeup & fragrance crafted for Indian skin.",
        "priceRange": "₹₹₹",
        "currenciesAccepted": "INR",
        "paymentAccepted": "Credit Card, Debit Card, UPI, Net Banking, COD",
        "areaServed": "India",
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Urban Trend Products",
          "itemListElement": [
            {"@type": "OfferCatalog", "name": "Skincare", "url": "{{ shop.url }}/collections/skincare"},
            {"@type": "OfferCatalog", "name": "Makeup", "url": "{{ shop.url }}/collections/makeup"},
            {"@type": "OfferCatalog", "name": "Fragrance", "url": "{{ shop.url }}/collections/fragrance"},
            {"@type": "OfferCatalog", "name": "Hair Care", "url": "{{ shop.url }}/collections/hair"},
            {"@type": "OfferCatalog", "name": "Body Care", "url": "{{ shop.url }}/collections/body-care"}
          ]
        }
      }
      {%- endif -%}
    ]
  }
  </script>

  {%- comment -%} ── FAVICONS ── {%- endcomment -%}
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | img_url: '32x32' }}">
