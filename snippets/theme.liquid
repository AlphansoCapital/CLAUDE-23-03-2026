  {%- comment -%} ── CRITICAL CSS INLINE ── {%- endcomment -%}
  <style>
    /* CRITICAL CSS — above fold only */
    :root{
      --ut-bg:#0A0908;--ut-bg-2:#141210;--ut-bg-3:#141210;--ut-bg-4:#1E1A16;--ut-bg-5:#1C1510;
      --ut-gold:#C9A96E;--ut-gold-light:#E2C98A;--ut-gold-dark:#9A7840;
      --ut-gold-10:rgba(201,169,110,0.10);--ut-gold-25:rgba(201,169,110,0.25);
      --ut-rose:#8B3A52;--ut-text:#FAF6F0;--ut-text-65:rgba(250,246,240,0.65);
      --ut-text-45:rgba(250,246,240,0.45);--ut-text-35:rgba(250,246,240,0.35);
      --ut-text-28:rgba(250,246,240,0.28);--ut-border:rgba(201,169,110,0.12);
      --ut-border-md:rgba(201,169,110,0.22);--ut-font-serif:'Cinzel',serif;
      --ut-font-display:'Cormorant Garamond',Georgia,serif;--ut-font-body:'Jost',sans-serif;
      --ut-radius:2px;--ut-ease:0.25s ease;
      --gold:#C9A96E;--gold-l:#E2C98A;--obs:#0A0908;--char:#141210;
      --ww:#FAF6F0;--muted:rgba(250,246,240,0.45);--border:rgba(201,169,110,0.18);
      --fd:'Cormorant Garamond',Georgia,serif;--fl:'Cinzel',serif;--fb:'Jost',sans-serif;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{background:#0A0908;color:#FAF6F0;font-family:'Jost',system-ui,sans-serif;font-weight:300;-webkit-font-smoothing:antialiased;overflow-x:hidden}
    img,video,svg{max-width:100%;height:auto;display:block}
    a{color:inherit;text-decoration:none}
    /* Nav critical */
    .nav,.ut-nav{display:flex;align-items:center;justify-content:space-between;padding:20px 52px;background:rgba(10,9,8,0.96);border-bottom:1px solid rgba(201,169,110,0.18);position:sticky;top:0;z-index:200;backdrop-filter:blur(16px)}
    .nav-logo,.ut-nav-logo{font-family:'Cinzel',serif;font-size:15px;letter-spacing:0.4em;color:#E2C98A;text-transform:uppercase}
    /* Hero critical */
    .hero{display:grid;grid-template-columns:1fr 1fr;min-height:100vh;position:relative;overflow:hidden;background:#0A0908}
    .hero-left{background:#141210;display:flex;flex-direction:column;justify-content:center;padding:90px 60px 90px 72px}
    .hero-right{background:linear-gradient(155deg,#1A1410 0%,#0D0B09 60%,#130F0D 100%);position:relative;overflow:hidden}
    .headline{font-family:'Cormorant Garamond',Georgia,serif;font-weight:300;font-size:clamp(46px,5vw,74px);line-height:1.05;color:#FAF6F0;margin-bottom:24px}
    .headline em{font-style:italic;color:#E2C98A}
    /* Jump bar */
    .jump-bar{display:flex;justify-content:center;gap:4px;padding:10px 0;background:#0A0908;border-bottom:1px solid rgba(201,169,110,0.1);position:sticky;top:61px;z-index:190}
    /* Prevent FOUC */
    .reveal{opacity:0;transform:translateY(30px);transition:opacity 0.9s ease,transform 0.9s ease}
    .reveal.vis{opacity:1;transform:translateY(0)}
    @media(max-width:960px){.hero{grid-template-columns:1fr;min-height:auto}.nav,.ut-nav{padding:0 24px;height:64px}}
    @media(max-width:600px){.nav,.ut-nav{height:52px;padding:0 16px}}
    @media(prefers-reduced-motion:reduce){*{animation-duration:0.01ms!important;animation-iteration-count:1!important;transition-duration:0.01ms!important}}
  </style>

  
