<body class="template-{{ template.name }}{% if template.suffix != blank %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  {%- comment -%} ── PAGE LOADER ── {%- endcomment -%}
  <div id="ut-page-loader">
    <div class="ut-loader-inner">
      <div class="ut-loader-logo">URBAN TREND</div>
      <div class="ut-loader-bar"><div class="ut-loader-fill" id="utLoaderFill"></div></div>
    </div>
  </div>
  <style>
  #ut-page-loader{position:fixed;inset:0;background:#0A0908;z-index:999999;display:flex;align-items:center;justify-content:center;transition:opacity 0.5s ease,visibility 0.5s ease;}
  #ut-page-loader.hide{opacity:0;visibility:hidden;pointer-events:none;}
  .ut-loader-inner{text-align:center;}
  .ut-loader-logo{font-family:'Cinzel',serif;font-size:16px;letter-spacing:0.55em;color:#C9A96E;text-transform:uppercase;margin-bottom:28px;opacity:0;animation:utLogoIn 0.8s ease 0.1s forwards;}
  @keyframes utLogoIn{from{opacity:0;letter-spacing:0.8em}to{opacity:1;letter-spacing:0.55em}}
  .ut-loader-bar{width:180px;height:1px;background:rgba(201,169,110,0.15);margin:0 auto;overflow:hidden;}
  .ut-loader-fill{height:100%;background:linear-gradient(to right,#C9A96E,#E2C98A);width:0%;transition:width 0.4s ease;}
  </style>
  <script>
  (function(){
    var fill = document.getElementById('utLoaderFill');
    var loader = document.getElementById('ut-page-loader');
    var p = 0;
    var t = setInterval(function(){
      p += Math.random() * 22;
      if(p > 90) p = 90;
      fill.style.width = p + '%';
    }, 120);
    window.addEventListener('load', function(){
      clearInterval(t);
      fill.style.width = '100%';
      setTimeout(function(){ loader.classList.add('hide'); }, 400);
    });
    // Fallback — remove after 3s max
    setTimeout(function(){ loader.classList.add('hide'); }, 3000);
  })();
  </script>

