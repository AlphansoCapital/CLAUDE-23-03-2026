<style>
.ut-password { background:var(--ut-bg); min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:40px 32px; text-align:center; }
.ut-password-logo { font-family:'Cinzel',serif; font-size:28px; color:var(--ut-gold); letter-spacing:0.25em; margin-bottom:48px; text-transform:uppercase; }
.ut-password-box { max-width:400px; width:100%; }
.ut-password-title { font-family:'Cinzel',serif; font-size:clamp(20px,3vw,28px); color:var(--ut-text); letter-spacing:0.1em; font-weight:400; margin:0 0 12px; }
.ut-password-sub { font-family:'Jost',sans-serif; font-size:13px; color:rgba(250,246,240,0.4); line-height:1.8; margin-bottom:40px; letter-spacing:0.05em; }
.ut-password-form { display:flex; flex-direction:column; gap:12px; }
.ut-password-input { background:none; border:1px solid rgba(201,169,110,0.2); color:var(--ut-text); font-family:'Jost',sans-serif; font-size:14px; padding:14px 18px; letter-spacing:0.08em; outline:none; text-align:center; transition:border-color 0.2s; }
.ut-password-input:focus { border-color:rgba(201,169,110,0.5); }
.ut-password-input::placeholder { color:rgba(250,246,240,0.2); }
.ut-password-submit { background:var(--ut-gold); color:var(--ut-bg); border:none; font-family:'Cinzel',serif; font-size:9px; letter-spacing:0.4em; text-transform:uppercase; padding:16px; cursor:pointer; transition:background 0.2s; }
.ut-password-submit:hover { background:var(--ut-gold-light); }
.ut-password-footer { margin-top:48px; font-family:'Jost',sans-serif; font-size:10px; color:rgba(250,246,240,0.2); letter-spacing:0.15em; }
.ut-password-footer a { color:rgba(201,169,110,0.4); text-decoration:none; }
</style>

<div class="ut-password">
  <div class="ut-password-logo">Urban Trend</div>

  <div class="ut-password-box">
    <h1 class="ut-password-title">Coming Soon</h1>
    <p class="ut-password-sub">We're putting the finishing touches on something bold.<br>Enter the password to get early access.</p>

    {% form 'storefront_password' %}
      {% if form.errors %}
        <p style="font-family:'Jost',sans-serif;font-size:12px;color:var(--ut-rose);margin-bottom:12px;letter-spacing:0.1em;">Incorrect password. Try again.</p>
      {% endif %}
      <div class="ut-password-form">
        <input class="ut-password-input" type="password" name="password" placeholder="Enter Password" autocomplete="current-password">
        <button class="ut-password-submit" type="submit">Enter Store</button>
      </div>
    {% endform %}
  </div>

  <div class="ut-password-footer">
    <p>{{ shop.name }} &mdash; Powered by <a href="https://shopify.com">Shopify</a></p>
  </div>
</div>

{% schema %}
{
  "name": "Password",
  "tag": "section",
  "settings": []
}
{% endschema %}
