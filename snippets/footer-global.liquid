<script>
function subscribeFooter(){
  var inp=document.getElementById('footerEmail');
  if(!inp?.value?.includes('@')){inp.style.borderColor='rgba(139,58,82,0.5)';return;}
  UT.toast('✓ Welcome to the Glow List!','success');
  inp.value=''; inp.placeholder='You\'re in! ✓'; inp.style.color='var(--ut-success)';
  setTimeout(()=>{inp.placeholder='your@email.com';inp.style.color='';},3000);
}
</script>
