      <span class="ut-mob-section">Shop</span>
      <a class="ut-mob-link" href="/collections/all">All Products</a>
      <a class="ut-mob-link" href="/collections/skincare">Skincare</a>
      <a class="ut-mob-link" href="/collections/makeup">Makeup</a>
