<script>
(function(){
  var nav=document.getElementById('utNav');
  var sBtn=document.getElementById('utSearchBtn');
  var sPanel=document.getElementById('utSearchPanel');
  var sInput=document.getElementById('utSearchInput');
  var sBox=document.getElementById('utSuggestBox');
  var sBD=document.getElementById('utSearchBackdrop');
  var burger=document.getElementById('utBurger');
  var mobile=document.getElementById('utMobile');
  var mobOv=document.getElementById('utMobOverlay');
  var isOpen=false,timer=null,lastQ='';

  /* Scroll */
  window.addEventListener('scroll',function(){nav.classList.toggle('scrolled',window.scrollY>8);},{passive:true});

  /* Search toggle */
  function openS(){isOpen=true;sPanel.classList.add('open');sBD.classList.add('open');sBtn.setAttribute('aria-expanded','true');setTimeout(function(){sInput.focus();},60);}
  function closeS(){isOpen=false;sPanel.classList.remove('open');sBD.classList.remove('open');sBtn.setAttribute('aria-expanded','false');}
  sBtn.addEventListener('click',function(e){e.stopPropagation();isOpen?closeS():openS();});
  sBD.addEventListener('click',closeS);
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&isOpen)closeS();});

  /* Popular */
  var pop=[
    {name:'Vitamin C Serum 20%',cat:'Skincare',price:'₹799',icon:'🍋',url:'/search?q=vitamin+c+serum&type=product'},
    {name:'SPF 50 Sunscreen',cat:'Skincare',price:'₹599',icon:'☀️',url:'/search?q=sunscreen+spf+50&type=product'},
    {name:'Hair Growth Oil',cat:'Hair Care',price:'₹649',icon:'🌿',url:'/search?q=hair+growth+oil&type=product'},
    {name:'Niacinamide 10%',cat:'Skincare',price:'₹499',icon:'✨',url:'/search?q=niacinamide&type=product'},
    {name:'Kajal & Liner Set',cat:'Makeup',price:'₹349',icon:'👁️',url:'/search?q=kajal&type=product'}
  ];
  function showPop(){
    var h='<div class="ut-suggest-label">Trending Now</div>';
    pop.forEach(function(s){h+='<a href="'+s.url+'" class="ut-suggest-item"><div class="ut-suggest-icon">'+s.icon+'</div><div class="ut-suggest-text"><span class="ut-suggest-name">'+s.name+'</span><span class="ut-suggest-cat">'+s.cat+'</span></div><span class="ut-suggest-price">'+s.price+'</span></a>';});
    sBox.innerHTML=h;
  }
  function showLoad(){sBox.innerHTML='<div class="ut-search-loading"><div class="ut-sdots"><span></span><span></span><span></span></div></div>';}
  function showEmpty(q){sBox.innerHTML='<div class="ut-search-empty">No results for "<strong style="color:var(--ut-gold-l)">'+q+'</strong>"<br><span style="font-size:11px;margin-top:6px;display:block;">Try: Serum, Moisturizer, Hair Oil…</span></div>';}
  function showResults(items,q){
    if(!items||!items.length){showEmpty(q);return;}
    var h='<div class="ut-suggest-label">Products</div>';
    items.slice(0,5).forEach(function(p){
      var pr=p.price_min?'₹'+(p.price_min/100).toLocaleString('en-IN'):'';
      var img=p.featured_image?'<img src="'+p.featured_image+'" alt="" style="width:100%;height:100%;object-fit:cover;">':'🧴';
      h+='<a href="'+p.url+'" class="ut-suggest-item"><div class="ut-suggest-icon">'+img+'</div><div class="ut-suggest-text"><span class="ut-suggest-name">'+p.title+'</span><span class="ut-suggest-cat">'+p.product_type+'</span></div><span class="ut-suggest-price">'+pr+'</span></a>';
    });
    if(items.length>5){h+='<div class="ut-suggest-divider"></div><a href="/search?q='+encodeURIComponent(q)+'&type=product" class="ut-suggest-item" style="justify-content:center;"><span style="font-family:Cinzel,serif;font-size:8px;letter-spacing:0.28em;color:var(--ut-gold);text-transform:uppercase;">View all '+items.length+' results →</span></a>';}
    sBox.innerHTML=h;
  }
  function doSearch(q){
    if(q===lastQ)return;lastQ=q;
    if(!q||q.length<2){showPop();return;}
    showLoad();
    fetch('/search/suggest.json?q='+encodeURIComponent(q)+'&resources[type]=product&resources[limit]=8')
      .then(function(r){return r.json();})
      .then(function(d){var p=(d&&d.resources&&d.resources.results&&d.resources.results.products)||[];showResults(p,q);})
      .catch(function(){showEmpty(q);});
  }
  sInput.addEventListener('input',function(){var q=this.value.trim();clearTimeout(timer);if(!q){showPop();lastQ='';return;}timer=setTimeout(function(){doSearch(q);},280);});
  sInput.addEventListener('focus',function(){if(!this.value.trim())showPop();});

  /* Mobile */
  window.UT=window.UT||{};
  window.UT.closeMob=function(){mobile.classList.remove('open');mobile.setAttribute('aria-hidden','true');burger.classList.remove('open');burger.setAttribute('aria-expanded','false');document.body.style.overflow='';};
  function openMob(){mobile.classList.add('open');mobile.setAttribute('aria-hidden','false');burger.classList.add('open');burger.setAttribute('aria-expanded','true');document.body.style.overflow='hidden';}
  if(burger)burger.addEventListener('click',openMob);
  if(mobOv)mobOv.addEventListener('click',window.UT.closeMob);
  showPop();
})();
</script>
