  {%- assign show_subcats = true -%}
  {%- assign subcat_handles = "foundation|lipstick|kajal-eyeliner|eyeshadow|blush-bronzer|highlighter|mascara|setting-spray" -%}
  {%- assign subcat_labels = "Foundation|Lipstick|Kajal & Eyeliner|Eyeshadow|Blush & Bronzer|Highlighter|Mascara|Setting Spray" -%}
  {%- assign subcat_icons = "🤎|💄|🖤|✨|🌸|⭐|👁️|💦" -%}
  {%- assign subcat_descs = "12 Indian skin shades|All-day vibrant colour|Intense definition|Buildable pigments|Natural sculpt & flush|Radiant glow|Lengthening & volumising|24-hour lock" -%}
  {%- assign cat_seo_text = "Urban Trend Makeup is designed for the bold Indian woman — our foundations cover 12 Indian skin tones, our kajals are smudge-proof for humid weather, and our lipsticks deliver rich pigment that lasts through chai, meals, and long days. Cruelty-free and PETA-certified." -%}
