  {%- assign subcat_descs = "No-nonsense grooming|Beard oils & balms|Anti-dandruff & growth|Bold masculine scents|Body wash & deodorant|Complete grooming kits" -%}
  {%- assign cat_seo_text = "Urban Trend Men's Grooming is built for the modern Indian man — our activated charcoal face washes deep-cleanse without stripping moisture, our beard oils use cold-pressed argan and castor oils for soft manageable beards, and our fragrances are bold, woody, and long-lasting." -%}
