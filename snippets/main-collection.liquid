  {%- assign show_subcats = true -%}
  {%- assign subcat_handles = "body-lotions|body-scrubs|body-oils|hand-nail|foot-care|bath-shower" -%}
  {%- assign subcat_labels = "Body Lotions|Body Scrubs|Body Oils|Hand & Nail|Foot Care|Bath & Shower" -%}
  {%- assign subcat_icons = "🧴|✨|🌿|💅|🦶|🛁" -%}
  {%- assign subcat_descs = "All-day moisturisation|Exfoliate & glow|Nourishing treatment|Soft hands, strong nails|Heel repair & softening|Luxurious rituals" -%}
  {%- assign cat_seo_text = "Urban Trend Body Care transforms everyday rituals into indulgent ceremonies — our saffron body scrubs reveal radiant skin, our shea butter lotions provide 24-hour hydration, and our body oils use cold-pressed Indian botanicals to nourish from head to toe." -%}
