  {%- assign subcat_descs = "Cleanse & strengthen|Deep moisture|Intensive treatment|Traditional rituals|Frizz control|Define & hold" -%}
  {%- assign cat_seo_text = "Urban Trend Hair Care combines ancient Ayurvedic wisdom with modern trichology — our Brahmi-infused hair oils promote growth, our sulphate-free shampoos protect colour-treated hair, and our deep conditioning masks reverse damage caused by pollution and hard water common across Indian cities." -%}
