  {%- assign subcat_handles = "nail-colour|nail-treatments|nail-tools|nail-removal|nail-art|nail-sets" -%}
  {%- assign subcat_labels = "Nail Colour|Treatments|Tools|Removal|Nail Art|Sets & Kits" -%}
