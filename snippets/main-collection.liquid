  {%- assign subcat_handles = "supplements|aromatherapy|sleep-care|stress-relief|immunity|feminine-care" -%}
  {%- assign subcat_labels = "Supplements|Aromatherapy|Sleep Care|Stress Relief|Immunity|Feminine Care" -%}
  {%- assign subcat_icons = "💊|🌿|🌙|🧘|🛡️|🌸" -%}
  {%- assign subcat_descs = "Inner glow supplements|Essential oil rituals|Deep sleep blends|Calm & balance|Daily defence|Gentle intimate care" -%}
