{%- if show_subcats -%}
<div class="ut-subcats-section" style="background:var(--ut-bg);padding:32px 32px 8px;border-bottom:1px solid rgba(201,169,110,0.08);">
  <div style="max-width:1300px;margin:0 auto;">
    <p style="font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.4em;text-transform:uppercase;color:rgba(201,169,110,0.5);margin-bottom:20px;">Shop by Category</p>
    <div class="ut-subcat-grid">
      {%- assign handles_arr = subcat_handles | split: "|" -%}
      {%- assign labels_arr = subcat_labels | split: "|" -%}
      {%- assign icons_arr = subcat_icons | split: "|" -%}
      {%- assign descs_arr = subcat_descs | split: "|" -%}
      {%- for handle in handles_arr -%}
        <a href="/collections/{{ handle }}" class="ut-subcat-card">
          <div class="ut-subcat-icon">{{ icons_arr[forloop.index0] }}</div>
          <div class="ut-subcat-info">
            <span class="ut-subcat-name">{{ labels_arr[forloop.index0] }}</span>
            <span class="ut-subcat-desc">{{ descs_arr[forloop.index0] }}</span>
          </div>
          <span class="ut-subcat-arrow">→</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}


<!-- ── SORT BAR (mobile) ── -->
<div class="ut-coll-sortbar">
  <button class="ut-filter-toggle" onclick="openSidebar()">
    <span>⚙</span> Filters
  </button>
  <button class="ut-sort-btn active" onclick="sortColl('manual',this)">Popularity</button>
  <button class="ut-sort-btn" onclick="sortColl('price-ascending',this)">Price: Low → High</button>
  <button class="ut-sort-btn" onclick="sortColl('price-descending',this)">Price: High → Low</button>
  <button class="ut-sort-btn" onclick="sortColl('created-descending',this)">Newest First</button>
  <button class="ut-sort-btn" onclick="sortColl('best-selling',this)">Best Selling</button>
</div>

<!-- ── MAIN LAYOUT ── -->
<div class="ut-coll-wrap">

  <!-- ── SIDEBAR FILTERS ── -->
  <aside class="ut-sidebar" id="collSidebar">
    <div class="ut-sb-header">
      <span class="ut-sb-header-title">Filters</span>
      <div style="display:flex;gap:10px;align-items:center;">
        <button class="ut-sb-clear" onclick="clearAllFilters()">Clear All</button>
        <button class="ut-sb-close" onclick="closeSidebar()">×</button>
      </div>
    </div>

    <!-- Active chips -->
    <div class="ut-active-chips" id="activeFilterChips"></div>

    <!-- Categories -->
    <div class="ut-fb" id="fb-cat">
      <button class="ut-fb-head" onclick="toggleFb('fb-cat')">
        Categories <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-cats">
          {% assign sub_cats = "Serums,Moisturizers,Toners,Sunscreen,Eye Cream,Face Masks,Cleansers,Exfoliators" | split: "," %}
          {% for sc in sub_cats %}
            <button class="ut-fb-cat" onclick="addFilter('{{ sc }}',this)">
              {{ sc }}
              <span class="ut-fb-cat-count">{{ collection.products_count | divided_by: 8 }}</span>
            </button>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Brand -->
    <div class="ut-fb" id="fb-brand">
      <button class="ut-fb-head" onclick="toggleFb('fb-brand')">
        Brand <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-checks" id="brandFilters">
          {% assign brands = "Urban Trend,Lakmé,Mamaearth,Dot & Key,Plum,mCaffeine,Minimalist,Kama Ayurveda,Forest Essentials,WOW Skin,SUGAR,Biotique" | split: "," %}
          {% for brand in brands limit:6 %}
            <label class="ut-fb-check">
              <input type="checkbox" onchange="toggleFilter('{{ brand }}',this)">
              <span class="ut-fb-check-label">{{ brand }}</span>
              <span class="ut-fb-check-count">{{ collection.products_count | divided_by: 12 }}</span>
            </label>
          {% endfor %}
          <div id="brandMore" style="display:none;">
            {% for brand in brands offset:6 %}
              <label class="ut-fb-check" style="margin-top:8px;">
                <input type="checkbox" onchange="toggleFilter('{{ brand }}',this)">
                <span class="ut-fb-check-label">{{ brand }}</span>
              </label>
            {% endfor %}
          </div>
          <button class="ut-fb-show-more" onclick="toggleBrandMore(this)">+ 6 more brands</button>
        </div>
      </div>
    </div>

    <!-- Price range -->
    <div class="ut-fb" id="fb-price">
      <button class="ut-fb-head" onclick="toggleFb('fb-price')">
        Price Range <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-price-wrap">
          <div class="ut-price-slider-track" id="priceTrack">
            <div class="ut-price-slider-fill" id="priceFill"></div>
            <input class="ut-price-range-inp" type="range" id="priceMin"
              min="0" max="9999" value="0" step="100"
              oninput="updatePriceRange()">
            <input class="ut-price-range-inp" type="range" id="priceMax"
              min="0" max="9999" value="9999" step="100"
              oninput="updatePriceRange()">
          </div>
          <div class="ut-price-inputs">
            <input class="ut-price-in" type="number" id="priceMinInput"
              placeholder="₹ Min" value="0" min="0" oninput="syncPriceSlider()">
            <span class="ut-price-sep">—</span>
            <input class="ut-price-in" type="number" id="priceMaxInput"
              placeholder="₹ Max" value="9999" max="9999" oninput="syncPriceSlider()">
            <button class="ut-price-go" onclick="applyPriceFilter()">Go</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Customer Rating -->
    <div class="ut-fb" id="fb-rating">
      <button class="ut-fb-head" onclick="toggleFb('fb-rating')">
        Customer Rating <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-ratings">
          {% for i in (1..4) reversed %}
            <label class="ut-fb-rating">
              <input type="radio" name="ratingFilter"
                onchange="addFilter('{{ i }}★ & above',null,'rating')">
              <span class="ut-fb-stars">
                {% for s in (1..i) %}★{% endfor %}{% assign r = 5 | minus: i %}{% for s in (1..r) %}☆{% endfor %}
              </span>
              <span class="ut-fb-rating-lbl">& above</span>
            </label>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Discount -->
    <div class="ut-fb" id="fb-disc">
      <button class="ut-fb-head" onclick="toggleFb('fb-disc')">
        Discount <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-discounts">
          {% assign discs = "10% or more,20% or more,30% or more,40% or more,50% or more" | split: "," %}
          {% for d in discs %}
            <button class="ut-disc-btn" onclick="toggleDiscount(this,'{{ d }}')">{{ d }}</button>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Skin Type -->
    <div class="ut-fb" id="fb-skin">
      <button class="ut-fb-head" onclick="toggleFb('fb-skin')">
        Skin Type <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-checks">
          {% assign skintypes = "All Skin Types,Oily Skin,Dry Skin,Combination,Sensitive,Normal" | split: "," %}
          {% for st in skintypes %}
            <label class="ut-fb-check">
              <input type="checkbox" onchange="toggleFilter('{{ st }}',this)">
              <span class="ut-fb-check-label">{{ st }}</span>
            </label>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Concern -->
    <div class="ut-fb" id="fb-concern">
      <button class="ut-fb-head" onclick="toggleFb('fb-concern')">
        Skin Concern <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-checks">
          {% assign concerns = "Brightening,Anti-aging,Acne,Pigmentation,Hydration,Pores,Dark Circles,Uneven Tone" | split: "," %}
          {% for c in concerns %}
            <label class="ut-fb-check">
              <input type="checkbox" onchange="toggleFilter('{{ c }}',this)">
              <span class="ut-fb-check-label">{{ c }}</span>
            </label>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Shade/Color -->
    <div class="ut-fb" id="fb-shade">
      <button class="ut-fb-head" onclick="toggleFb('fb-shade')">
        Shade / Color <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-swatches">
          {% assign shade_names = "Ivory,Beige,Sand,Caramel,Mocha,Espresso,Rose,Coral,Berry,Red,Nude,Gold" | split: "," %}
          {% assign shade_colors = "#F5E6D0,#E8C9A0,#D4A87A,#B8834F,#8B5E3C,#4A2E1A,#E8A0A0,#F4917A,#9B3B6E,#CC2936,#C9A88A,var(--ut-gold)" | split: "," %}
          {% for shade in shade_names %}
            <div class="ut-fb-swatch" title="{{ shade }}" onclick="toggleSwatch(this,'{{ shade }}')" >
              <span class="ut-fb-swatch-in" style="background:{{ shade_colors[forloop.index0] }};"></span>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <!-- Availability -->
    <div class="ut-fb" id="fb-avail">
      <button class="ut-fb-head" onclick="toggleFb('fb-avail')">
        Availability <span class="ut-fb-arrow">▾</span>
      </button>
      <div class="ut-fb-body">
        <div class="ut-fb-checks">
          <label class="ut-fb-check">
            <input type="checkbox" onchange="toggleFilter('In Stock',this)" checked>
            <span class="ut-fb-check-label">In Stock</span>
          </label>
          <label class="ut-fb-check">
            <input type="checkbox" onchange="toggleFilter('Pre-order',this)">
            <span class="ut-fb-check-label">Pre-order</span>
          </label>
        </div>
      </div>
    </div>
  </aside>

  <!-- ── PRODUCTS ── -->
  <div class="ut-coll-content">
    <!-- Top toolbar -->
    <div class="ut-coll-toolbar">
      <p class="ut-coll-result-count">
        Showing <strong>{{ collection.products_count }}</strong> products
      </p>
      <div class="ut-coll-right-tools">
        <div class="ut-coll-view-btns">
          <button class="ut-view-btn active" onclick="setGrid(3,this)" title="3 columns">⊞</button>
          <button class="ut-view-btn" onclick="setGrid(2,this)" title="2 columns">▦</button>
          <button class="ut-view-btn" onclick="setGrid(4,this)" title="4 columns">⊟</button>
        </div>
        <select class="ut-coll-sort-sel" onchange="sortColl(this.value,null)">
          <option value="manual">Popularity</option>
          <option value="best-selling">Best Selling</option>
          <option value="price-ascending">Price: Low → High</option>
          <option value="price-descending">Price: High → Low</option>
          <option value="created-descending">Newest First</option>
          <option value="title-ascending">Name A → Z</option>
        </select>
      </div>
    </div>

    <!-- Grid -->
    {% paginate collection.products by 24 %}
    <div class="ut-coll-grid" id="collGrid">
      {% for product in collection.products %}
        {% assign second_img = product.images[1] %}
        {% assign disc_pct = 0 %}
        {% if product.compare_at_price > product.price %}
          {% assign disc_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
        {% endif %}

        <div class="ut-pc"
          data-tags="{{ product.tags | join: ',' | downcase }}"
          data-vendor="{{ product.vendor | downcase }}"
          data-price="{{ product.price }}"
          data-disc="{{ disc_pct }}">

          <!-- Image -->
          <a href="{{ product.url }}" style="display:block;text-decoration:none;">
            <div class="ut-pc-img">
              {% if product.featured_image %}
                <img class="ut-pc-img-main"
                  src="{{ product.featured_image | img_url: '500x' }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy">
                {% if second_img %}
                  <img class="ut-pc-img-hover"
                    src="{{ second_img | img_url: '500x' }}"
                    alt="{{ second_img.alt | escape }}"
                    loading="lazy">
                {% endif %}
              {% else %}
                <div class="ut-pc-no-img">{{ product.title }}</div>
              {% endif %}

              <!-- Badge -->
              {% if product.tags contains 'new' or forloop.index <= 2 %}
                <span class="ut-pc-badge new">New</span>
              {% elsif product.tags contains 'bestseller' %}
                <span class="ut-pc-badge bestseller">Bestseller</span>
              {% elsif product.tags contains 'hot' %}
                <span class="ut-pc-badge hot">Hot</span>
              {% endif %}

              {% if disc_pct > 0 %}
                <div class="ut-pc-ribbon">{{ disc_pct }}% off</div>
              {% endif %}

              <!-- Wishlist -->
              <button class="ut-pc-wish" onclick="toggleWish(this,event)" aria-label="Wishlist">♡</button>

              <!-- Quick Add -->
              <button class="ut-pc-qadd"
                onclick="quickAdd('{{ product.selected_or_first_available_variant.id }}',this,event)">
                + Quick Add
              </button>
            </div>
          </a>

          <!-- Info -->
          <a href="{{ product.url }}" style="text-decoration:none;display:flex;flex-direction:column;flex:1;">
            <div class="ut-pc-info">
              <div class="ut-pc-brand">{{ product.vendor | default: 'Urban Trend' }}</div>
              <div class="ut-pc-name">{{ product.title }}</div>
              <div class="ut-pc-variant">{{ product.metafields.custom.subtitle | default: product.type }}</div>

              <!-- Rating -->
              <div class="ut-pc-rating">
                <div class="ut-pc-stars-pill">★ 4.{{ forloop.index | modulo: 5 | plus: 5 }}</div>
                <span class="ut-pc-rev-count">({{ forloop.index | times: 127 | plus: 43 }})</span>
              </div>

              <!-- Price -->
              <div class="ut-pc-price-row">
                <span class="ut-pc-price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="ut-pc-compare">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
              {% if disc_pct > 0 %}
              <div style="margin-top:4px;">
                <span style="font-family:'Jost',sans-serif;font-size:11px;color:var(--ut-success);letter-spacing:0.04em;">{{ disc_pct }}% off</span>
                <span style="font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.28);margin-left:4px;">Save {{ product.compare_at_price | minus: product.price | money }}</span>
              </div>
              {% endif %}

              <!-- Assured + free delivery -->
              <div class="ut-pc-assured">
                <span class="ut-pc-assured-badge">✓ Authentic</span>
                {% if product.price >= 99900 %}
                  <span class="ut-pc-free-del">Free Delivery</span>
                {% endif %}
              </div>

              <!-- Color swatches if product has colors -->
              {% if product.options contains 'Color' or product.options contains 'Shade' %}
                <div class="ut-pc-swatches">
                  {% assign color_opts = product.options_with_values | where: "name", "Color" %}
                  {% if color_opts == blank %}
                    {% assign color_opts = product.options_with_values | where: "name", "Shade" %}
                  {% endif %}
                  {% for opt in color_opts %}
                    {% for val in opt.values limit:5 %}
                      <div class="ut-pc-swatch" title="{{ val }}"
                        style="background:{{ val | downcase | replace: ' ',''}};"></div>
                    {% endfor %}
                  {% endfor %}
                </div>
              {% endif %}
            </div>
          </a>
        </div>

      {% else %}
        <div class="ut-coll-empty">
          <p class="ut-coll-empty-title">No products found</p>
          <p class="ut-coll-empty-sub">Try a different category or clear your filters</p>
        </div>
      {% endfor %}
    </div>

    <!-- INFINITE SCROLL SENTINEL -->
    {% if paginate.next %}
    <div id="ut-scroll-sentinel" data-next="{{ paginate.next.url }}" style="height:1px;"></div>
    {% endif %}

    <!-- Loading spinner -->
    <div id="ut-scroll-spinner" style="display:none;justify-content:center;padding:40px;">
      <div style="width:32px;height:32px;border:2px solid rgba(201,169,110,0.2);border-top-color:#C9A96E;border-radius:50%;animation:ut-spin 0.8s linear infinite;"></div>
    </div>

    <!-- End of products -->
    <div id="ut-scroll-end" style="display:none;text-align:center;padding:32px;font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;color:rgba(201,169,110,0.4);text-transform:uppercase;">
      — End of Collection —
    </div>

    <!-- Premium Pagination -->
    {% if paginate.pages > 1 %}
    <div class="ut-pagination" id="utPagination">
      <div class="ut-pag-info">
        <span style="font-family:'Jost',sans-serif;font-size:11px;font-weight:200;color:rgba(250,246,240,0.3);letter-spacing:0.1em;">
          Page {{ paginate.current_page }} of {{ paginate.pages }} &nbsp;·&nbsp; {{ paginate.items }} Products
        </span>
      </div>
      <div class="ut-pag-btns">
        {% if paginate.previous %}
          <a href="{{ paginate.previous.url }}" class="ut-pag-btn ut-pag-arrow" aria-label="Previous page">
            <span>←</span><span style="font-size:9px;letter-spacing:0.2em;margin-left:6px;">PREV</span>
          </a>
        {% endif %}
        {% for part in paginate.parts %}
          {% if part.is_link %}
            <a href="{{ part.url }}" class="ut-pag-btn">{{ part.title }}</a>
          {% elsif part.title == '...' %}
            <span class="ut-pag-ellipsis">···</span>
          {% else %}
            <span class="ut-pag-btn ut-pag-active">{{ part.title }}</span>
          {% endif %}
        {% endfor %}
        {% if paginate.next %}
          <a href="{{ paginate.next.url }}" class="ut-pag-btn ut-pag-arrow" aria-label="Next page">
            <span style="font-size:9px;letter-spacing:0.2em;margin-right:6px;">NEXT</span><span>→</span>
          </a>
        {% endif %}
      </div>
      <div class="ut-pag-progress">
        <div class="ut-pag-prog-fill" style="width:{{ paginate.current_page | times: 100 | divided_by: paginate.pages }}%;"></div>
      </div>
    </div>
    {% endif %}

    <style>
    .ut-pagination{padding:52px 0 24px;display:flex;flex-direction:column;align-items:center;gap:20px;}
    .ut-pag-info{text-align:center;}
    .ut-pag-btns{display:flex;align-items:center;gap:4px;flex-wrap:wrap;justify-content:center;}
    .ut-pag-btn{display:inline-flex;align-items:center;justify-content:center;min-width:40px;height:40px;padding:0 14px;background:rgba(20,18,16,1);border:1px solid rgba(201,169,110,0.12);font-family:'Cinzel',serif;font-size:11px;letter-spacing:0.18em;color:rgba(250,246,240,0.45);text-decoration:none;transition:all 0.25s;cursor:pointer;}
    .ut-pag-btn:hover{border-color:rgba(201,169,110,0.45);color:#C9A96E;background:rgba(201,169,110,0.06);}
    .ut-pag-active{background:rgba(201,169,110,0.12) !important;border-color:rgba(201,169,110,0.55) !important;color:#E2C98A !important;}
    .ut-pag-arrow{gap:2px;padding:0 18px;}
    .ut-pag-ellipsis{font-family:'Cinzel',serif;font-size:11px;color:rgba(250,246,240,0.2);padding:0 8px;line-height:40px;}
    .ut-pag-progress{width:200px;height:1px;background:rgba(201,169,110,0.1);}
    .ut-pag-prog-fill{height:100%;background:linear-gradient(to right,#C9A96E,#E2C98A);transition:width 0.4s ease;}
    @media(max-width:480px){.ut-pag-btn{min-width:36px;height:36px;font-size:10px;padding:0 10px;}}
    </style>

    <!-- Fallback pagination for no-JS -->
    <noscript>
    {% if paginate.pages > 1 %}
    <div class="ut-coll-pages">
      {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="ut-page-btn">←</a>{% endif %}
      {% for part in paginate.parts %}
        {% if part.is_link %}<a href="{{ part.url }}" class="ut-page-btn">{{ part.title }}</a>
        {% else %}<span class="ut-page-btn active">{{ part.title }}</span>{% endif %}
      {% endfor %}
      {% if paginate.next %}<a href="{{ paginate.next.url }}" class="ut-page-btn">→</a>{% endif %}
    </div>
    {% endif %}
    </noscript>

    {% endpaginate %}

    <!-- SEO description -->
    {% if collection.description != blank %}
    <div class="ut-coll-seo">
      <p>{{ collection.description }}</p>
    </div>
    {% endif %}
  </div>
</div>

<script>
var activeFilters = {};

/* ── SIDEBAR ── */
function openSidebar() {
  document.getElementById('collSidebar').classList.add('open');
  document.getElementById('sidebarOverlay').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeSidebar() {
  document.getElementById('collSidebar').classList.remove('open');
  document.getElementById('sidebarOverlay').classList.remove('open');
  document.body.style.overflow = '';
}

/* ── FILTER BLOCKS TOGGLE ── */
function toggleFb(id) {
  document.getElementById(id).classList.toggle('collapsed');
}

/* ── FILTERS ── */
function addFilter(label, btn, group) {
  group = group || label;
  activeFilters[group] = label;
  if (btn) {
    btn.closest('.ut-fb-cats')?.querySelectorAll('.ut-fb-cat').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }
  renderChips();
  applyFilters();
}

function toggleFilter(label, checkbox) {
  if (checkbox.checked) {
    activeFilters[label] = label;
  } else {
    delete activeFilters[label];
  }
  renderChips();
  applyFilters();
}

function toggleSwatch(el, label) {
  el.classList.toggle('active');
  if (el.classList.contains('active')) {
    activeFilters['shade_' + label] = label;
  } else {
    delete activeFilters['shade_' + label];
  }
  renderChips();
  applyFilters();
}

function toggleDiscount(btn, label) {
  btn.classList.toggle('active');
  if (btn.classList.contains('active')) {
    activeFilters['disc'] = label;
  } else {
    delete activeFilters['disc'];
  }
  renderChips();
  applyFilters();
}

function removeFilter(key) {
  delete activeFilters[key];
  // Uncheck corresponding checkbox
  document.querySelectorAll('.ut-fb-check input, .ut-fb-rating input').forEach(inp => {
    var lbl = inp.closest('label')?.querySelector('.ut-fb-check-label,.ut-fb-rating-lbl')?.textContent?.trim();
    if (lbl && activeFilters[lbl] === undefined) inp.checked = false;
  });
  renderChips();
  applyFilters();
}

function clearAllFilters() {
  activeFilters = {};
  document.querySelectorAll('.ut-fb-check input,.ut-fb-rating input').forEach(i => i.checked = false);
  document.querySelectorAll('.ut-fb-cat').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.ut-disc-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.ut-fb-swatch').forEach(s => s.classList.remove('active'));
  document.getElementById('priceMin').value = 0;
  document.getElementById('priceMax').value = 9999;
  document.getElementById('priceMinInput').value = 0;
  document.getElementById('priceMaxInput').value = 9999;
  updatePriceRange();
  renderChips();
  applyFilters();
}

function renderChips() {
  var chips = document.getElementById('activeFilterChips');
  var html = '';
  Object.keys(activeFilters).forEach(key => {
    html += '<div class="ut-chip" onclick="removeFilter(\'' + key + '\')">' +
      activeFilters[key] + '<span class="ut-chip-x">×</span></div>';
  });
  chips.innerHTML = html;
}

function applyFilters() {
  var cards = document.querySelectorAll('.ut-pc');
  var keys = Object.keys(activeFilters);
  if (!keys.length) {
    cards.forEach(c => c.style.display = '');
    return;
  }
  var minP = parseInt(document.getElementById('priceMin').value) * 100;
  var maxP = parseInt(document.getElementById('priceMax').value) * 100;
  cards.forEach(card => {
    var tags = (card.dataset.tags || '').toLowerCase();
    var vendor = (card.dataset.vendor || '').toLowerCase();
    var price = parseInt(card.dataset.price || 0);
    var disc = parseInt(card.dataset.disc || 0);
    var show = true;
    keys.forEach(key => {
      var val = activeFilters[key].toLowerCase();
      if (key === 'price') {
        show = show && (price >= minP && price <= maxP);
      } else if (key === 'disc') {
        var pct = parseInt(val);
        show = show && disc >= pct;
      } else {
        var match = tags.includes(val) || vendor.includes(val);
        show = show && match;
      }
    });
    card.style.display = show ? '' : 'none';
  });
}

/* ── PRICE RANGE ── */
function updatePriceRange() {
  var min = parseInt(document.getElementById('priceMin').value);
  var max = parseInt(document.getElementById('priceMax').value);
  if (min > max) {
    if (event?.target?.id === 'priceMin') { min = max; document.getElementById('priceMin').value = min; }
    else { max = min; document.getElementById('priceMax').value = max; }
  }
  document.getElementById('priceMinInput').value = min;
  document.getElementById('priceMaxInput').value = max;
  var pct1 = min / 9999 * 100;
  var pct2 = max / 9999 * 100;
  document.getElementById('priceFill').style.left = pct1 + '%';
  document.getElementById('priceFill').style.width = (pct2 - pct1) + '%';
}

function syncPriceSlider() {
  var min = parseInt(document.getElementById('priceMinInput').value) || 0;
  var max = parseInt(document.getElementById('priceMaxInput').value) || 9999;
  document.getElementById('priceMin').value = min;
  document.getElementById('priceMax').value = max;
  updatePriceRange();
}

function applyPriceFilter() {
  var min = document.getElementById('priceMin').value;
  var max = document.getElementById('priceMax').value;
  activeFilters['price'] = '₹' + min + '–' + max;
  renderChips();
  applyFilters();
}

/* ── SORT ── */
function sortColl(val, btn) {
  if (btn) {
    document.querySelectorAll('.ut-sort-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
  }
  var url = new URL(window.location.href);
  if (val && val !== 'manual') url.searchParams.set('sort_by', val);
  else url.searchParams.delete('sort_by');
  window.location.href = url.toString();
}

/* ── GRID VIEW ── */
function setGrid(n, btn) {
  document.querySelectorAll('.ut-view-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  var grid = document.getElementById('collGrid');
  grid.className = 'ut-coll-grid' + (n !== 3 ? ' grid-' + n : '');
}

/* ── WISHLIST ── */
function toggleWish(btn, e) {
  e.preventDefault(); e.stopPropagation();
  btn.classList.toggle('active');
  btn.textContent = btn.classList.contains('active') ? '♥' : '♡';
}

/* ── QUICK ADD ── */
function quickAdd(id, btn, e) {
  e.preventDefault(); e.stopPropagation();
  btn.textContent = '…';
  fetch('/cart/add.js', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: id, quantity: 1 })
  }).then(() => {
    btn.textContent = '✓ Added!';
    btn.style.background = 'rgba(40,74,40,0.9)'; btn.style.color = 'var(--ut-success)';
    if (typeof openCartDrawer === 'function') setTimeout(openCartDrawer, 400);
    setTimeout(() => {
      btn.textContent = '+ Quick Add';
      btn.style.background = ''; btn.style.color = '';
    }, 1800);
  }).catch(() => { btn.textContent = '+ Quick Add'; });
}

/* ── SHOW MORE BRANDS ── */
function toggleBrandMore(btn) {
  var more = document.getElementById('brandMore');
  if (more.style.display === 'none') {
    more.style.display = 'block'; btn.textContent = '− Show less';
  } else {
    more.style.display = 'none'; btn.textContent = '+ 6 more brands';
  }
}

// Init price fill
updatePriceRange();
</script>


<!-- ── SEO TEXT BLOCK ── -->
{%- if show_subcats and cat_seo_text != blank -%}
<div class="ut-seo-block" style="background:var(--ut-bg-2);border-top:1px solid rgba(201,169,110,0.08);padding:40px 32px;">
  <div style="max-width:900px;margin:0 auto;">
    <h2 style="font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.38em;text-transform:uppercase;color:rgba(201,169,110,0.55);margin-bottom:14px;">About {{ collection.title }}</h2>
    <p style="font-family:'Jost',sans-serif;font-size:13px;font-weight:200;line-height:1.9;color:rgba(250,246,240,0.45);letter-spacing:0.04em;">{{ cat_seo_text }}</p>
    <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:20px;">
      {%- for handle in handles_arr -%}
        <a href="/collections/{{ handle }}" style="font-family:'Jost',sans-serif;font-size:10px;font-weight:200;color:rgba(201,169,110,0.55);border:1px solid rgba(201,169,110,0.15);padding:5px 14px;text-decoration:none;letter-spacing:0.08em;transition:all 0.2s;" onmouseover="this.style.borderColor='rgba(201,169,110,0.45)';this.style.color='#C9A96E'" onmouseout="this.style.borderColor='rgba(201,169,110,0.15)';this.style.color='rgba(201,169,110,0.55)'">{{ labels_arr[forloop.index0] }}</a>
      {%- endfor -%}
    </div>
  </div>
</div>
{%- endif -%}


{% schema %}{"name":"Collection","tag":"section","settings":[]}{% endschema %}
