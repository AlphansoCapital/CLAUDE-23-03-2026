  {%- assign show_subcats = true -%}
  {%- assign subcat_handles = "shampoo|conditioner|hair-masks|hair-oils|hair-serums|hair-styling" -%}
  {%- assign subcat_labels = "Shampoo|Conditioner|Hair Masks|Hair Oils|Hair Serums|Styling" -%}
