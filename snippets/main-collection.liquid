  {%- assign subcat_descs = "Targeted treatments|Deep hydration|Gentle cleansing|Balance & refine|SPF protection|Dark circles & puffiness|Deep treatment rituals|Reveal fresh skin" -%}
  {%- assign cat_seo_text = "Urban Trend's Skincare range is scientifically formulated for Indian skin — from brightening Vitamin C serums to deeply hydrating moisturisers, our dermatologist-tested formulas address hyperpigmentation, dullness, and dehydration common in Indian climates. Each product uses rare Indian botanicals like saffron, turmeric, and neem." -%}
