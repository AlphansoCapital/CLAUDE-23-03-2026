  {%- assign subcat_labels = "Eau de Parfum|Eau de Toilette|Body Mists|Perfume Oils|Home Fragrance|Gift Sets" -%}
  {%- assign subcat_icons = "🌹|🌺|💨|🫙|🕯️|🎁" -%}
