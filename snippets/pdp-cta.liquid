    <div class="ut-cta-trust-item"><i>↩</i>15-day returns</div>
    <div class="ut-cta-trust-item"><i>🔒</i>Secure checkout</div>
    <div class="ut-cta-trust-item"><i>🧪</i>Dermatologist tested</div>
    <div class="ut-cta-trust-item"><i>🌿</i>Cruelty free</div>
  </div>

</div><!-- /ut-cta -->

<script>
(function(){
  /* ── Shared countdown — one key for the whole page ── */
  var KEY  = 'ut-cta-end-{{ product.handle | escape }}';
  var SECS = 20 * 3600; /* 20-hour flash sale */
  var stored = parseInt(localStorage.getItem(KEY) || '0');
  var now    = Math.floor(Date.now() / 1000);
  var end    = (stored && stored > now) ? stored : now + SECS;
  if (!stored || stored <= now) localStorage.setItem(KEY, end);

  var hEl = document.getElementById('ctaCdH');
  var mEl = document.getElementById('ctaCdM');
  var sEl = document.getElementById('ctaCdS');

  function tick() {
    var rem = Math.max(0, end - Math.floor(Date.now() / 1000));
    if (hEl) hEl.textContent = String(Math.floor(rem / 3600)).padStart(2, '0');
    if (mEl) mEl.textContent = String(Math.floor((rem % 3600) / 60)).padStart(2, '0');
    if (sEl) sEl.textContent = String(rem % 60).padStart(2, '0');
    if (rem > 0) setTimeout(tick, 1000);
    else {
      var wrap = document.querySelector('.ut-cta-cd');
      if (wrap) wrap.style.display = 'none';
      localStorage.removeItem(KEY);
    }
  }
  tick();
})();

/* ── Bundle option select ── */
var ctaSelectedQty   = 2; /* default: Most Popular */
var ctaSelectedPrice = {{ bundle2_price }};

function ctaSelOpt(el) {
  document.querySelectorAll('.ut-cta-opt').forEach(function(o) {
    o.classList.remove('selected');
  });
  el.classList.add('selected');
  el.querySelector('input').checked = true;
  ctaSelectedQty   = parseInt(el.dataset.qty   || '1');
  ctaSelectedPrice = parseInt(el.dataset.price || '{{ base_price }}');
}

/* ── Refill toggle (visual only — no subscription logic yet) ── */
function ctaToggleRefill(el) {
  el.classList.toggle('unchecked');
  var cb = el.querySelector('input');
  if (cb) cb.checked = !el.classList.contains('unchecked');
}

/* ── Add to Bag ── */
function ctaAddBag() {
  var btn = document.getElementById('ctaMainBtn');
  var variantId = {{ variant.id }};

  /* If bundle qty > 1 add directly then open cart drawer */
  if (ctaSelectedQty > 1) {
    if (btn) { btn.textContent = 'Adding…'; btn.disabled = true; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: ctaSelectedQty })
    }).then(function() {
      if (btn) {
        btn.textContent = '✓ Added to Bag';
        btn.classList.add('added');
        btn.disabled = false;
      }
      if (typeof UT !== 'undefined') { UT.updateCartBadge(); }
      if (typeof openCartDrawer === 'function') setTimeout(openCartDrawer, 350);
      setTimeout(function() {
        if (btn) { btn.textContent = 'Add to Bag'; btn.classList.remove('added'); }
      }, 2400);
    }).catch(function() {
      if (btn) { btn.textContent = 'Add to Bag'; btn.disabled = false; }
    });
    return;
  }

  /* Single qty — use global UT helper */
  if (typeof UT !== 'undefined') UT.addToCart(variantId, 1);
  if (btn) {
    btn.textContent = '✓ Added to Bag';
    btn.classList.add('added');
    setTimeout(function() {
      btn.textContent = 'Add to Bag';
      btn.classList.remove('added');
    }, 2400);
  }
}

/* ── Buy Now ── */
function ctaBuyNow() {
  var variantId = {{ variant.id }};
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id: variantId, quantity: ctaSelectedQty })
  }).then(function() { window.location = '/checkout'; });
}

/* ── Wishlist ── */
function ctaToggleWish() {
  var btn = document.getElementById('ctaWishBtn');
  if (!btn) return;
  btn.classList.toggle('active');
  btn.textContent = btn.classList.contains('active') ? '♥' : '♡';
  if (typeof UT !== 'undefined') {
    UT.toast(btn.classList.contains('active') ? 'Added to wishlist' : 'Removed from wishlist', 'info');
  }
}

/* ── Pre-order ── */
function ctaPreOrder() {
  var btn = document.getElementById('ctaMainBtn');
  var variantId = {{ variant.id }};
  if (btn) { btn.textContent = 'Reserving…'; btn.style.opacity = '0.7'; }
  fetch('/cart/add.js', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      id: variantId, quantity: 1,
      properties: { 'Pre-order': 'Yes' }
    })
  }).then(function() {
    if (btn) {
      btn.textContent = '✓ Pre-Order Confirmed!';
      btn.style.background = 'linear-gradient(90deg,rgba(40,74,40,0.9),#1A3A1A)';
      btn.style.opacity = '1';
    }
    if (typeof UT !== 'undefined') {
      UT.fetchCart();
      UT.toast('✓ Pre-order placed!', 'success');
    }
    if (typeof openCartDrawer === 'function') setTimeout(openCartDrawer, 400);
    setTimeout(function() {
      if (btn) {
        btn.textContent = 'Pre-Order Now →';
        btn.style.background = '';
      }
    }, 3200);
  }).catch(function() {
    if (btn) { btn.textContent = 'Pre-Order Now →'; btn.style.opacity = '1'; }
  });
}
</script>
