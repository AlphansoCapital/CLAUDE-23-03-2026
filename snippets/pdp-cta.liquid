{% comment %}
  ============================================================
  PDP CTA SECTION — Urban Trend
  Drop this snippet into main-product.liquid with:
    {% render 'pdp-cta', product: product %}

  REPLACES:
  • The old ut-pdp-atc-row (qty + inline bundle mixed together)
  • The below-fold ut-bundle duplicate block
  • The scattered preorder logic

  WHAT THIS DOES:
  • Single bundle widget, correct placement (above ATC)
  • One shared countdown timer (key: ut-cta-end)
  • Dr. Priya endorsement moved here from below-fold
  • Pre-order / In-stock / Sold-out handled cleanly
  • Bundle math fixed — savings shown vs compare_at_price
  • Full-width ATC button, secondary Buy Now
  • Trust badges below CTA
  ============================================================
{% endcomment %}

{%- liquid
  assign variant     = product.selected_or_first_available_variant
  assign base_price  = variant.price
  assign compare     = variant.compare_at_price
  assign is_preorder = false
  if product.tags contains 'pre-order'
    assign is_preorder = true
  endif

  comment
    Bundle prices — set 2 and 3 discounted vs compare_at_price
    2-set: 60% off compare × 2  → compare × 2 × 0.40
    3-set: 70% off compare × 3  → compare × 3 × 0.30
    If no compare_at_price fall back to base_price discounts
  endcomment

  if compare > base_price
    assign bundle2_price = compare | times: 2 | times: 40 | divided_by: 100
    assign bundle3_price = compare | times: 3 | times: 30 | divided_by: 100
    assign bundle2_orig  = compare | times: 2
    assign bundle3_orig  = compare | times: 3
  else
    assign bundle2_price = base_price | times: 2 | times: 75 | divided_by: 100
    assign bundle3_price = base_price | times: 3 | times: 65 | divided_by: 100
    assign bundle2_orig  = base_price | times: 2
    assign bundle3_orig  = base_price | times: 3
  endif

  assign bundle2_save_pct = bundle2_orig | minus: bundle2_price | times: 100 | divided_by: bundle2_orig
  assign bundle3_save_pct = bundle3_orig | minus: bundle3_price | times: 100 | divided_by: bundle3_orig
-%}

<style>
