  {% comment %} ── 4. BUNDLE OPTIONS (only when in stock, not pre-order) ── {% endcomment %}
  {% if product.available and is_preorder == false %}
    <div class="ut-cta-opts" id="ctaOpts">

      <label class="ut-cta-opt" onclick="ctaSelOpt(this)" data-qty="1" data-price="{{ base_price }}">
        <input type="radio" name="cta-bundle" style="display:none;">
