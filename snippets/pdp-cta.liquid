  {% comment %} ── 3. RATING + STOCK ── {% endcomment %}
  <div class="ut-cta-meta">
    <div>
      <span class="ut-cta-stars">★★★★★</span>
      <span class="ut-cta-score">4.9</span>
      <span class="ut-cta-rcount" onclick="pdpSwitchTab('reviews')">2,847 reviews</span>
