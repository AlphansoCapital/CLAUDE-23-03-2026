{% comment %}
  Urban Trend — Post Purchase Review Request
  
  HOW TO USE:
  1. Go to Shopify Admin > Settings > Checkout
  2. Scroll to "Order status page" > Additional scripts
  3. Paste the script block below (between the SCRIPT tags)
  
  This snippet is also included in theme.liquid for order status page
{% endcomment %}

{% if request.page_type == 'thank_you' or template == 'customers/order' %}
<script>
(function(){
  'use strict';
  var REVIEW_DELAY_DAYS = 7;
  
  // Store order data for review reminder
  function scheduleReviewRequest(orderId, email, productIds) {
    try {
      var existing = JSON.parse(localStorage.getItem('ut_review_queue') || '[]');
      existing.push({
        orderId: orderId,
        email: email,
        productIds: productIds,
        sendAfter: Date.now() + (REVIEW_DELAY_DAYS * 86400000),
        sent: false
      });
      localStorage.setItem('ut_review_queue', JSON.stringify(existing));
    } catch(e) {}
  }

  // Check and show review prompt if due
  function checkReviewPrompts() {
    try {
      var queue = JSON.parse(localStorage.getItem('ut_review_queue') || '[]');
      var now = Date.now();
      var updated = queue.map(function(item) {
        if (!item.sent && now >= item.sendAfter) {
          showReviewPrompt(item);
          item.sent = true;
        }
        return item;
      });
      localStorage.setItem('ut_review_queue', JSON.stringify(updated));
    } catch(e) {}
  }

  function showReviewPrompt(item) {
    var banner = document.createElement('div');
    banner.id = 'ut-review-prompt';
    banner.style.cssText = 'position:fixed;bottom:24px;right:24px;z-index:9999;background:#1A1510;border:1px solid rgba(201,169,110,0.4);padding:24px 28px;max-width:320px;box-shadow:0 8px 32px rgba(0,0,0,0.6);';
    banner.innerHTML = [
      '<button onclick="this.parentElement.remove()" style="position:absolute;top:10px;right:14px;background:none;border:none;color:rgba(250,246,240,0.3);font-size:18px;cursor:pointer;">✕</button>',
      '<p style="font-family:Cinzel,serif;font-size:10px;letter-spacing:.25em;color:#C9A96E;text-transform:uppercase;margin-bottom:8px;">How was your order?</p>',
      '<p style="font-family:Jost,sans-serif;font-size:13px;color:rgba(250,246,240,.7);line-height:1.6;margin-bottom:16px;">Share your experience and help others discover Urban Trend beauty.</p>',
      '<div style="display:flex;gap:8px;">',
      '<a href="/pages/write-review?order=' + item.orderId + '" style="flex:1;background:#C9A96E;color:#0A0908;border:none;padding:12px;font-family:Cinzel,serif;font-size:9px;letter-spacing:.25em;text-transform:uppercase;text-align:center;text-decoration:none;cursor:pointer;">Write Review ★</a>',
      '<button onclick="this.closest(\'#ut-review-prompt\').remove()" style="padding:12px 16px;background:none;border:1px solid rgba(201,169,110,.2);color:rgba(250,246,240,.4);font-family:Cinzel,serif;font-size:8px;letter-spacing:.2em;cursor:pointer;">Later</button>',
      '</div>'
    ].join('');
    document.body.appendChild(banner);
  }

  // Run on page load
  document.addEventListener('DOMContentLoaded', checkReviewPrompts);

  // Expose for Shopify checkout additional scripts
  window.UTReviewRequest = { schedule: scheduleReviewRequest };
})();
</script>
{% endif %}

{% comment %}
=== PASTE THIS IN SHOPIFY ADMIN > SETTINGS > CHECKOUT > ADDITIONAL SCRIPTS ===

<script>
if (typeof Shopify !== 'undefined' && Shopify.checkout) {
  var productIds = (Shopify.checkout.line_items || []).map(function(i){ return i.product_id; });
  // Schedule review request for 7 days after purchase
  if (window.UTReviewRequest) {
    UTReviewRequest.schedule(
      Shopify.checkout.order_id,
      Shopify.checkout.email,
      productIds
    );
  }
}
</script>

=== END OF ADDITIONAL SCRIPTS ===
{% endcomment %}
