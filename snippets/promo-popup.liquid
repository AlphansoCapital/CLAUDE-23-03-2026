<div class="ut-popup" id="promoPopup">
  <div class="ut-popup-box">
    <button class="ut-popup-close" onclick="closePromoPopup()">×</button>
    <div class="ut-popup-img">
      <div style="display:flex;align-items:center;justify-content:center;height:100%;min-height:300px;flex-direction:column;gap:12px;">
        <div style="width:100px;height:100px;border:1px solid rgba(201,169,110,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;">
          <span style="font-size:36px;">🌹</span>
        </div>
        <span style="font-family:Cinzel,serif;font-size:10px;color:var(--ut-gold);letter-spacing:0.3em;text-transform:uppercase;">Urban Trend</span>
      </div>
    </div>
    <div class="ut-popup-content">
      <p class="ut-popup-eyebrow">Welcome Gift</p>
      <h2 class="ut-popup-title">Get 15% Off Your First Order</h2>
      <p class="ut-popup-sub">Join the Glow List and unlock exclusive offers, early access to launches, and beauty tips crafted for Indian skin.</p>
      <input class="ut-popup-input" type="email" id="popupEmail" placeholder="your@email.com">
      <button class="ut-popup-btn" onclick="submitPopupEmail()">Claim My 15% Off</button>
      <p class="ut-popup-skip" onclick="closePromoPopup()">No thanks, I'll pay full price</p>
    </div>
  </div>
</div>
