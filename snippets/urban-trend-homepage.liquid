<script>
(function(){
  var cur = 0, total = 3, timer, dur = 5000;
  var track = document.getElementById('utSliderTrack');
  var dots = document.querySelectorAll('.ut-sdot');
  var progress = document.getElementById('utSliderProgress');

  function go(n){
    document.getElementById('utSlide'+cur).classList.remove('active');
    dots[cur].classList.remove('active');
    cur = (n + total) % total;
    track.style.transform = 'translateX(-' + (cur * 100) + '%)';
    document.getElementById('utSlide'+cur).classList.add('active');
    dots[cur].classList.add('active');
    resetProgress();
  }

  function resetProgress(){
    progress.style.transition = 'none';
    progress.style.width = '0%';
    setTimeout(function(){
      progress.style.transition = 'width ' + dur + 'ms linear';
      progress.style.width = '100%';
    }, 50);
  }

  function startAuto(){
    clearInterval(timer);
    timer = setInterval(function(){ go(cur + 1); }, dur);
  }

  window.utSliderMove = function(dir){ go(cur + dir); startAuto(); };
  window.utSliderGo = function(n){ go(n); startAuto(); };

  // Pause on hover
  var slider = document.getElementById('utSlider');
  slider.addEventListener('mouseenter', function(){ clearInterval(timer); });
  slider.addEventListener('mouseleave', function(){ startAuto(); });

  // Touch swipe
  var startX = 0;
  slider.addEventListener('touchstart', function(e){ startX = e.touches[0].clientX; }, {passive:true});
  slider.addEventListener('touchend', function(e){
    var diff = startX - e.changedTouches[0].clientX;
    if(Math.abs(diff) > 50){ go(cur + (diff > 0 ? 1 : -1)); startAuto(); }
  }, {passive:true});

  resetProgress();
  startAuto();
})();
</script>
