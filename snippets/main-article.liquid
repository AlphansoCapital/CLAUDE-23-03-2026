<style>
.ut-art{background:var(--ut-bg);min-height:100vh;padding:0 0 80px;}
.ut-art-hero{background:linear-gradient(180deg,var(--ut-bg-4) 0%,var(--ut-bg) 100%);padding:48px 32px 40px;border-bottom:1px solid var(--ut-border);}
.ut-art-inner{max-width:780px;margin:0 auto;}
.ut-art-crumb{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.28em;color:rgba(201,169,110,0.35);text-transform:uppercase;margin-bottom:14px;}
.ut-art-crumb a{color:rgba(201,169,110,0.35);text-decoration:none;transition:color 0.2s;}
.ut-art-crumb a:hover{color:var(--ut-gold);}
.ut-art-crumb span{color:rgba(201,169,110,0.18);margin:0 6px;}
.ut-art-cat{font-family:'Cinzel',serif;font-size:7px;letter-spacing:0.4em;color:var(--ut-gold);text-transform:uppercase;margin-bottom:10px;display:block;}
.ut-art-title{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,44px);font-weight:300;color:var(--ut-text);line-height:1.2;margin-bottom:14px;}
.ut-art-meta{display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin-bottom:28px;}
.ut-art-author{font-family:'Jost',sans-serif;font-size:11px;color:rgba(250,246,240,0.55);letter-spacing:0.1em;}
.ut-art-date{font-family:'Jost',sans-serif;font-size:11px;color:rgba(250,246,240,0.3);letter-spacing:0.1em;}
.ut-art-read{font-family:'Jost',sans-serif;font-size:11px;color:rgba(201,169,110,0.45);letter-spacing:0.1em;}
.ut-art-hero-img{width:100%;aspect-ratio:16/9;background:linear-gradient(145deg,var(--ut-bg-4),var(--ut-bg));overflow:hidden;margin-bottom:0;}
.ut-art-hero-img img{width:100%;height:100%;object-fit:cover;}
/* Body */
.ut-art-body{max-width:780px;margin:0 auto;padding:40px 32px;}
@media(max-width:600px){.ut-art-body{padding:28px 16px;}}
.ut-art-body .rte{font-family:'Jost',sans-serif;font-size:15px;color:rgba(250,246,240,0.65);line-height:1.95;letter-spacing:0.03em;}
.ut-art-body .rte h2{font-family:'Cormorant Garamond',serif;font-size:clamp(22px,3vw,30px);font-weight:300;color:var(--ut-text);margin:36px 0 14px;}
.ut-art-body .rte h3{font-family:'Cinzel',serif;font-size:13px;letter-spacing:0.15em;color:var(--ut-gold);margin:28px 0 10px;text-transform:uppercase;}
.ut-art-body .rte p{margin-bottom:18px;}
.ut-art-body .rte strong{color:var(--ut-text);font-weight:500;}
.ut-art-body .rte a{color:var(--ut-gold);text-decoration:underline;}
.ut-art-body .rte blockquote{border-left:2px solid var(--ut-gold);padding:16px 20px;margin:24px 0;background:rgba(201,169,110,0.04);font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:var(--ut-text-65);}
.ut-art-body .rte img{width:100%;height:auto;margin:20px 0;}
.ut-art-body .rte ul,.ut-art-body .rte ol{padding-left:20px;margin-bottom:18px;}
.ut-art-body .rte li{margin-bottom:8px;}
/* Tags */
.ut-art-tags{display:flex;flex-wrap:wrap;gap:8px;margin:28px 0;padding-top:24px;border-top:1px solid var(--ut-border);}
.ut-art-tag{font-family:'Jost',sans-serif;font-size:10px;color:rgba(201,169,110,0.45);border:1px solid var(--ut-border);padding:5px 12px;letter-spacing:0.08em;transition:all 0.2s;text-decoration:none;}
.ut-art-tag:hover{border-color:var(--ut-gold);color:var(--ut-gold);}
/* Share */
.ut-art-share{display:flex;align-items:center;gap:10px;flex-wrap:wrap;margin:20px 0 36px;}
.ut-art-share-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.32em;color:rgba(201,169,110,0.45);text-transform:uppercase;}
.ut-art-share-btn{width:36px;height:36px;border:1px solid var(--ut-border);background:none;color:rgba(250,246,240,0.5);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;text-decoration:none;}
.ut-art-share-btn:hover{border-color:var(--ut-gold);color:var(--ut-gold);}
/* Related products -->
.ut-art-products{margin-top:8px;padding-top:36px;border-top:1px solid var(--ut-border);}
.ut-art-products-title{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.38em;color:rgba(201,169,110,0.45);text-transform:uppercase;margin-bottom:20px;}
.ut-art-prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
@media(max-width:700px){.ut-art-prod-grid{grid-template-columns:repeat(2,1fr);}}
/* Related articles */
.ut-art-related{max-width:1100px;margin:0 auto;padding:0 32px 40px;}
@media(max-width:600px){.ut-art-related{padding:0 16px 28px;}}
.ut-art-related-title{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.38em;color:rgba(201,169,110,0.45);text-transform:uppercase;margin-bottom:20px;display:flex;align-items:center;gap:14px;}
.ut-art-related-title::after{content:'';flex:1;height:1px;background:var(--ut-border);}
.ut-art-related-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;}
@media(max-width:768px){.ut-art-related-grid{grid-template-columns:1fr 1fr;}}
</style>

<div class="ut-art">
  <div class="ut-art-hero">
    <div class="ut-art-inner">
      <div class="ut-art-crumb">
        <a href="{{ routes.root_url }}">Home</a><span>/</span>
        <a href="{{ blog.url }}">{{ blog.title }}</a><span>/</span>
        <span style="color:rgba(201,169,110,0.5);">{{ article.title | truncate: 40 }}</span>
      </div>
      <span class="ut-art-cat">{{ article.tags | first | default: blog.title }}</span>
      <h1 class="ut-art-title">{{ article.title }}</h1>
      <div class="ut-art-meta">
        <span class="ut-art-author">By {{ article.author }}</span>
        <span class="ut-art-date">{{ article.published_at | date: '%d %B %Y' }}</span>
        <span class="ut-art-read">{{ article.content | strip_html | divided_by: 200 | plus: 1 }} min read</span>
      </div>
    </div>
    {% if article.image %}
    <div class="ut-art-hero-img">
      <img src="{{ article.image | img_url: '1200x' }}" alt="{{ article.image.alt | escape }}" loading="eager">
    </div>
    {% endif %}
  </div>

  <div class="ut-art-body">
    <div class="rte">{{ article.content }}</div>

    <!-- Tags -->
    {% if article.tags.size > 0 %}
    <div class="ut-art-tags">
      {% for tag in article.tags %}
        <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="ut-art-tag">{{ tag }}</a>
      {% endfor %}
    </div>
    {% endif %}

    <!-- Share -->
    <div class="ut-art-share">
      <span class="ut-art-share-label">Share</span>
      <a class="ut-art-share-btn" href="https://wa.me/?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" title="WhatsApp">💬</a>
      <a class="ut-art-share-btn" href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" title="Facebook">𝐟</a>
      <a class="ut-art-share-btn" href="https://twitter.com/intent/tweet?text={{ article.title | url_encode }}&url={{ shop.url }}{{ article.url }}" target="_blank" rel="noopener" title="Twitter">𝕏</a>
      <button class="ut-art-share-btn" onclick="navigator.clipboard.writeText(window.location.href);this.textContent='✓'" title="Copy link">🔗</button>
    </div>

    <!-- Featured products in article -->
    <div class="ut-art-products">
      <div class="ut-art-products-title">Products Mentioned in This Article</div>
      <div class="ut-art-prod-grid">
        {% assign shown = 0 %}
        {% for product in collections.all.products %}
          {% if shown < 4 %}{% assign shown = shown | plus: 1 %}
          <a href="{{ product.url }}" style="background:var(--ut-bg-2);border:1px solid var(--ut-border);text-decoration:none;display:block;transition:border-color 0.2s;padding:12px;" onmouseover="this.style.borderColor='rgba(201,169,110,0.3)'" onmouseout="this.style.borderColor='rgba(201,169,110,0.12)'">
            <div style="aspect-ratio:1;background:var(--ut-bg-4);display:flex;align-items:center;justify-content:center;margin-bottom:10px;overflow:hidden;">
              {% if product.featured_image %}<img src="{{ product.featured_image | img_url: '300x' }}" alt="" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
              {% else %}<span style="font-size:28px;">🌹</span>{% endif %}
            </div>
            <div style="font-family:'Cinzel',serif;font-size:10px;color:var(--ut-text);letter-spacing:0.06em;margin-bottom:4px;">{{ product.title | truncate: 24 }}</div>
            <div style="font-family:'Cinzel',serif;font-size:12px;color:var(--ut-gold);">{{ product.price | money }}</div>
          </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- Comments disabled - use app -->
    <div style="margin-top:36px;padding:20px;background:rgba(201,169,110,0.03);border:1px solid var(--ut-border);text-align:center;">
      <p style="font-family:'Jost',sans-serif;font-size:12px;color:rgba(250,246,240,0.38);letter-spacing:0.06em;">Questions about this article? <a href="https://wa.me/919876543210" style="color:var(--ut-gold);">Ask on WhatsApp →</a></p>
    </div>
  </div>

  <!-- Related articles -->
  {% if blog.articles.size > 1 %}
  <div class="ut-art-related">
    <div class="ut-art-related-title">More from the Journal</div>
    <div class="ut-art-related-grid">
      {% for a in blog.articles limit:3 %}
        {% if a.handle != article.handle %}
        <a href="{{ a.url }}" style="background:var(--ut-bg-2);border:1px solid var(--ut-border);text-decoration:none;display:block;transition:border-color 0.2s,transform 0.2s;" onmouseover="this.style.borderColor='rgba(201,169,110,0.3)';this.style.transform='translateY(-2px)'" onmouseout="this.style.borderColor='rgba(201,169,110,0.12)';this.style.transform=''">
          <div style="aspect-ratio:16/9;background:var(--ut-bg-4);overflow:hidden;display:flex;align-items:center;justify-content:center;">
            {% if a.image %}<img src="{{ a.image | img_url: '500x' }}" alt="" style="width:100%;height:100%;object-fit:cover;" loading="lazy">
            {% else %}<span style="font-size:32px;">✨</span>{% endif %}
          </div>
          <div style="padding:14px;">
            <div style="font-family:'Cinzel',serif;font-size:7px;letter-spacing:0.3em;color:var(--ut-gold);text-transform:uppercase;margin-bottom:5px;">{{ a.tags | first | default: 'Beauty' }}</div>
            <div style="font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:300;color:var(--ut-text);line-height:1.3;">{{ a.title | truncate: 50 }}</div>
            <div style="font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.3);margin-top:8px;letter-spacing:0.1em;">{{ a.published_at | date: '%d %b %Y' }}</div>
          </div>
        </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
  {% endif %}
</div>

{% schema %}{"name":"Article","tag":"section","settings":[]}{% endschema %}
