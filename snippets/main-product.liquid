</style>

<!-- Zoom Modal -->
<div class="ut-zoom-modal" id="pdpZoom" onclick="pdpCloseZoom()">
  <button class="ut-zoom-close" onclick="pdpCloseZoom()">×</button>
  <img id="pdpZoomImg" src="" alt="">
</div>

<!-- Product data for JS -->
<div id="pdpData"
  data-product-handle="{{ product.handle }}"
  data-product-title="{{ product.title | escape }}"
  data-product-price="{{ product.price | money }}"
  data-product-img="{{ product.featured_image | img_url: '300x' }}"
  style="display:none;">
</div>

<div class="ut-pdp">
<div class="ut-pdp-wrap">

  <!-- GALLERY -->
  <div class="ut-gal">
    <div class="ut-gal-main" id="pdpGalMain">
      {% if product.compare_at_price > product.price %}
        <div class="ut-gal-badge">
          {% assign save_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
          <span class="ut-badge sale">{{ save_pct }}% Off</span>
        </div>
      {% elsif product.tags contains 'new' %}
        <div class="ut-gal-badge"><span class="ut-badge new">New</span></div>
      {% elsif product.tags contains 'bestseller' %}
        <div class="ut-gal-badge"><span class="ut-badge bestseller">Bestseller</span></div>
      {% endif %}
      <button class="ut-gal-share" onclick="utShare('wa')" title="Share">⬆</button>
      {% if product.featured_image %}
        <img id="pdpMainImg"
          src="{{ product.featured_image | img_url: '800x' }}"
          srcset="{{ product.featured_image | img_url: '400x' }} 400w,
                  {{ product.featured_image | img_url: '600x' }} 600w,
                  {{ product.featured_image | img_url: '800x' }} 800w,
                  {{ product.featured_image | img_url: '1000x' }} 1000w"
          sizes="(max-width:768px) 100vw, 50vw"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="800" height="800"
          fetchpriority="high"
          decoding="async"
          onclick="pdpOpenZoom(this.src)">
      {% else %}
        <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
          <span style="font-family:'Cinzel',serif;font-size:14px;color:var(--ut-gold);letter-spacing:0.25em;text-align:center;padding:24px;">{{ product.title }}</span>
        </div>
      {% endif %}
      <video id="pdpMainVideo" muted loop playsinline style="display:none;width:100%;height:100%;object-fit:cover;"></video>

      <!-- Dimensions overlay -->
      <div class="ut-dim-overlay" id="pdpDimOverlay">
        {% assign dim_w = product.metafields.custom.dim_width | default: '' %}
        {% assign dim_h = product.metafields.custom.dim_height | default: '' %}
        {% assign dim_d = product.metafields.custom.dim_depth | default: '' %}
        <!-- Top horizontal line -->
        <div class="ut-dim-line h" style="top:12%;"></div>
        <div class="ut-dim-label" style="top:calc(12% - 12px);left:50%;transform:translateX(-50%);">{% if dim_w != '' %}{{ dim_w }}{% else %}Width{% endif %}</div>
        <!-- Left vertical line -->
