      .ut-bw-opt-compare{font-size:12px;color:rgba(250,246,240,0.55);text-decoration:line-through;display:block;}
      .ut-bw-refill{display:flex;align-items:flex-start;gap:10px;background:rgba(200,170,110,0.08);border:1px solid rgba(200,170,110,0.3);border-radius:10px;padding:12px 14px;cursor:pointer;margin-bottom:0;}
      .ut-bw-refill input{display:none;}
      .ut-bw-refill-box{width:18px;height:18px;border-radius:4px;border:2px solid #c8aa6e;background:#c8aa6e;color:#111;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
      .ut-bw-refill-text strong{display:block;font-size:13px;color:#ffffff;margin-bottom:2px;}
      .ut-bw-refill-text span{font-size:11px;color:rgba(250,246,240,0.65);}
      </style>

      <script>
      (function(){
        var end=parseInt(localStorage.getItem('ut-bw-end')||0),now=Math.floor(Date.now()/1000);
        if(!end||end<now){end=now+2*3600+10*60+32;localStorage.setItem('ut-bw-end',end);}
        function tick(){
          var rem=end-Math.floor(Date.now()/1000);if(rem<0)rem=0;
          var hh=Math.floor(rem/3600),mm=Math.floor((rem%3600)/60),ss=rem%60;
          var he=document.getElementById('bw-h'),me=document.getElementById('bw-m'),se=document.getElementById('bw-s');
          if(he)he.textContent=String(hh).padStart(2,'0');
          if(me)me.textContent=String(mm).padStart(2,'0');
          if(se)se.textContent=String(ss).padStart(2,'0');
        }
        tick();setInterval(tick,1000);
      })();
      function selBW(el){
        document.querySelectorAll('.ut-bw-opt').forEach(function(o){
          o.classList.remove('ut-bw-selected');
          var r=o.querySelector('.ut-bw-radio');
          if(r){r.classList.remove('ut-bw-radio-checked');}
        });
        el.classList.add('ut-bw-selected');
        var r=el.querySelector('.ut-bw-radio');
        if(r){r.classList.add('ut-bw-radio-checked');}
        el.querySelector('input').checked=true;
      }
