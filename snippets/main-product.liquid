.ut-wr-submit{background:var(--ut-gold);color:var(--ut-bg);border:none;font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.38em;text-transform:uppercase;padding:13px 28px;cursor:pointer;margin-top:14px;transition:background 0.2s;}
.ut-wr-submit:hover{background:var(--ut-gold-light);}

/* CROSS-SELL */
