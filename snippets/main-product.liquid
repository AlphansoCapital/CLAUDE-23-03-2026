.ut-wr-input{width:100%;background:none;border:1px solid rgba(201,169,110,0.15);color:var(--ut-text);font-family:'Jost',sans-serif;font-size:13px;padding:11px 13px;outline:none;letter-spacing:0.04em;transition:border-color 0.2s;}
.ut-wr-input::placeholder{color:rgba(250,246,240,0.2);}
