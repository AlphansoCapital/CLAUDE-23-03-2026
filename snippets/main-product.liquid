<script>
(function(){
  var end=parseInt(localStorage.getItem('bcd-end')||0),now=Math.floor(Date.now()/1000);
  if(!end||end<now){end=now+20*3600;localStorage.setItem('bcd-end',end);}
  function tick(){
    var rem=end-Math.floor(Date.now()/1000);if(rem<0)rem=0;
    var hh=Math.floor(rem/3600),mm=Math.floor((rem%3600)/60),ss=rem%60;
    var he=document.getElementById('bcd-h'),me=document.getElementById('bcd-m'),se=document.getElementById('bcd-s');
    if(he)he.textContent=String(hh).padStart(2,'0');
    if(me)me.textContent=String(mm).padStart(2,'0');
    if(se)se.textContent=String(ss).padStart(2,'0');
  }
  tick();setInterval(tick,1000);
})();
function selBundle(el){
  document.querySelectorAll('.ut-bundle-option').forEach(function(o){o.classList.remove('selected');});
  el.classList.add('selected');
  el.querySelector('input').checked=true;
}
function doBundleATC(){
  var variantId={{ product.selected_or_first_available_variant.id }};
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:variantId,quantity:1})})
  .then(function(){window.location='/cart';}).catch(function(){window.location='/cart';});
}
</script>

