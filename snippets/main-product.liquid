.ut-rev-card{background:var(--ut-bg-2);border:1px solid rgba(201,169,110,0.07);padding:20px;}
.ut-rev-card-top{display:flex;justify-content:space-between;margin-bottom:8px;}
.ut-rev-card-stars{color:var(--ut-gold);font-size:12px;letter-spacing:1px;}
.ut-rev-card-date{font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.22);}
.ut-rev-card-title{font-family:'Cinzel',serif;font-size:12px;color:var(--ut-text);letter-spacing:0.04em;margin-bottom:7px;}
.ut-rev-card-body{font-family:'Jost',sans-serif;font-size:12px;color:rgba(250,246,240,0.52);line-height:1.7;}
.ut-rev-card-author{font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.28);margin-top:10px;display:flex;align-items:center;gap:6px;}
