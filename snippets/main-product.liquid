.ut-bundle-trust{margin-bottom:8px;font-size:13px;}
.ut-bundle-stars{color:#c8aa6e;margin-right:6px;}
.ut-bundle-stock{background:rgba(200,170,110,0.1);border-left:3px solid #c8aa6e;padding:8px 12px;font-size:12px;margin-bottom:18px;border-radius:4px;}
.ut-bundle-options{display:flex;flex-direction:column;gap:10px;margin-bottom:18px;}
.ut-bundle-option{display:flex;align-items:center;justify-content:space-between;border:1.5px solid rgba(200,170,110,0.2);border-radius:10px;padding:14px 16px;cursor:pointer;transition:all .2s;}
