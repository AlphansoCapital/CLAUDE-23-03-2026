var pdpQty = 1;
var pdpStars = 0;

function pdpChQty(d){pdpQty=Math.max(1,pdpQty+d);document.getElementById('pdpQtyNum').textContent=pdpQty;}

function pdpSelectOpt(btn){
  var idx=parseInt(btn.dataset.opt);
  btn.closest('.ut-opt-btns').querySelectorAll('.ut-opt-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  pdpOptions[idx]=btn.dataset.val;
  var lbl=document.getElementById('optVal'+idx);
  if(lbl)lbl.textContent=btn.dataset.val;
  var match=pdpVariants.find(v=>v.options.every((o,i)=>o===pdpOptions[i]));
  if(match){pdpVariantId=match.id;pdpUpdatePrice(match);pdpUpdateVariantImage(match);}
}

function pdpUpdatePrice(v){
  var p=document.getElementById('pdpPrice');
  if(p)p.textContent='₹'+Math.round(v.price/100).toLocaleString('en-IN');
  var c=document.getElementById('pdpCompare');
  var s=document.getElementById('pdpSave');
  if(v.compare_at_price && v.compare_at_price > v.price){
    if(c)c.textContent='₹'+Math.round(v.compare_at_price/100).toLocaleString('en-IN');
    if(c)c.style.display='';
    var pct=Math.round((v.compare_at_price-v.price)*100/v.compare_at_price);
    if(s){s.textContent=pct+'% Off';s.style.display='';}
  } else {
    if(c){c.textContent='';c.style.display='none';}
    if(s){s.textContent='';s.style.display='none';}
  }
}

function pdpAddBag(){
  var bndSel = document.querySelector('#ut-bw input[name="ut-bw-radio"]:checked');
  var bndQty = bndSel ? parseInt(bndSel.dataset.qty) : 1;
  if(bndQty > 1){ 
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:pdpVariantId,quantity:bndQty})}).then(function(){window.location='/cart';});
    return;
  }
  UT.addToCart(pdpVariantId, pdpQty);
  var btn=document.getElementById('pdpAtcBtn');
  btn.textContent='✓ Added'; btn.classList.add('added');
  setTimeout(()=>{btn.textContent='Add to Bag';btn.classList.remove('added');},2200);
}

function pdpBuyNow(){
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:pdpVariantId,quantity:pdpQty})})
    .then(()=>window.location='/checkout');
}

function pdpToggleWish(){
  var btn=document.getElementById('pdpWishBtn');
  btn.classList.toggle('active');
  btn.textContent=btn.classList.contains('active')?'♥':'♡';
  UT.toast(btn.classList.contains('active')?'Added to wishlist':'Removed from wishlist','info');
}

function pdpSwitchImg(src,thumb){
  var m=document.getElementById('pdpGalMain');
  var img=document.getElementById('pdpMainImg');
  var vid=document.getElementById('pdpMainVideo');
  if(vid){vid.pause();vid.style.display='none';m.classList.remove('show-video');}
  if(img){
    img.style.opacity='0';
    img.style.transition='opacity 0.3s ease';
    setTimeout(function(){ img.src=src; img.srcset=''; img.style.display='block'; img.style.opacity='1'; },150);
  }
  document.querySelectorAll('.ut-gal-thumb').forEach(t=>t.classList.remove('active'));
  if(thumb)thumb.classList.add('active');
}

/* Variant→Image map from Liquid */
var pdpVariantImageMap = {
  {% for variant in product.variants %}{% if variant.featured_image %}{{ variant.id }}:{src:'{{ variant.featured_image | img_url: "1000x" }}',alt:'{{ variant.featured_image.alt | default: variant.title | escape }}',pos:{{ variant.featured_image.position | minus: 1 }}}{% unless forloop.last %},{% endunless %}{% endif %}{% endfor %}
};

function pdpUpdateVariantImage(variant){
  if(!variant||!variant.featured_image)return;
  var data=pdpVariantImageMap[variant.id];
  if(!data)return;
  var img=document.getElementById('pdpMainImg');
  var vid=document.getElementById('pdpMainVideo');
  if(vid){vid.pause();vid.style.display='none';}
  if(img){
    img.style.opacity='0';
    img.style.transition='opacity 0.3s ease';
    setTimeout(function(){
      img.src=data.src; img.srcset='';
      if(data.alt)img.alt=data.alt;
      img.style.display='block'; img.style.opacity='1';
    },150);
  }
  var thumbs=document.querySelectorAll('.ut-gal-thumb');
  thumbs.forEach(function(t){t.classList.remove('active');});
  if(thumbs[data.pos]){
    thumbs[data.pos].classList.add('active');
    thumbs[data.pos].scrollIntoView({behavior:'smooth',block:'nearest',inline:'center'});
  }
}

function pdpSwitchVid(src,thumb){
  var m=document.getElementById('pdpGalMain');
  var vid=document.getElementById('pdpMainVideo');
  var img=document.getElementById('pdpMainImg');
  if(img)img.style.display='none';
  if(vid){vid.src=src;vid.style.display='block';vid.play();m.classList.add('show-video');}
  document.querySelectorAll('.ut-gal-thumb').forEach(t=>t.classList.remove('active'));
  thumb.classList.add('active');
  m.style.cursor='default';
}

function pdpOpenZoom(src){
  document.getElementById('pdpZoomImg').src=src;
  document.getElementById('pdpZoom').classList.add('open');
  document.body.style.overflow='hidden';
}
function pdpCloseZoom(){
  document.getElementById('pdpZoom').classList.remove('open');
  document.body.style.overflow='';
}

function pdpToggleDim(){
  var toggle = document.getElementById('pdpDimToggle');
  var overlay = document.getElementById('pdpDimOverlay');
  if(!toggle||!overlay) return;
  var isOn = toggle.classList.toggle('active');
  overlay.classList.toggle('show', isOn);
}

function pdpSwitchTab(id){
  document.querySelectorAll('.ut-pdp-tab').forEach((t,i)=>{
    var panes=['details','reviews','ingredients','faq'];
    t.classList.toggle('active',panes[i]===id);
  });
  document.querySelectorAll('.ut-pdp-tab-pane').forEach(p=>{p.classList.toggle('active',p.id==='pdpTab-'+id);});
  if(id==='reviews'){
    setTimeout(()=>{
      document.querySelectorAll('.ut-rev-bar-fill').forEach(f=>{f.style.width=f.dataset.w+'%';});
    },200);
  }
}

function pdpFilterRevs(btn,type){
  document.querySelectorAll('.ut-rev-filter').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.ut-rev-card').forEach(c=>{
    c.style.display = (type==='all' || c.dataset.stars===type || (type==='verified'&&c.dataset.verified==='true') || type==='photos') ? '' : 'none';
  });
}

function pdpSetStars(n){
  pdpStars=n;
  document.querySelectorAll('#pdpStarPick .ut-sp').forEach((s,i)=>s.classList.toggle('lit',i<n));
}

function pdpSubmitReview(){
  var name=document.getElementById('revName').value.trim();
  var body=document.getElementById('revBody').value.trim();
  if(!name||!body||!pdpStars){UT.toast('Please fill all fields and select a rating','error');return;}
  UT.toast('✓ Review submitted — thank you!','success');
  document.getElementById('revName').value='';
  document.getElementById('revEmail').value='';
  document.getElementById('revTitle').value='';
  document.getElementById('revBody').value='';
  pdpSetStars(0);
}

function pdpCheckPin(){
  var pin=document.getElementById('pinInput').value.trim();
  var res=document.getElementById('pinResult');
  if(pin.length!==6){res.style.display='block';res.style.color='rgba(139,58,82,0.8)';res.textContent='Please enter a valid 6-digit PIN';return;}
  res.style.display='block';res.style.color='rgba(123,200,123,0.9)';
  res.textContent='✓ Delivery available by '+(new Date(Date.now()+4*86400000)).toLocaleDateString('en-IN',{weekday:'long',day:'numeric',month:'short'});
}

// Trigger animations on page load

// ===== PRE-ORDER =====
(function(){
  var isPreorder = {{ product.metafields.custom.is_preorder | default: false }};
  if(isPreorder || '{{ product.tags }}'.includes('preorder')) {
    document.getElementById('preorderBanner')?.classList.add('show');
    var atcBtn = document.getElementById('pdpAtcBtn');
    if(atcBtn) {
      atcBtn.textContent = 'Pre-Order Now →';
      atcBtn.style.background = 'linear-gradient(90deg,var(--ut-rose),var(--ut-gold))';
      atcBtn.style.color = 'var(--ut-text)';
    }
  }
})();

// ===== FREQUENTLY BOUGHT TOGETHER =====
var fbtBasePrice = {{ product.price }};
var fbtItems = [];
document.querySelectorAll('[data-fbt-id]').forEach(function(el) {
  if(el.tagName === 'INPUT') return;
  fbtItems.push({ id: el.dataset.fbtId, price: parseInt(el.dataset.fbtPrice || 0) });
});

function updateFbtTotal() {
  var total = fbtBasePrice;
  document.querySelectorAll('input[data-fbt-id]').forEach(function(cb) {
    if(cb.checked) total += parseInt(cb.dataset.fbtPrice || 0);
  });
  var origTotal = fbtBasePrice;
  document.querySelectorAll('input[data-fbt-id]').forEach(function(cb) {
    origTotal += parseInt(cb.dataset.fbtPrice || 0);
  });
  document.getElementById('fbtTotal').textContent = '₹' + Math.round(total/100).toLocaleString('en-IN');
  var saved = origTotal - total;
  var saveEl = document.getElementById('fbtSave');
  if(saved > 0 && saveEl) {
    saveEl.textContent = ' (Save ₹' + Math.round(saved/100).toLocaleString('en-IN') + ')';
  }
}

function addFbtToCart() {
  var btn = document.querySelector('.ut-fbt-atc');
  btn.textContent = 'Adding…';
  var items = [{ id: pdpVariantId, quantity: 1 }];
  document.querySelectorAll('input[data-fbt-id]:checked').forEach(function(cb) {
    items.push({ id: cb.dataset.fbtId, quantity: 1 });
  });
  var promises = items.map(item =>
    fetch('/cart/add.js', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(item)
    })
  );
  Promise.all(promises).then(function() {
    btn.textContent = '✓ All Added!';
    btn.style.background = 'rgba(40,74,40,0.9)'; btn.style.color = 'var(--ut-success)';
    if(typeof openCartDrawer === 'function') setTimeout(openCartDrawer, 400);
    setTimeout(function() {
      btn.textContent = 'Add All to Bag';
      btn.style.background = ''; btn.style.color = '';
    }, 2200);
    if(typeof UT !== 'undefined') UT.updateCartBadge();
  }).catch(function() { btn.textContent = 'Add All to Bag'; });
}

// Init FBT total
updateFbtTotal();

// ===== YOU MIGHT BE INTERESTED IN — TAB FILTER =====
function ymalTab(btn, type) {
  document.querySelectorAll('.ut-ymal-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.ut-ymal-card').forEach(card => {
    var tags = card.dataset.tags || '';
    var cardType = card.dataset.type || '';
    if(type === 'all') {
      card.style.display = '';
    } else if(type === 'bestseller') {
      card.style.display = tags.includes('bestseller') ? '' : 'none';
    } else {
      card.style.display = (tags.includes(type) || cardType.includes(type)) ? '' : 'none';
    }
  });
}


/* ── FBT CART ── */
function addFbtToCart() {
  var checks = document.querySelectorAll('.ut-fbt-check.checked');
  var btn = document.querySelector('.ut-fbt-add-btn');
  if(!checks.length) return;
  var items = [];
  document.querySelectorAll('#fbtProducts .ut-fbt-item').forEach(function(item,idx) {
    var chk = item.querySelector('.ut-fbt-check');
    if(!chk || !chk.classList.contains('checked')) return;
    var priceEl = item.querySelector('.ut-fbt-item-price');
    var id = priceEl?.dataset?.id;
    if(id) items.push({id:parseInt(id),quantity:1});
    else items.push({id:pdpVariantId,quantity:pdpQty});
  });
  if(btn){btn.textContent='Adding…';btn.style.opacity='0.7';}
  var addNext = function(i) {
    if(i >= items.length){
      if(btn){btn.textContent='✓ Added All!';btn.style.background='rgba(40,74,40,0.9)';btn.style.color='var(--ut-success)';}
      if(typeof UT!=='undefined'){UT.fetchCart();setTimeout(openCartDrawer,400);UT.toast('✓ '+items.length+' items added to bag!','success');}
      setTimeout(function(){if(btn){btn.textContent='Add All to Bag →';btn.style.background='';btn.style.color='';btn.style.opacity='';}},2200);
      return;
    }
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(items[i])}).then(function(){addNext(i+1);});
  };
  addNext(0);
}

function toggleFbt(idx, btn) {
  btn.classList.toggle('checked');
  btn.textContent = btn.classList.contains('checked') ? '✓' : '';
  calcFbtTotal();
}

function calcFbtTotal() {
  var total = 0; var count = 0;
  document.querySelectorAll('#fbtProducts .ut-fbt-item').forEach(function(item) {
    var chk = item.querySelector('.ut-fbt-check');
    if(chk && chk.classList.contains('checked')) {
      var p = parseInt(item.querySelector('.ut-fbt-item-price')?.dataset?.price || 0);
      total += p; count++;
    }
  });
  var el = document.getElementById('fbtTotal');
  var saveEl = document.getElementById('fbtSave');
  if(el) el.textContent = '₹'+Math.round(total/100).toLocaleString('en-IN');
  if(saveEl && count > 1) {
    saveEl.textContent = 'Save ₹'+Math.round(total*0.05/100).toLocaleString('en-IN')+' when bought together';
  } else if(saveEl) { saveEl.textContent=''; }
}

/* ── PRE-ORDER TIMER ── */
(function(){
  var poD=document.getElementById('poD'); if(!poD) return;
  var endTime = Math.floor(Date.now()/1000)+15*24*3600;
  function tick(){
    var r=Math.max(0,endTime-Math.floor(Date.now()/1000));
    poD.textContent=String(Math.floor(r/86400)).padStart(2,'0');
    document.getElementById('poH').textContent=String(Math.floor((r%86400)/3600)).padStart(2,'0');
    document.getElementById('poM').textContent=String(Math.floor((r%3600)/60)).padStart(2,'0');
    document.getElementById('poS').textContent=String(r%60).padStart(2,'0');
    if(r>0) setTimeout(tick,1000);
  }
  tick();
})();

function pdpPreOrder(){
  var btn=document.getElementById('pdpAtcBtn');
  if(btn){btn.textContent='Reserving…';btn.style.opacity='0.7';}
  fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json'},
    body:JSON.stringify({id:pdpVariantId,quantity:pdpQty,properties:{'Pre-order':'Yes'}})
  }).then(function(){
    if(btn){btn.textContent='✓ Pre-Order Confirmed!';btn.style.background='linear-gradient(90deg,rgba(40,74,40,0.9),#1A3A1A)';}
    if(typeof UT!=='undefined'){UT.fetchCart();setTimeout(openCartDrawer,400);UT.toast('✓ Pre-order placed!','success');}
    setTimeout(function(){if(btn){btn.textContent='Pre-Order Now →';btn.style.background='';btn.style.opacity='';}},3000);
  }).catch(function(){if(btn){btn.textContent='Pre-Order Now →';btn.style.opacity='';}});
}

function ymlTab(btn, pane) {
  document.querySelectorAll('.ut-yml-tab').forEach(function(b){b.classList.remove('active');});
  document.querySelectorAll('.ut-yml-pane').forEach(function(p){p.classList.remove('active');});
  btn.classList.add('active');
  var el=document.getElementById('yml-'+pane);
  if(el) el.classList.add('active');
}

document.addEventListener('DOMContentLoaded',()=>{
  UT.initCountdown();
  UT.initAnimations();
  UT.trackCurrentProduct();
  UT.initRecentlyViewed();
  setTimeout(calcFbtTotal, 200);
  setTimeout(()=>{
    document.querySelectorAll('.ut-rev-bar-fill').forEach(f=>{f.style.width='0';});
  },100);
});
</script>


