.ut-rev-helpful{font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.22);margin-top:8px;display:flex;align-items:center;gap:6px;}
.ut-rev-hbtn{background:none;border:1px solid rgba(201,169,110,0.1);color:rgba(201,169,110,0.35);font-size:10px;padding:3px 9px;cursor:pointer;font-family:'Jost',sans-serif;transition:all 0.2s;}
.ut-rev-hbtn:hover{border-color:var(--ut-gold);color:var(--ut-gold);}
/* Write review */
.ut-write-rev{border:1px solid rgba(201,169,110,0.1);padding:28px;margin-top:8px;}
.ut-wr-title{font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.3em;color:rgba(201,169,110,0.55);text-transform:uppercase;margin-bottom:18px;}
.ut-star-pick-row{display:flex;gap:6px;margin-bottom:14px;}
.ut-sp{font-size:22px;color:rgba(201,169,110,0.2);cursor:pointer;transition:color 0.15s;line-height:1;}
.ut-sp.lit{color:var(--ut-gold);}
.ut-wr-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px;}
