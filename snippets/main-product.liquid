{% comment %} ── PRODUCT PAGE SEO ── {% endcomment %}
<title>{{ product.title | escape }} | {{ product.type }} | Urban Trend India</title>
{% if product.description != blank %}
  <meta name="description" content="{{ product.description | strip_html | truncate: 155 | escape }}">
{% else %}
  <meta name="description" content="Buy {{ product.title }} online at Urban Trend. {{ product.type }} crafted for Indian skin. Dermatologist-tested, cruelty-free. Free shipping above ₹999. Cash on delivery available.">
{% endif %}
<meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1">
<link rel="canonical" href="{{ canonical_url }}">

<meta property="og:type" content="product">
<meta property="og:title" content="{{ product.title | escape }} | Urban Trend">
<meta property="og:description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
{% if product.featured_image %}
  <meta property="og:image" content="https:{{ product.featured_image | img_url: '1200x630', crop: 'center' }}">
  <meta property="og:image:alt" content="{{ product.featured_image.alt | default: product.title | escape }}">
{% endif %}
<meta property="product:price:amount" content="{{ product.price | money_without_currency }}">
<meta property="product:price:currency" content="{{ cart.currency.iso_code }}">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ product.title | escape }} | Urban Trend">
<meta name="twitter:description" content="{{ product.description | strip_html | truncate: 200 | escape }}">
{% if product.featured_image %}
  <meta name="twitter:image" content="https:{{ product.featured_image | img_url: '1200x628', crop: 'center' }}">
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "{{ product.title | escape }}",
  "description": "{{ product.description | strip_html | truncate: 500 | escape }}",
  "brand": {
    "@type": "Brand",
    "name": "Urban Trend",
    "url": "{{ shop.url }}"
  },
  "sku": "{{ product.selected_or_first_available_variant.sku | escape }}",
  "mpn": "{{ product.id }}",
  "gtin": "{{ product.selected_or_first_available_variant.barcode | escape }}",
  "category": "{{ product.type | escape }}",
  "url": "{{ canonical_url }}",
  "image": [
    {% if product.images.size > 0 %}
      {% for image in product.images limit: 7 %}
        "https:{{ image | img_url: '800x800', crop: 'center' }}"{% unless forloop.last %},{% endunless %}
      {% endfor %}
    {% endif %}
  ],
  "offers": {
    "@type": "Offer",
    "url": "{{ canonical_url }}",
    "priceCurrency": "INR",
    "price": "{{ product.price | money_without_currency }}",
    {% if product.compare_at_price > product.price %}
    "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": "{{ product.price | money_without_currency }}",
      "priceCurrency": "INR",
      "referenceQuantity": {"@type": "QuantitativeValue", "value": "1"}
    },
    {% endif %}
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {
      "@type": "Organization",
      "name": "Urban Trend",
      "url": "{{ shop.url }}"
    },
    "shippingDetails": {
      "@type": "OfferShippingDetails",
      "shippingRate": {
        "@type": "MonetaryAmount",
        "value": {% if product.price >= 99900 %}"0"{% else %}"99"{% endif %},
        "currency": "INR"
      },
      "shippingDestination": {"@type": "DefinedRegion", "addressCountry": "IN"},
      "deliveryTime": {
        "@type": "ShippingDeliveryTime",
        "handlingTime": {"@type": "QuantitativeValue", "minValue": 1, "maxValue": 2, "unitCode": "DAY"},
        "transitTime": {"@type": "QuantitativeValue", "minValue": 3, "maxValue": 7, "unitCode": "DAY"}
      }
    },
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "applicableCountry": "IN",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 30,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/FreeReturn"
    }
  }
  {% if product.metafields.reviews.rating %}
  ,"aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.reviews.rating.value }}",
    "reviewCount": "{{ product.metafields.reviews.rating_count.value }}",
    "bestRating": "5",
    "worstRating": "1"
  }
  {% endif %}
  {% if product.tags contains 'faq' %}
  ,"mainEntity": [
    {
      "@type": "Question",
      "name": "Is {{ product.title }} suitable for Indian skin?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, {{ product.title }} is dermatologist-tested and specifically formulated for Indian skin types and climate conditions."}
    },
    {
      "@type": "Question",
      "name": "Is {{ product.title }} cruelty-free?",
      "acceptedAnswer": {"@type": "Answer", "text": "Yes, all Urban Trend products including {{ product.title }} are 100% cruelty-free and PETA certified."}
    }
  ]
  {% endif %}
}
</script>

{% comment %}World class product detail page{% endcomment %}
<style>
.ut-pdp{background:var(--ut-bg);}
.ut-pdp-wrap{max-width:1200px;margin:0 auto;padding:40px 40px 60px;display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:start;}
@media(max-width:960px){.ut-pdp-wrap{grid-template-columns:1fr;gap:36px;padding:24px 20px 48px;}}

/* GALLERY */
.ut-gal{position:sticky;top:84px;}
.ut-gal-main{aspect-ratio:3/4;background:linear-gradient(145deg,var(--ut-bg-4),var(--ut-bg));border:1px solid rgba(201,169,110,0.12);overflow:hidden;position:relative;cursor:zoom-in;}
.ut-gal-main img,.ut-gal-main video{width:100%;height:100%;object-fit:cover;display:block;}
.ut-gal-main video{display:none;}
.ut-gal-main.show-video img{display:none;}
.ut-gal-main.show-video video{display:block;}
.ut-gal-main:hover img{transform:scale(1.03);transition:transform 0.5s ease;}
.ut-gal-badge{position:absolute;top:14px;left:14px;z-index:3;}
.ut-gal-share{position:absolute;top:14px;right:14px;background:rgba(10,9,8,0.65);border:1px solid rgba(201,169,110,0.2);color:var(--ut-gold);width:38px;height:38px;display:flex;align-items:center;justify-content:center;cursor:pointer;z-index:3;font-size:16px;backdrop-filter:blur(4px);transition:all 0.2s;}
.ut-gal-share:hover{background:rgba(201,169,110,0.15);}
.ut-gal-thumbs{display:flex;gap:8px;margin-top:10px;overflow-x:auto;padding-bottom:4px;}
.ut-gal-thumbs::-webkit-scrollbar{height:2px;}
.ut-gal-thumbs::-webkit-scrollbar-thumb{background:rgba(201,169,110,0.2);}
.ut-gal-thumb{width:68px;height:84px;flex-shrink:0;border:1px solid rgba(201,169,110,0.1);cursor:pointer;overflow:hidden;background:var(--ut-bg-4);transition:border-color 0.2s;position:relative;}
.ut-gal-thumb:hover,.ut-gal-thumb.active{border-color:var(--ut-gold);}
.ut-gal-thumb img,.ut-gal-thumb video{width:100%;height:100%;object-fit:cover;pointer-events:none;}
.ut-gal-thumb .play-icon{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.35);color:var(--ut-gold);font-size:18px;}
/* Zoom */
.ut-zoom-modal{position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:99999;display:none;align-items:center;justify-content:center;cursor:zoom-out;}
.ut-zoom-modal.open{display:flex;}
.ut-zoom-modal img{max-width:90vw;max-height:90vh;object-fit:contain;}
.ut-zoom-close{position:absolute;top:20px;right:24px;background:none;border:none;color:var(--ut-gold);font-size:32px;cursor:pointer;line-height:1;}

/* INFO */
.ut-pdp-info{}
.ut-pdp-crumb{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.28em;color:rgba(201,169,110,0.35);text-transform:uppercase;margin-bottom:16px;}
.ut-pdp-crumb a{color:rgba(201,169,110,0.35);transition:color 0.2s;}
.ut-pdp-crumb a:hover{color:var(--ut-gold);}
.ut-pdp-crumb span{color:rgba(201,169,110,0.2);margin:0 6px;}
.ut-pdp-badge-row{margin-bottom:12px;}
.ut-pdp-title{font-family:'Cinzel',serif;font-size:clamp(22px,2.8vw,34px);font-weight:400;color:var(--ut-text);letter-spacing:0.05em;line-height:1.2;margin:0 0 6px;}
.ut-pdp-vendor{font-family:'Jost',sans-serif;font-size:11px;color:rgba(250,246,240,0.35);letter-spacing:0.2em;text-transform:uppercase;margin-bottom:16px;}
/* Rating */
.ut-pdp-rating{display:flex;align-items:center;gap:10px;margin-bottom:18px;padding-bottom:18px;border-bottom:1px solid rgba(201,169,110,0.08);flex-wrap:wrap;}
.ut-pdp-stars{color:var(--ut-gold);font-size:14px;letter-spacing:2px;}
.ut-pdp-score{font-family:'Cinzel',serif;font-size:13px;color:var(--ut-gold);}
.ut-pdp-rcount{font-family:'Jost',sans-serif;font-size:11px;color:rgba(250,246,240,0.4);cursor:pointer;text-decoration:underline;}
.ut-pdp-rcount:hover{color:var(--ut-gold);}
.ut-pdp-verified{font-family:'Jost',sans-serif;font-size:9px;color:var(--ut-success);border:1px solid rgba(123,200,123,0.3);padding:3px 8px;letter-spacing:0.1em;}
/* Price */
.ut-pdp-price-row{display:flex;align-items:baseline;gap:12px;margin-bottom:6px;flex-wrap:wrap;}
.ut-pdp-price{font-family:'Cinzel',serif;font-size:32px;color:var(--ut-gold);}
.ut-pdp-compare{font-family:'Jost',sans-serif;font-size:17px;color:rgba(250,246,240,0.25);text-decoration:line-through;}
.ut-pdp-save{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.25em;color:var(--ut-text);background:var(--ut-rose);padding:4px 12px;text-transform:uppercase;}
.ut-pdp-tax{font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.28);letter-spacing:0.06em;margin-bottom:14px;}
.ut-pdp-emi{font-family:'Jost',sans-serif;font-size:11px;color:rgba(250,246,240,0.45);margin-bottom:18px;padding:10px 14px;border:1px solid rgba(201,169,110,0.1);background:rgba(201,169,110,0.02);}
.ut-pdp-emi span{color:var(--ut-gold);}
/* Countdown */
.ut-pdp-timer{margin-bottom:16px;}
/* Stock */
.ut-pdp-stock{margin-bottom:14px;}
/* Options */
.ut-opt-header{display:flex;justify-content:space-between;align-items:center;font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.33em;color:rgba(201,169,110,0.5);text-transform:uppercase;margin:18px 0 10px;}
.ut-opt-header em{font-style:normal;color:var(--ut-text);font-size:10px;letter-spacing:0.1em;}
.ut-opt-header .size-link{color:rgba(201,169,110,0.45);font-size:8px;letter-spacing:0.2em;cursor:pointer;text-decoration:underline;transition:color 0.2s;}
.ut-opt-header .size-link:hover{color:var(--ut-gold);}
.ut-opt-btns{display:flex;flex-wrap:wrap;gap:8px;}
.ut-opt-btn{font-family:'Jost',sans-serif;font-size:12px;color:rgba(250,246,240,0.55);border:1px solid rgba(201,169,110,0.18);background:none;padding:9px 18px;cursor:pointer;transition:all 0.2s;letter-spacing:0.04em;}
.ut-opt-btn:hover{border-color:rgba(201,169,110,0.5);}
.ut-opt-btn.active{border-color:var(--ut-gold);color:var(--ut-gold);background:rgba(201,169,110,0.06);}
.ut-opt-btn.soldout{opacity:0.3;cursor:not-allowed;text-decoration:line-through;}

/* COLOR SWATCHES */
.ut-swatch-btns{display:flex;flex-wrap:wrap;gap:8px;}
.ut-swatch-btn{width:38px;height:38px;border-radius:50%;border:2px solid transparent;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;padding:0;background:none;flex-shrink:0;}
.ut-swatch-btn img{width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;}
.ut-swatch-btn.active{border-color:var(--ut-gold);box-shadow:0 0 0 2px var(--ut-bg),0 0 0 4px var(--ut-gold);}
.ut-swatch-btn:hover{border-color:var(--ut-gold-45);}
.ut-swatch-btn.soldout{opacity:0.35;cursor:not-allowed;}
.ut-swatch-btn.soldout::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(45deg,transparent,transparent 4px,rgba(0,0,0,0.4) 4px,rgba(0,0,0,0.4) 5px);border-radius:50%;}

/* DIMENSIONS TOGGLE */
.ut-dim-toggle{position:absolute;bottom:14px;left:14px;z-index:4;display:flex;align-items:center;gap:8px;background:rgba(10,9,8,0.75);border:1px solid rgba(201,169,110,0.2);padding:7px 12px;backdrop-filter:blur(6px);cursor:pointer;user-select:none;}
.ut-dim-toggle span{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.18em;color:rgba(250,246,240,0.7);text-transform:uppercase;}
.ut-dim-switch{width:32px;height:18px;background:rgba(201,169,110,0.2);border-radius:9px;position:relative;transition:background 0.25s;flex-shrink:0;}
.ut-dim-switch::after{content:'';position:absolute;top:2px;left:2px;width:14px;height:14px;background:rgba(250,246,240,0.5);border-radius:50%;transition:all 0.25s;}
.ut-dim-toggle.active .ut-dim-switch{background:var(--ut-gold);}
.ut-dim-toggle.active .ut-dim-switch::after{left:16px;background:var(--ut-bg);}
.ut-dim-overlay{position:absolute;inset:0;pointer-events:none;z-index:2;opacity:0;transition:opacity 0.35s;}
.ut-dim-overlay.show{opacity:1;}
.ut-dim-line{position:absolute;background:rgba(250,246,240,0.85);}
.ut-dim-line.h{height:1px;left:20%;right:20%;}
.ut-dim-line.v{width:1px;top:10%;bottom:10%;}
.ut-dim-label{position:absolute;font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.12em;color:var(--ut-text);background:rgba(10,9,8,0.8);padding:2px 8px;white-space:nowrap;}
/* Qty + CTA */
.ut-pdp-atc-row{display:flex;gap:10px;margin:22px 0 10px;align-items:stretch;}
.ut-pdp-qty{display:flex;align-items:center;border:1px solid rgba(201,169,110,0.2);flex-shrink:0;}
.ut-pdp-qty button{background:none;border:none;color:var(--ut-gold);font-size:20px;width:42px;height:50px;cursor:pointer;transition:background 0.2s;line-height:1;}
.ut-pdp-qty button:hover{background:rgba(201,169,110,0.06);}
.ut-pdp-qty span{font-family:'Cinzel',serif;font-size:14px;color:var(--ut-text);width:38px;text-align:center;user-select:none;}
.ut-pdp-atc{flex:1;background:var(--ut-gold);color:var(--ut-bg);border:none;font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.42em;text-transform:uppercase;height:50px;cursor:pointer;transition:all 0.3s;padding:0 16px;white-space:nowrap;}
.ut-pdp-atc:hover{background:var(--ut-gold-light);}
.ut-pdp-atc:active{transform:scale(0.98);}
.ut-pdp-atc.added{background:rgba(40,74,40,0.9);color:var(--ut-success);}
.ut-pdp-wish{width:50px;height:50px;border:1px solid rgba(201,169,110,0.2);background:none;color:rgba(201,169,110,0.55);font-size:20px;cursor:pointer;transition:all 0.2s;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.ut-pdp-wish:hover,.ut-pdp-wish.active{border-color:var(--ut-rose);color:var(--ut-rose);}
.ut-pdp-buy{width:100%;background:none;border:1px solid rgba(201,169,110,0.28);color:var(--ut-gold);font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.42em;text-transform:uppercase;height:48px;cursor:pointer;transition:all 0.2s;margin-bottom:18px;}
.ut-pdp-buy:hover{background:rgba(201,169,110,0.06);}
/* Trust */
.ut-pdp-trust{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;}
.ut-pdp-trust-item{display:flex;align-items:center;gap:8px;font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.45);padding:8px 10px;border:1px solid rgba(201,169,110,0.07);}
.ut-pdp-trust-item i{color:var(--ut-gold);font-style:normal;}
/* Pincode */
.ut-pdp-delivery{padding:12px 14px;border:1px solid rgba(201,169,110,0.1);margin-bottom:20px;}
.ut-pdp-delivery-head{display:flex;align-items:center;gap:8px;font-family:'Jost',sans-serif;font-size:12px;color:rgba(250,246,240,0.55);margin-bottom:10px;}
.ut-pdp-delivery-head i{color:var(--ut-gold);font-style:normal;}
.ut-pdp-pin-row{display:flex;gap:8px;}
.ut-pdp-pin-input{background:none;border:1px solid rgba(201,169,110,0.15);color:var(--ut-text);font-family:'Jost',sans-serif;font-size:12px;padding:8px 12px;width:130px;outline:none;letter-spacing:0.06em;}
.ut-pdp-pin-input::placeholder{color:rgba(250,246,240,0.2);}
.ut-pdp-pin-btn{background:none;border:1px solid rgba(201,169,110,0.25);color:var(--ut-gold);font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.25em;padding:8px 14px;cursor:pointer;text-transform:uppercase;transition:all 0.2s;white-space:nowrap;}
.ut-pdp-pin-btn:hover{background:rgba(201,169,110,0.06);}
.ut-pdp-pin-result{font-family:'Jost',sans-serif;font-size:11px;margin-top:8px;display:none;letter-spacing:0.04em;}
/* Share */
.ut-pdp-share{display:flex;align-items:center;gap:8px;padding:14px 0;border-top:1px solid rgba(201,169,110,0.08);flex-wrap:wrap;}
.ut-pdp-share-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.35em;color:rgba(201,169,110,0.4);text-transform:uppercase;}
.ut-pdp-share-btn{width:32px;height:32px;border:1px solid rgba(201,169,110,0.15);background:none;color:rgba(201,169,110,0.5);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:13px;transition:all 0.2s;}
.ut-pdp-share-btn:hover{border-color:var(--ut-gold);color:var(--ut-gold);}
/* Description */
.ut-pdp-desc{font-family:'Jost',sans-serif;font-size:14px;color:rgba(250,246,240,0.6);line-height:1.9;margin-bottom:22px;padding-top:20px;border-top:1px solid rgba(201,169,110,0.08);}
/* Accordion */
.ut-acc{border-top:1px solid rgba(201,169,110,0.08);}
.ut-acc-item{border-bottom:1px solid rgba(201,169,110,0.08);}
.ut-acc-btn{width:100%;display:flex;justify-content:space-between;align-items:center;padding:15px 0;cursor:pointer;background:none;border:none;font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.3em;color:rgba(201,169,110,0.6);text-transform:uppercase;text-align:left;transition:color 0.2s;}
.ut-acc-btn:hover{color:var(--ut-gold);}
.ut-acc-btn .icon{font-size:16px;color:var(--ut-gold);transition:transform 0.3s;flex-shrink:0;}
.ut-acc-btn.open .icon{transform:rotate(45deg);}
.ut-acc-body{font-family:'Jost',sans-serif;font-size:13px;color:rgba(250,246,240,0.55);line-height:1.85;max-height:0;overflow:hidden;transition:max-height 0.4s ease;}
.ut-acc-body.open{max-height:600px;padding-bottom:16px;}
.ut-acc-body ul{padding-left:16px;} .ut-acc-body li{margin-bottom:5px;}

/* BELOW FOLD */
.ut-pdp-below{max-width:1200px;margin:0 auto;padding:0 40px 80px;}
@media(max-width:768px){.ut-pdp-below{padding:0 20px 60px;}}
.ut-pdp-tabs{display:flex;border-bottom:1px solid rgba(201,169,110,0.1);margin-bottom:40px;overflow-x:auto;gap:0;}
.ut-pdp-tab{font-family:'Cinzel',serif;font-size:9px;letter-spacing:0.28em;color:rgba(201,169,110,0.4);text-transform:uppercase;padding:14px 22px;cursor:pointer;border-bottom:2px solid transparent;background:none;border-top:none;border-left:none;border-right:none;white-space:nowrap;transition:all 0.2s;}
.ut-pdp-tab:hover{color:var(--ut-gold);}
.ut-pdp-tab.active{color:var(--ut-gold);border-bottom-color:var(--ut-gold);}
.ut-pdp-tab-pane{display:none;}
.ut-pdp-tab-pane.active{display:block;}

/* REVIEWS */
.ut-rev-summary{display:grid;grid-template-columns:180px 1fr;gap:36px;margin-bottom:36px;align-items:center;}
@media(max-width:560px){.ut-rev-summary{grid-template-columns:1fr;}}
.ut-rev-big-score{text-align:center;}
.ut-rev-num{font-family:'Cinzel',serif;font-size:64px;color:var(--ut-gold);line-height:1;}
.ut-rev-stars-big{color:var(--ut-gold);font-size:20px;letter-spacing:3px;margin:4px 0;}
.ut-rev-total-count{font-family:'Jost',sans-serif;font-size:11px;color:rgba(250,246,240,0.35);letter-spacing:0.15em;}
.ut-rev-bar-row{display:flex;align-items:center;gap:10px;margin-bottom:7px;cursor:pointer;}
.ut-rev-bar-lbl{font-family:'Cinzel',serif;font-size:9px;color:rgba(201,169,110,0.5);width:38px;text-align:right;flex-shrink:0;}
.ut-rev-bar-track{flex:1;height:4px;background:rgba(201,169,110,0.08);border-radius:2px;overflow:hidden;}
.ut-rev-bar-fill{height:100%;background:var(--ut-gold);border-radius:2px;width:0;transition:width 1.2s ease;}
.ut-rev-bar-cnt{font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.25);width:36px;text-align:left;}
.ut-rev-filters{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;}
.ut-rev-filter{font-family:'Jost',sans-serif;font-size:10px;color:rgba(250,246,240,0.4);border:1px solid rgba(201,169,110,0.1);background:none;padding:6px 14px;cursor:pointer;letter-spacing:0.08em;transition:all 0.2s;}
.ut-rev-filter:hover,.ut-rev-filter.active{border-color:var(--ut-gold);color:var(--ut-gold);background:rgba(201,169,110,0.04);}
.ut-rev-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:28px;}
