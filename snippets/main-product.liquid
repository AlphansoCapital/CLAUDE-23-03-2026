    <script>
    (function(){
      var KEY='ut-pdp-cd-end-{{ product.handle | escape }}';
      var DURATION=24*3600;
      var stored=localStorage.getItem(KEY);
      var endTime;
      if(stored && parseInt(stored) > Date.now()/1000){
        endTime=parseInt(stored);
      } else {
        endTime=Math.floor(Date.now()/1000)+DURATION;
        localStorage.setItem(KEY,endTime);
      }
      var hEl=document.getElementById('pdpCdH');
      var mEl=document.getElementById('pdpCdM');
      var sEl=document.getElementById('pdpCdS');
      if(!hEl) return;
      function tick(){
        var r=Math.max(0, endTime - Math.floor(Date.now()/1000));
        hEl.textContent=String(Math.floor(r/3600)).padStart(2,'0');
        mEl.textContent=String(Math.floor((r%3600)/60)).padStart(2,'0');
        sEl.textContent=String(r%60).padStart(2,'0');
        if(r>0) setTimeout(tick,1000);
        else { document.getElementById('pdpTimerWrap').style.display='none'; localStorage.removeItem(KEY); }
      }
      tick();
    })();
