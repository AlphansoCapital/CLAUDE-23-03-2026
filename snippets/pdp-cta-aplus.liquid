{% comment %}
╔══════════════════════════════════════════════════════════════╗
║  URBAN TREND — PDP CTA + A+ CONTENT SNIPPET                 ║
║  File: snippets/pdp-cta-aplus.liquid                        ║
║                                                              ║
║  HOW TO USE IN main-product.liquid:                          ║
║    1. Find the old ATC row + trust + below-fold bundle       ║
║    2. Delete them (see INTEGRATION-GUIDE.md)                 ║
║    3. Add this ONE line after the accordions:                ║
║       {% render 'pdp-cta-aplus', product: product %}         ║
╚══════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- liquid
  assign variant    = product.selected_or_first_available_variant
  assign base_price = variant.price
  assign compare    = variant.compare_at_price
  assign is_preorder = false
  if product.tags contains 'pre-order'
    assign is_preorder = true
  endif

  comment ── Bundle price math (vs compare_at_price) ── endcomment
  if compare > base_price
    assign b2_price   = compare | times: 2 | times: 40 | divided_by: 100
    assign b3_price   = compare | times: 3 | times: 30 | divided_by: 100
    assign b2_orig    = compare | times: 2
    assign b3_orig    = compare | times: 3
  else
    assign b2_price   = base_price | times: 2 | times: 75 | divided_by: 100
    assign b3_price   = base_price | times: 3 | times: 65 | divided_by: 100
    assign b2_orig    = base_price | times: 2
    assign b3_orig    = base_price | times: 3
  endif

  assign b1_save  = compare | minus: base_price | times: 100 | divided_by: compare
  assign b2_save  = b2_orig | minus: b2_price | times: 100 | divided_by: b2_orig
  assign b3_save  = b3_orig | minus: b3_price | times: 100 | divided_by: b3_orig

  comment ── Ship date = today + 7 days (Liquid has no date math, we use JS) ── endcomment
  comment ── Metafield fallbacks ── endcomment
  assign expert_name  = product.metafields.custom.expert_name  | default: 'Dr. Priya'
  assign expert_title = product.metafields.custom.expert_title | default: 'Wellness Specialist'
  assign stock_units  = product.metafields.custom.stock_units  | default: '9'
-%}

<!-- ╔═══════════════════════════════════════╗ -->
<!-- ║  SECTION 1 — CTA BLOCK               ║ -->
<!-- ╚═══════════════════════════════════════╝ -->
<div class="utc" id="utCta">

  {% comment %} 1. URGENCY — Countdown {% endcomment %}
  <div class="utc-urgency">
    <div class="utc-urg-left">
      <span class="utc-urg-icon">⚡</span>
      <span class="utc-urg-text">Flash Sale Ends In</span>
    </div>
    <div class="utc-timer">
      <div class="utc-t-blk"><span class="utc-t-n" id="utcCdH">--</span><span class="utc-t-u">Hrs</span></div>
      <span class="utc-t-sep">:</span>
      <div class="utc-t-blk"><span class="utc-t-n" id="utcCdM">--</span><span class="utc-t-u">Min</span></div>
      <span class="utc-t-sep">:</span>
      <div class="utc-t-blk"><span class="utc-t-n" id="utcCdS">--</span><span class="utc-t-u">Sec</span></div>
    </div>
  </div>

  {% comment %} 2. SOCIAL PROOF — Endorsement + Rating {% endcomment %}
  <div class="utc-proof">
    <div class="utc-endorse">
      <div class="utc-endorse-av">{{ expert_name | slice: 0 }}</div>
      <span class="utc-endorse-txt">
        Recommended by <strong>{{ expert_name }}</strong>&nbsp;|&nbsp;{{ expert_title }}
      </span>
    </div>
    <div class="utc-proof-div"></div>
    <div class="utc-proof-rating">
      <span class="utc-proof-stars">★★★★★</span>
      <a class="utc-proof-count" href="#utc-reviews">
        {{ product.metafields.reviews.rating_count.value | default: '2,847' }} verified reviews
      </a>
    </div>
  </div>

  {% comment %} 3. SCARCITY — Stock bar {% endcomment %}
  {% if product.available and is_preorder == false %}
    <div class="utc-scarcity">
      <span class="utc-scar-dot"></span>
      <span class="utc-scar-txt">Only <strong>{{ stock_units }} units</strong> left at this price — selling fast</span>
      <div class="utc-scar-bar-wrap">
        <div class="utc-scar-bar"><div class="utc-scar-fill"></div></div>
      </div>
    </div>
  {% endif %}

  {% comment %} 4. BUNDLE OPTIONS {% endcomment %}
  {% if product.available and is_preorder == false %}
    <div class="utc-opts" id="utcOpts">

      <label class="utc-opt" onclick="utcSelOpt(this)" data-qty="1" data-price="{{ base_price }}">
        <input type="radio" name="utc-bundle" style="display:none">
        <span class="utc-radio"></span>
        <div class="utc-opt-l">
          <div class="utc-opt-name">1 Set</div>
          <div class="utc-opt-save">
            Save {% if compare > base_price %}{{ b1_save }}%{% else %}best starter{% endif %}
          </div>
        </div>
        <div class="utc-opt-r">
          <span class="utc-opt-price">{{ base_price | money }}</span>
          {% if compare > base_price %}
            <span class="utc-opt-comp">{{ compare | money }}</span>
          {% endif %}
        </div>
      </label>

      <label class="utc-opt utc-sel" onclick="utcSelOpt(this)" data-qty="2" data-price="{{ b2_price }}">
        <span class="utc-opt-badge utc-badge-gold">Most Popular</span>
        <input type="radio" name="utc-bundle" checked style="display:none">
        <span class="utc-radio"></span>
        <div class="utc-opt-l">
          <div class="utc-opt-name">2 Sets</div>
          <div class="utc-opt-save">Save {{ b2_save }}% — best for 3 months</div>
        </div>
        <div class="utc-opt-r">
          <span class="utc-opt-price">{{ b2_price | money }}</span>
          <span class="utc-opt-comp">{{ b2_orig | money }}</span>
        </div>
      </label>

      <label class="utc-opt" onclick="utcSelOpt(this)" data-qty="3" data-price="{{ b3_price }}">
        <span class="utc-opt-badge utc-badge-green">Best Value</span>
        <input type="radio" name="utc-bundle" style="display:none">
        <span class="utc-radio"></span>
        <div class="utc-opt-l">
          <div class="utc-opt-name">3 Sets</div>
          <div class="utc-opt-save">Save {{ b3_save }}% — full 6 month supply</div>
        </div>
        <div class="utc-opt-r">
          <span class="utc-opt-price">{{ b3_price | money }}</span>
          <span class="utc-opt-comp">{{ b3_orig | money }}</span>
        </div>
      </label>

    </div>
  {% endif %}

  {% comment %} 5. AUTO-REFILL + SHIPS LINE {% endcomment %}
  {% if product.available %}
    <label class="utc-refill" id="utcRefill">
      <input type="checkbox" id="utcRefillCb" checked onchange="utcToggleRefill(this)">
      <span class="utc-rbox" id="utcRbox">✓</span>
      <div class="utc-rtxt">
        <strong>Save More with Automatic Refills</strong>
        <span>Zero commitment · Cancel anytime in 1 click</span>
      </div>
    </label>
    <div class="utc-ships">
      🚚 Order now — ships by <strong id="utcShipDate"></strong> &nbsp;·&nbsp; Free delivery above ₹999
    </div>
  {% endif %}

  {% comment %} 6. PRIMARY CTA BUTTON {% endcomment %}
  {% if is_preorder %}
    <button class="utc-btn-atc utc-btn-preorder" id="utcMainBtn" onclick="utcPreOrder()">
      <span class="utc-btn-inner">Pre-Order Now →</span>
    </button>
  {% elsif product.available %}
    <button class="utc-btn-atc" id="utcMainBtn" onclick="utcAddBag()">
      <span class="utc-btn-inner">Add to Bag</span>
    </button>
  {% else %}
    <button class="utc-btn-atc" disabled>
      <span class="utc-btn-inner">Sold Out</span>
    </button>
    {% render 'back-in-stock', product: product %}
  {% endif %}

  {% comment %} 7. SECONDARY ROW {% endcomment %}
  {% if product.available %}
    <div class="utc-secondary">
      <button class="utc-btn-buy" onclick="utcBuyNow()">Buy Now →</button>
      <button class="utc-btn-wish" id="utcWishBtn" onclick="utcToggleWish()" aria-label="Wishlist">♡</button>
    </div>
  {% endif %}

  {% comment %} 8. TRUST GRID {% endcomment %}
  <div class="utc-trust">
    <div class="utc-trust-item"><i>🚚</i>Free shipping ₹999+</div>
    <div class="utc-trust-item"><i>💳</i>COD available</div>
    <div class="utc-trust-item"><i>↩</i>15-day returns</div>
    <div class="utc-trust-item"><i>🔒</i>Secure checkout</div>
    <div class="utc-trust-item"><i>🧪</i>Dermatologist tested</div>
    <div class="utc-trust-item"><i>🌿</i>Cruelty free</div>
  </div>

  {% comment %} 9. MICRO SOCIAL PROOF {% endcomment %}
  <div class="utc-micro">
    <div class="utc-micro-avs">
      <div class="utc-micro-av">P</div>
      <div class="utc-micro-av">A</div>
      <div class="utc-micro-av">N</div>
      <div class="utc-micro-av">S</div>
    </div>
    <div class="utc-micro-txt">
      <strong>4,200+ customers</strong> ordered this month.
      78% are on auto-refill.
    </div>
    <span class="utc-live-dot"></span>
  </div>

</div><!-- /utc -->


