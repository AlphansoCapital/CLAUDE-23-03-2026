{% if page.handle == 'affiliate' or page.handle == 'affiliates' or page.handle == 'partner' %}
{% include 'affiliate-page' %}
{% elsif page.handle == 'about' or page.handle == 'our-story' %}
<style>
.ut-about{background:var(--obs);min-height:100vh;}
.ut-about-hero{background:linear-gradient(180deg,#141210 0%,var(--obs) 100%);padding:80px 32px 60px;border-bottom:1px solid var(--border);text-align:center;position:relative;overflow:hidden;}
.ut-about-hero::before{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:400px;background:radial-gradient(ellipse,rgba(201,169,110,0.07) 0%,transparent 70%);}
.ut-about-eyebrow{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.44em;color:rgba(201,169,110,0.5);text-transform:uppercase;display:block;margin-bottom:16px;}
.ut-about-title{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,60px);font-weight:300;color:#FAF6F0;line-height:1.1;margin-bottom:18px;}
.ut-about-title em{font-style:italic;color:#C9A96E;}
.ut-about-sub{font-family:'Jost',sans-serif;font-size:14px;color:rgba(250,246,240,0.5);letter-spacing:0.06em;max-width:560px;margin:0 auto;line-height:1.9;}
.ut-about-body{max-width:1100px;margin:0 auto;padding:64px 32px;}
@media(max-width:600px){.ut-about-body{padding:40px 16px;}}
.ut-about-story{display:grid;grid-template-columns:1fr 1fr;gap:72px;align-items:start;margin-bottom:72px;}
@media(max-width:900px){.ut-about-story{grid-template-columns:1fr;gap:40px;}}
.ut-about-year{font-family:'Cormorant Garamond',serif;font-size:80px;font-weight:300;color:rgba(201,169,110,0.12);line-height:1;margin-bottom:-20px;display:block;}
.ut-about-section-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:0.42em;color:rgba(201,169,110,0.5);text-transform:uppercase;display:block;margin-bottom:16px;}
.ut-about-section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,3vw,40px);font-weight:300;color:#FAF6F0;line-height:1.15;margin-bottom:20px;}
.ut-about-section-title em{font-style:italic;color:#C9A96E;}
.ut-about-para{font-family:'Jost',sans-serif;font-size:13px;font-weight:200;color:rgba(250,246,240,0.55);line-height:2;letter-spacing:0.04em;margin-bottom:18px;}
.ut-about-quote{border-left:2px solid #C9A96E;padding:16px 22px;margin:24px 0;background:rgba(201,169,110,0.04);}
.ut-about-quote p{font-family:'Cormorant Garamond',serif;font-size:18px;font-style:italic;color:#FAF6F0;line-height:1.7;}
.ut-about-quote cite{font-family:'Jost',sans-serif;font-size:10px;font-weight:200;color:rgba(201,169,110,0.6);letter-spacing:0.16em;text-transform:uppercase;margin-top:10px;display:block;}
.ut-about-img-ph{width:100%;aspect-ratio:3/4;background:linear-gradient(135deg,#1C1510,#141210);border:0.5px solid var(--border);display:flex;align-items:center;justify-content:center;position:relative;}
.ut-about-img-ph img{width:100%;height:100%;object-fit:cover;}
.ut-about-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-bottom:72px;}
@media(max-width:700px){.ut-about-stats{grid-template-columns:repeat(2,1fr);}}
.ut-about-stat{background:#141210;border:0.5px solid var(--border);padding:32px 24px;text-align:center;}
.ut-about-stat-num{font-family:'Cormorant Garamond',serif;font-size:44px;font-weight:300;color:#C9A96E;display:block;line-height:1;margin-bottom:8px;}
.ut-about-stat-lbl{font-family:'Jost',sans-serif;font-size:10px;font-weight:200;color:rgba(250,246,240,0.35);letter-spacing:0.18em;text-transform:uppercase;}
.ut-about-values{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-bottom:72px;}
@media(max-width:700px){.ut-about-values{grid-template-columns:1fr;}}
.ut-about-value{background:#141210;border:0.5px solid var(--border);padding:28px 24px;transition:border-color 0.3s;}
.ut-about-value:hover{border-color:rgba(201,169,110,0.45);}
.ut-about-value-icon{font-size:24px;display:block;margin-bottom:14px;}
.ut-about-value-title{font-family:'Cinzel',serif;font-size:10px;letter-spacing:0.28em;color:#C9A96E;text-transform:uppercase;display:block;margin-bottom:10px;}
.ut-about-value-body{font-family:'Jost',sans-serif;font-size:12px;font-weight:200;color:rgba(250,246,240,0.5);line-height:1.8;}
.ut-about-press{text-align:center;padding:48px 0;border-top:0.5px solid var(--border);}
.ut-about-press-label{font-family:'Cinzel',serif;font-size:7px;letter-spacing:0.42em;color:rgba(201,169,110,0.4);text-transform:uppercase;display:block;margin-bottom:28px;}
.ut-about-press-logos{display:flex;justify-content:center;align-items:center;gap:40px;flex-wrap:wrap;}
.ut-about-press-logo{font-family:'Cinzel',serif;font-size:11px;letter-spacing:0.22em;color:rgba(250,246,240,0.2);transition:color 0.3s;}
.ut-about-press-logo:hover{color:rgba(201,169,110,0.6);}
</style>
<div class="ut-about" itemscope itemtype="https://schema.org/AboutPage">
  <div class="ut-about-hero">
    <span class="ut-about-eyebrow">Our Story — Est. 1975</span>
    <h1 class="ut-about-title">50 Years of Solving<br>India's <em>Beauty Problems</em></h1>
    <p class="ut-about-sub">A family store in Sirsa. A promise never broken. Half a century of real solutions for real skin.</p>
  </div>
  <div class="ut-about-body">
    <div class="ut-about-story">
      <div class="ut-about-img-ph" aria-label="Manish Jain — Founder & CEO, Urban Trend" style="padding:0;overflow:hidden;position:relative;border:1px solid rgba(201,169,110,0.22);">
        <!-- Gold corner brackets -->
        <div style="position:absolute;top:12px;left:12px;width:28px;height:28px;border-top:1.5px solid #C9A96E;border-left:1.5px solid #C9A96E;z-index:3;pointer-events:none;"></div>
        <div style="position:absolute;top:12px;right:12px;width:28px;height:28px;border-top:1.5px solid #C9A96E;border-right:1.5px solid #C9A96E;z-index:3;pointer-events:none;"></div>
        <div style="position:absolute;bottom:12px;left:12px;width:28px;height:28px;border-bottom:1.5px solid #C9A96E;border-left:1.5px solid #C9A96E;z-index:3;pointer-events:none;"></div>
        <div style="position:absolute;bottom:12px;right:12px;width:28px;height:28px;border-bottom:1.5px solid #C9A96E;border-right:1.5px solid #C9A96E;z-index:3;pointer-events:none;"></div>
        <img
          src="{{ 'manish-jain-founder.png' | asset_url }}"
          alt="Manish Jain — Founder & CEO, Urban Trend · Est. 1975"
          style="width:100%;height:100%;object-fit:cover;object-position:center top;display:block;filter:brightness(1.02) contrast(1.03);"
          loading="lazy"
          decoding="async"
        >
        <div style="position:absolute;bottom:0;left:0;right:0;height:100px;background:linear-gradient(to top,rgba(10,9,8,0.65),transparent);z-index:2;pointer-events:none;"></div>
        <div style="position:absolute;bottom:16px;left:50%;transform:translateX(-50%);z-index:4;background:rgba(10,9,8,0.9);border:1px solid rgba(201,169,110,0.4);padding:6px 16px;white-space:nowrap;">
          <span style="font-family:'Cinzel',serif;font-size:7px;letter-spacing:0.32em;text-transform:uppercase;color:#C9A96E;">Manish Jain · Founder & CEO</span>
        </div>
      </div>
      <div>
        <span class="ut-about-year">1975</span>
        <span class="ut-about-section-label">Where It All Began</span>
        <h2 class="ut-about-section-title">A Father's <em>Promise</em> in Sirsa</h2>
        <p class="ut-about-para">In 1975, our founder opened a small cosmetics store in Sirsa, Haryana with one rule: never sell a fake product. Every customer who walked through that door had a real problem — dark spots, hair fall, a wedding in three weeks — and they deserved a real answer.</p>
        <p class="ut-about-para">That promise has never changed. Through five decades, every trend, every competitor, every platform — we have survived because we never compromised on authenticity. Not once. Not for any margin.</p>
        <div class="ut-about-quote">
          <p>"In 50 years, I have never sold a fake product. That is not marketing — that is who we are. Your trust is worth more than any sale."</p>
          <cite>— Manish Jain · Founder, Urban Trend · Sirsa, 1975</cite>
        </div>
        <p class="ut-about-para">Featured in the Economic Times Power of Ideas series. Serving customers across India for five decades. Today, we carry 100+ trusted brands — O3+, WOW, Mamaearth, L'Oréal, and more — sourced directly from brands and authorised distributors. No grey market. No fakes. No shortcuts.</p>
      </div>
    </div>
    <!-- Founder Bio Card -->
    <div style="background:#141210;border:1px solid rgba(201,169,110,.16);padding:32px 36px;margin-bottom:40px;display:grid;grid-template-columns:auto 1fr;gap:32px;align-items:center;">
      <div style="width:80px;height:80px;border-radius:50%;background:linear-gradient(135deg,#2A2018,#1A1410);border:1px solid rgba(201,169,110,.3);display:flex;align-items:center;justify-content:center;font-family:'Cinzel',serif;font-size:24px;color:#C9A96E;flex-shrink:0;">MJ</div>
      <div>
        <div style="display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:8px;">
          <span style="font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:300;color:#FAF6F0;">Manish Jain</span>
          <span style="font-family:'Cinzel',serif;font-size:7px;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,169,110,.6);border:1px solid rgba(201,169,110,.2);padding:4px 10px;">Founder &amp; CEO</span>
        </div>
        <div style="display:flex;flex-direction:column;gap:7px;">
          <div style="display:flex;align-items:center;gap:10px;">
            <span style="font-size:14px;">🎓</span>
            <div>
              <span style="font-family:'Jost',sans-serif;font-size:12px;font-weight:300;color:#FAF6F0;display:block;">Post Graduate Diploma in International Trade Management (PGDITM)</span>
              <span style="font-family:'Jost',sans-serif;font-size:10px;font-weight:200;color:rgba(201,169,110,.7);letter-spacing:.06em;">NMIMS — SVKM's Narsee Monjee Institute of Management Studies, Mumbai · 2021</span>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <span style="font-size:14px;">📜</span>
            <div>
              <span style="font-family:'Jost',sans-serif;font-size:12px;font-weight:300;color:#FAF6F0;display:block;">Bachelor of Commerce · Tax Procedure &amp; Practice</span>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:10px;margin-top:4px;">
            <span style="font-size:14px;">📰</span>
            <span style="font-family:'Jost',sans-serif;font-size:11px;font-weight:200;color:rgba(250,246,240,.5);">Featured in The Economic Times · Power of Ideas 2014</span>
          </div>
        </div>
      </div>
    </div>

    <div class="ut-about-stats" itemscope itemtype="https://schema.org/Organization">
      <div class="ut-about-stat"><span class="ut-about-stat-num">1975</span><span class="ut-about-stat-lbl">Founded in Sirsa</span></div>
      <div class="ut-about-stat"><span class="ut-about-stat-num">50+</span><span class="ut-about-stat-lbl">Years of Trust</span></div>
      <div class="ut-about-stat"><span class="ut-about-stat-num">100+</span><span class="ut-about-stat-lbl">Trusted Brands</span></div>
      <div class="ut-about-stat"><span class="ut-about-stat-num">0</span><span class="ut-about-stat-lbl">Fake Products. Ever.</span></div>
    </div>
    <div class="ut-about-values">
      <div class="ut-about-value">
        <span class="ut-about-value-icon">🔒</span>
        <span class="ut-about-value-title">100% Authentic</span>
        <p class="ut-about-value-body">Every product sourced directly from the brand or authorised distributor. We have never sold a grey-market or counterfeit product in 50 years. This is not a claim — it is our founding principle.</p>
      </div>
      <div class="ut-about-value">
        <span class="ut-about-value-icon">🌿</span>
        <span class="ut-about-value-title">Made for Indian Skin</span>
        <p class="ut-about-value-body">We stock only what works on Indian skin tones, in Indian climate, in Indian humidity. No product enters our store without being tested for Indian skin concerns first.</p>
      </div>
      <div class="ut-about-value">
        <span class="ut-about-value-icon">🤝</span>
        <span class="ut-about-value-title">Family Business Values</span>
        <p class="ut-about-value-body">We are not a funded startup with VC money and fake urgency. We are a 50-year-old family business that has served real customers with real problems. That accountability never goes away.</p>
      </div>
    </div>
    <div class="ut-about-press">
      <span class="ut-about-press-label">As Featured In</span>
      <div class="ut-about-press-logos">
        <span class="ut-about-press-logo">Economic Times</span>
        <span class="ut-about-press-logo">ET Power of Ideas</span>
        <span class="ut-about-press-logo">Flipkart Top Seller 2014</span>
        <span class="ut-about-press-logo">50 Years · Sirsa, Haryana</span>
      </div>
    </div>
  </div>
</div>
{% else %}
<div class="page-body" style="max-width:860px;margin:0 auto;padding:52px 32px;">
  <h1 style="font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,44px);font-weight:300;color:#FAF6F0;margin-bottom:28px;">{{ page.title }}</h1>
  <div class="rte" style="font-family:'Jost',sans-serif;font-size:14px;font-weight:200;color:rgba(250,246,240,0.6);line-height:2;letter-spacing:0.03em;">{{ page.content }}</div>
</div>
{% endif %}
{% schema %}{"name":"Page","tag":"section","settings":[]}{% endschema %}
