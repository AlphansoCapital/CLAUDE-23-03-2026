    </button>
  </div>
</div>
<script>
function toggleWaChat(){
  var box=document.getElementById('waChatBox');
  box.classList.toggle('open');
}
// Auto-open after 45s on first visit
if(!sessionStorage.getItem('wa-shown')){
  setTimeout(function(){
    document.getElementById('waChatBox')?.classList.add('open');
    sessionStorage.setItem('wa-shown','1');
  },45000);
}
</script>
