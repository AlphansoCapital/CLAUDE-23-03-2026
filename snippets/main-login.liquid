<script>
function switchAuthTab(tab, btn) {
  document.querySelectorAll('.ut-auth-tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.ut-auth-form').forEach(f => f.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('authForm' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
}

function togglePw(id, btn) {
  var inp = document.getElementById(id);
  if (inp.type === 'password') {
    inp.type = 'text';
    btn.textContent = '🙈';
  } else {
    inp.type = 'password';
    btn.textContent = '👁';
  }
}

function checkPwStrength(val) {
  var bars = [document.getElementById('pwBar1'), document.getElementById('pwBar2'), document.getElementById('pwBar3'), document.getElementById('pwBar4')];
  var label = document.getElementById('pwLabel');
  bars.forEach(b => { b.className = 'ut-pw-bar'; });
  if (!val) { label.textContent = ''; return; }
  var score = 0;
  if (val.length >= 6) score++;
  if (val.length >= 10) score++;
  if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  var cls = score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong';
  var lbl = score <= 1 ? 'Weak' : score <= 2 ? 'Good' : score === 3 ? 'Strong' : 'Very Strong';
  var colors = ['weak','weak','medium','strong'];
  for (var i = 0; i < score; i++) bars[i].classList.add(colors[Math.min(i, score-1)]);
  label.textContent = lbl;
  label.style.color = cls === 'weak' ? 'var(--ut-rose)' : cls === 'medium' ? 'var(--ut-gold)' : 'var(--ut-success)';
}

function showToast(msg, type) {
  if (typeof UT !== 'undefined') { UT.toast(msg, type); return; }
  alert(msg);
}

// Auto-switch to register if URL has ?register
if (window.location.search.includes('register')) {
  var tabs = document.querySelectorAll('.ut-auth-tab');
  if (tabs[1]) switchAuthTab('register', tabs[1]);
}

/* ── SOCIAL LOGIN CONFIG ──
   Google: Add your Client ID below
   Facebook: Add your App ID below
   WhatsApp OTP: Uses MSG91 Widget Token (safe — no AuthKey exposure)
   ─────────────────────────────────────── */
var UT_SOCIAL_CONFIG = {
  google_client_id:   '61115780502-s6ntrd4v92g30brcmk8k312kepbqcc9h.apps.googleusercontent.com',   // console.cloud.google.com
  facebook_app_id:    '2013294159590812',    // developers.facebook.com
  msg91_widget_id:    '3663756e6155383738383932',    // MSG91 Dashboard → Widgets → Token (safe to expose)
  shop_url:           window.location.origin,
};

/* ── GOOGLE ONE TAP ── */
function utInitGoogleOneTap() {
  if(!UT_SOCIAL_CONFIG.google_client_id || UT_SOCIAL_CONFIG.google_client_id === 'YOUR_GOOGLE_CLIENT_ID') return;
  var script = document.createElement('script');
  script.src = 'https://accounts.google.com/gsi/client';
  script.async = true;
  script.defer = true;
  script.onload = function() {
    google.accounts.id.initialize({
      client_id: UT_SOCIAL_CONFIG.google_client_id,
      callback: function(response) {
        utHandleGoogleToken(response.credential);
      },
      auto_select: false,
      cancel_on_tap_outside: true,
    });
    google.accounts.id.renderButton(
      document.getElementById('ut-google-btn'),
      { theme:'filled_black', size:'large', shape:'rectangular', width:320, text:'continue_with' }
    );
    google.accounts.id.prompt();
  };
  document.head.appendChild(script);
}

function utHandleGoogleToken(token) {
  /* Decode JWT to get email */
  try {
    var payload = JSON.parse(atob(token.split('.')[1]));
    var email = payload.email;
    var name  = payload.name;
    /* Pre-fill login form and submit */
    var emailInput = document.getElementById('authEmail');
    if(emailInput) {
      emailInput.value = email;
      if(typeof UT !== 'undefined') UT.toast('Welcome, ' + (name || email) + '!', 'success');
      /* In production: send token to your backend to create/login customer */
      setTimeout(function(){
        window.location = '/account?google_token=' + encodeURIComponent(token);
      }, 800);
    }
  } catch(e) {
    if(typeof UT !== 'undefined') UT.toast('Google login failed. Please try again.', 'error');
  }
}

/* ── FACEBOOK LOGIN ── */
function utInitFacebook() {
  if(!UT_SOCIAL_CONFIG.facebook_app_id || UT_SOCIAL_CONFIG.facebook_app_id === 'YOUR_FACEBOOK_APP_ID') return;
  window.fbAsyncInit = function() {
    FB.init({ appId: UT_SOCIAL_CONFIG.facebook_app_id, cookie:true, xfbml:true, version:'v18.0' });
  };
  var script = document.createElement('script');
  script.src = 'https://connect.facebook.net/en_US/sdk.js';
  script.async = true;
  script.defer = true;
  document.head.appendChild(script);
}

function utFacebookLogin() {
  if(typeof FB === 'undefined') {
    if(typeof UT !== 'undefined') UT.toast('Facebook SDK loading... try again', 'info');
    return;
  }
  FB.login(function(response) {
    if(response.authResponse) {
      FB.api('/me', {fields:'name,email'}, function(user) {
        if(typeof UT !== 'undefined') UT.toast('Welcome, ' + user.name + '!', 'success');
        var emailInput = document.getElementById('authEmail');
        if(emailInput && user.email) emailInput.value = user.email;
        setTimeout(function(){ window.location = '/account'; }, 800);
      });
    }
  }, {scope:'email,public_profile'});
}

/* ── WHATSAPP OTP via MSG91 Widget (Safe — no AuthKey in frontend) ── */
/* Widget Token is safe to expose publicly — it's designed for client-side use */
function utLoadMsg91Widget() {
  if(!UT_SOCIAL_CONFIG.msg91_widget_id || UT_SOCIAL_CONFIG.msg91_widget_id === 'YOUR_MSG91_WIDGET_ID') return;
  if(document.getElementById('msg91-widget-script')) return; // already loaded
  var script = document.createElement('script');
  script.id = 'msg91-widget-script';
  script.type = 'text/javascript';
  script.src = 'https://verify.msg91.com/otp-provider.js';
  script.onload = function() {
    if(window.initSendOTP) {
      window.sendOTPWidget = window.initSendOTP({
        widgetId: UT_SOCIAL_CONFIG.msg91_widget_id,
        tokenAuth: UT_SOCIAL_CONFIG.msg91_widget_id,
        success: function(data) {
          if(typeof UT !== 'undefined') UT.toast('✓ Verified! Logging you in...', 'success');
          setTimeout(function(){ window.location = '/account'; }, 800);
        },
        failure: function(error) {
          if(typeof UT !== 'undefined') UT.toast('OTP verification failed. Try again.', 'error');
        }
      });
    }
  };
  document.head.appendChild(script);
}

function utSendWhatsappOtp(phone) {
  if(!phone || phone.length !== 10) {
    if(typeof UT !== 'undefined') UT.toast('Valid 10-digit number daalo', 'error');
    return;
  }
  if(!UT_SOCIAL_CONFIG.msg91_widget_id || UT_SOCIAL_CONFIG.msg91_widget_id === 'YOUR_MSG91_WIDGET_ID') {
    if(typeof UT !== 'undefined') UT.toast('MSG91 Widget ID setup needed', 'info');
    return;
  }
  utLoadMsg91Widget();
  if(window.sendOTPWidget) {
    window.sendOTPWidget.send('91' + phone);
    if(typeof UT !== 'undefined') UT.toast('OTP sent on WhatsApp to +91 ' + phone, 'success');
  } else {
    setTimeout(function(){
      if(window.sendOTPWidget) {
        window.sendOTPWidget.send('91' + phone);
        if(typeof UT !== 'undefined') UT.toast('OTP sent on WhatsApp to +91 ' + phone, 'success');
      }
    }, 1500);
  }
}

function utVerifyWhatsappOtp(phone, otp) {
  if(window.sendOTPWidget) {
    window.sendOTPWidget.verify('91' + phone, otp);
  } else {
    if(typeof UT !== 'undefined') UT.toast('Please send OTP first', 'error');
  }
}

/* ── MAIN SOCIAL LOGIN HANDLER ── */
function utSocialLogin(provider) {
  switch(provider) {
    case 'google':
      if(UT_SOCIAL_CONFIG.google_client_id === 'YOUR_GOOGLE_CLIENT_ID') {
        if(typeof UT !== 'undefined') UT.toast('Google login setup needed — check CLAUDE.md for instructions', 'info');
      } else {
        google.accounts.id.prompt();
      }
      break;
    case 'facebook':
      if(UT_SOCIAL_CONFIG.facebook_app_id === 'YOUR_FACEBOOK_APP_ID') {
        if(typeof UT !== 'undefined') UT.toast('Facebook login setup needed', 'info');
      } else {
        utFacebookLogin();
      }
      break;
    case 'whatsapp':
      showPhoneOtp('whatsapp');
      break;
    case 'apple':
      /* Apple Sign In — requires Apple Developer account */
      if(typeof UT !== 'undefined') UT.toast('Apple login: Add Apple Developer credentials in config', 'info');
      break;
    case 'twitter':
      if(typeof UT !== 'undefined') UT.toast('X/Twitter login: Add X Developer credentials in config', 'info');
      break;
  }
}

/* Init on page load */
document.addEventListener('DOMContentLoaded', function() {
  utInitGoogleOneTap();
  utInitFacebook();
});

function showPhoneOtp() {
  var panel = document.getElementById('phoneOtpPanel');
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
  if (panel.style.display === 'block') {
    setTimeout(function(){ document.getElementById('otpPhone').focus(); }, 100);
  }
}

var utOtpMode = 'sms'; // 'sms' or 'whatsapp'

function showPhoneOtp(mode) {
  utOtpMode = mode || 'sms';
  var panel = document.getElementById('phoneOtpPanel');
  panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
  // Update label based on mode
  var lbl = panel.querySelector('p');
  if(lbl) lbl.textContent = mode === 'whatsapp' ? 'Enter WhatsApp Number' : 'Enter Phone Number';
  if(panel.style.display === 'block') {
    setTimeout(function(){ document.getElementById('otpPhone').focus(); }, 100);
  }
}

function sendOtp() {
  var phone = document.getElementById('otpPhone').value.trim();
  if (phone.length !== 10) {
    if (typeof UT !== 'undefined') UT.toast('Valid 10-digit number daalo', 'error');
    document.getElementById('otpPhone').style.borderColor = 'rgba(139,58,82,0.6)';
    return;
  }
  document.getElementById('otpPhone').style.borderColor = '';
  document.getElementById('otpInputSection').style.display = 'block';
  document.querySelector('.ut-otp-digit').focus();
  startOtpTimer();

  // Use MSG91 Widget if configured, else simulate
  if(UT_SOCIAL_CONFIG.msg91_widget_id !== 'YOUR_MSG91_WIDGET_ID') {
    utSendWhatsappOtp(phone);
  } else {
    var channel = utOtpMode === 'whatsapp' ? 'WhatsApp' : 'SMS';
    if (typeof UT !== 'undefined') UT.toast('OTP sent via ' + channel + ' to +91 ' + phone, 'success');
  }
}

var otpTimer;
function startOtpTimer() {
  var t = 30;
  var cd = document.getElementById('otpCountdown');
  var btn = document.getElementById('resendBtn');
  btn.disabled = true;
  clearInterval(otpTimer);
  otpTimer = setInterval(function() {
    t--;
    cd.textContent = 'in ' + t + 's';
    if (t <= 0) {
      clearInterval(otpTimer);
      btn.disabled = false;
      cd.textContent = '';
    }
  }, 1000);
}

function resendOtp() {
  if (typeof UT !== 'undefined') UT.toast('OTP resent!', 'success');
  startOtpTimer();
}

function otpNav(inp, idx) {
  var digits = document.querySelectorAll('.ut-otp-digit');
  inp.value = inp.value.replace(/[^0-9]/g, '');
  if (inp.value && idx < 5) digits[idx + 1].focus();
  if (!inp.value && idx > 0) digits[idx - 1].focus();
}

function verifyOtp() {
  var digits = document.querySelectorAll('.ut-otp-digit');
  var otp = Array.from(digits).map(d => d.value).join('');
  if (otp.length !== 6) {
    if (typeof UT !== 'undefined') UT.toast('Please enter complete 6-digit OTP', 'error');
    return;
  }
  // In production: verify via backend/SMS API
  if (typeof UT !== 'undefined') UT.toast('OTP verified! Logging in...', 'success');
  setTimeout(function() { window.location.href = '/account'; }, 1200);
}

// Auto-switch if returning from failed register
{% if form.errors and form.id == 'create_customer' %}
switchAuthTab('register', document.querySelectorAll('.ut-auth-tab')[1]);
{% endif %}
</script>

