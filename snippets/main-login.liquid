{%- comment -%} SEO {%- endcomment -%}
<title>Sign In | Urban Trend</title>
<meta name="description" content="Sign in to your Urban Trend account to track orders and manage your wishlist.">
<meta name="robots" content="noindex, nofollow">

<style>
/* ===== LAYOUT ===== */
.ut-auth-page {
  background:var(--ut-bg);
  min-height:100vh;
  display:grid;
  grid-template-columns:1fr 1fr;
  position:relative;
}
@media(max-width:900px){ .ut-auth-page{ grid-template-columns:1fr; } }

/* ===== LEFT PANEL ===== */
.ut-auth-left {
  background:linear-gradient(155deg,var(--ut-bg-4) 0%,var(--ut-bg) 50%,#120E08 100%);
  position:relative;
  overflow:hidden;
  display:flex;
  flex-direction:column;
  justify-content:space-between;
  padding:48px;
  min-height:100vh;
}
@media(max-width:900px){ .ut-auth-left{ display:none; } }
.ut-auth-left::before {
  content:'';
  position:absolute;
  top:20%;left:50%;
  transform:translate(-50%,-50%);
  width:500px;height:500px;
  background:radial-gradient(ellipse,rgba(201,169,110,0.08) 0%,rgba(139,58,82,0.05) 50%,transparent 70%);
  pointer-events:none;
}
.ut-auth-left-logo {
  font-family:'Cinzel',serif;
  font-size:16px;
  color:var(--ut-gold);
  letter-spacing:0.4em;
  text-transform:uppercase;
  text-decoration:none;
  position:relative;z-index:1;
}
.ut-auth-left-center {
  position:relative;z-index:1;
  flex:1;
  display:flex;
  flex-direction:column;
  justify-content:center;
  padding:40px 0;
}
.ut-auth-illustration {
  width:100%;
  max-width:340px;
  margin:0 auto 40px;
  aspect-ratio:1;
  background:linear-gradient(135deg,rgba(201,169,110,0.06),rgba(139,58,82,0.04));
  border:1px solid rgba(201,169,110,0.1);
  display:flex;
  align-items:center;
  justify-content:center;
  position:relative;
  overflow:hidden;
}
.ut-auth-illustration::before {
  content:'';
  position:absolute;
  inset:16px;
  border:1px solid rgba(201,169,110,0.08);
}
.ut-auth-ill-icon {
  font-size:80px;
  opacity:0.7;
  position:relative;z-index:1;
}
.ut-auth-left-title {
  font-family:'Cormorant Garamond',serif;
  font-size:clamp(28px,3vw,40px);
  font-weight:300;
  color:var(--ut-text);
  line-height:1.2;
  margin-bottom:14px;
  text-align:center;
}
.ut-auth-left-title em {
  font-style:italic;
  color:var(--ut-gold);
}
.ut-auth-left-sub {
  font-family:'Jost',sans-serif;
  font-size:13px;
  color:rgba(250,246,240,0.4);
  line-height:1.8;
  text-align:center;
  max-width:320px;
  margin:0 auto;
  letter-spacing:0.06em;
}
/* Benefits list */
.ut-auth-benefits {
  position:relative;z-index:1;
  display:flex;
  flex-direction:column;
  gap:12px;
}
.ut-auth-benefit {
  display:flex;
  align-items:center;
  gap:12px;
  font-family:'Jost',sans-serif;
  font-size:12px;
  color:rgba(250,246,240,0.45);
  letter-spacing:0.05em;
}
.ut-auth-benefit-icon {
  width:32px;height:32px;
  border:1px solid rgba(201,169,110,0.18);
  display:flex;align-items:center;justify-content:center;
  font-size:14px;
  flex-shrink:0;
  color:var(--ut-gold);
}

/* ===== RIGHT PANEL ===== */
.ut-auth-right {
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  padding:48px 40px;
  position:relative;
  min-height:100vh;
}
@media(max-width:600px){ .ut-auth-right{ padding:40px 20px; } }
.ut-auth-right-inner {
  width:100%;
  max-width:420px;
}

/* Mobile logo */
.ut-auth-mobile-logo {
  display:none;
  font-family:'Cinzel',serif;
  font-size:18px;
  color:var(--ut-gold);
  letter-spacing:0.35em;
  text-transform:uppercase;
  text-align:center;
  margin-bottom:36px;
  text-decoration:none;
}
@media(max-width:900px){ .ut-auth-mobile-logo{ display:block; } }

/* Tab switcher */
.ut-auth-tabs {
  display:flex;
  border-bottom:1px solid rgba(201,169,110,0.12);
  margin-bottom:32px;
}
.ut-auth-tab {
  flex:1;
  font-family:'Cinzel',serif;
  font-size:10px;
  letter-spacing:0.3em;
  text-transform:uppercase;
  color:rgba(201,169,110,0.35);
  padding:14px;
  text-align:center;
  cursor:pointer;
  border:none;
  background:none;
  border-bottom:2px solid transparent;
  transition:all 0.2s;
  margin-bottom:-1px;
}
.ut-auth-tab:hover { color:rgba(201,169,110,0.7); }
.ut-auth-tab.active {
  color:var(--ut-gold);
  border-bottom-color:var(--ut-gold);
}

/* Forms */
.ut-auth-form { display:none; }
.ut-auth-form.active { display:block; }
.ut-auth-form-title {
  font-family:'Cinzel',serif;
  font-size:clamp(20px,2.5vw,26px);
  color:var(--ut-text);
  font-weight:400;
  letter-spacing:0.06em;
  margin-bottom:6px;
}
.ut-auth-form-sub {
  font-family:'Jost',sans-serif;
  font-size:12px;
  color:rgba(250,246,240,0.38);
  letter-spacing:0.08em;
  margin-bottom:28px;
  line-height:1.6;
}

/* Fields */
.ut-auth-field { margin-bottom:16px; position:relative; }
.ut-auth-label {
  font-family:'Cinzel',serif;
  font-size:8px;
  letter-spacing:0.35em;
  color:rgba(201,169,110,0.5);
  text-transform:uppercase;
  display:block;
  margin-bottom:7px;
}
.ut-auth-input {
  width:100%;
  background:rgba(201,169,110,0.03);
  border:1px solid rgba(201,169,110,0.18);
  color:var(--ut-text);
  font-family:'Jost',sans-serif;
  font-size:14px;
  padding:13px 16px;
  letter-spacing:0.04em;
  outline:none;
  box-sizing:border-box;
  transition:border-color 0.25s,background 0.25s;
}
.ut-auth-input:focus {
  border-color:rgba(201,169,110,0.55);
  background:rgba(201,169,110,0.05);
}
.ut-auth-input::placeholder { color:rgba(250,246,240,0.18); }
.ut-auth-input.error { border-color:rgba(139,58,82,0.6); }

/* Password toggle */
.ut-auth-field-wrap { position:relative; }
.ut-auth-toggle-pw {
  position:absolute;
  right:14px;top:50%;transform:translateY(-50%);
  background:none;border:none;
  color:rgba(201,169,110,0.4);
  cursor:pointer;font-size:16px;line-height:1;
  transition:color 0.2s;
}
.ut-auth-toggle-pw:hover { color:var(--ut-gold); }

/* Phone + OTP */
.ut-phone-row { display:flex; gap:10px; }
.ut-phone-code {
  background:rgba(201,169,110,0.05);
  border:1px solid rgba(201,169,110,0.18);
  color:var(--ut-gold);
  font-family:'Cinzel',serif;
  font-size:13px;
  padding:13px 14px;
  width:72px;
  flex-shrink:0;
  text-align:center;
  letter-spacing:0.05em;
}
.ut-auth-otp-row {
  display:flex;
  gap:10px;
  margin-bottom:4px;
}
.ut-otp-digit {
  flex:1;
  background:rgba(201,169,110,0.04);
  border:1px solid rgba(201,169,110,0.18);
  border-bottom:2px solid rgba(201,169,110,0.35);
  color:var(--ut-text);
  font-family:'Cinzel',serif;
  font-size:22px;
  text-align:center;
  padding:12px 4px;
  outline:none;
  transition:border-color 0.2s;
  letter-spacing:0;
}
.ut-otp-digit:focus {
  border-color:rgba(201,169,110,0.5);
  border-bottom-color:var(--ut-gold);
  background:rgba(201,169,110,0.06);
}
.ut-otp-timer {
  font-family:'Jost',sans-serif;
  font-size:11px;
  color:rgba(250,246,240,0.35);
  letter-spacing:0.08em;
  margin:8px 0 16px;
  display:flex;
  align-items:center;
  gap:8px;
}
.ut-otp-timer span { color:var(--ut-gold); }
.ut-otp-resend {
  font-family:'Jost',sans-serif;
  font-size:11px;
  color:rgba(201,169,110,0.45);
  background:none;border:none;
  cursor:pointer;letter-spacing:0.08em;
  text-decoration:underline;
  transition:color 0.2s;
}
.ut-otp-resend:hover { color:var(--ut-gold); }
.ut-otp-resend:disabled { opacity:0.3; cursor:not-allowed; text-decoration:none; }

/* Submit buttons */
.ut-auth-btn {
  width:100%;
  background:var(--ut-gold);
  color:var(--ut-bg);
  border:none;
  font-family:'Cinzel',serif;
  font-size:10px;
  letter-spacing:0.42em;
  text-transform:uppercase;
  padding:16px;
  cursor:pointer;
  transition:all 0.3s;
  margin-top:6px;
  position:relative;
  overflow:hidden;
}
.ut-auth-btn:hover { background:var(--ut-gold-light); }
.ut-auth-btn:active { transform:scale(0.99); }
.ut-auth-btn.loading {
  pointer-events:none;
  opacity:0.7;
}
.ut-auth-btn-outline {
  width:100%;
  background:none;
  color:var(--ut-gold);
  border:1px solid rgba(201,169,110,0.28);
  font-family:'Cinzel',serif;
  font-size:10px;
  letter-spacing:0.42em;
  text-transform:uppercase;
  padding:15px;
  cursor:pointer;
  transition:all 0.2s;
  margin-top:10px;
  display:block;
  text-align:center;
  text-decoration:none;
}
.ut-auth-btn-outline:hover { background:rgba(201,169,110,0.06); }

/* Error / success */
.ut-auth-error {
  background:rgba(139,58,82,0.1);
  border:1px solid rgba(139,58,82,0.3);
  color:var(--ut-rose-light);
  font-family:'Jost',sans-serif;
  font-size:12px;
  padding:11px 14px;
  letter-spacing:0.04em;
  margin-bottom:16px;
  display:none;
}
.ut-auth-success {
  background:rgba(40,120,40,0.1);
  border:1px solid rgba(40,150,40,0.3);
  color:var(--ut-success);
  font-family:'Jost',sans-serif;
  font-size:12px;
  padding:11px 14px;
  letter-spacing:0.04em;
  margin-bottom:16px;
  display:none;
}
.ut-auth-error.show,.ut-auth-success.show { display:block; }

/* Divider */
.ut-auth-divider {
  display:flex;align-items:center;gap:14px;
  margin:24px 0;
}
.ut-auth-divider::before,.ut-auth-divider::after {
  content:'';flex:1;height:1px;
  background:rgba(201,169,110,0.1);
}
.ut-auth-divider span {
  font-family:'Cinzel',serif;font-size:8px;
  letter-spacing:0.28em;color:rgba(201,169,110,0.28);
}

/* Social login btns */
.ut-auth-socials {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-bottom:6px;
}
.ut-auth-social-btn {
  display:flex;align-items:center;justify-content:center;gap:8px;
  border:1px solid rgba(201,169,110,0.15);
  background:none;
  color:rgba(250,246,240,0.55);
  font-family:'Jost',sans-serif;
  font-size:12px;
  padding:12px;
  cursor:pointer;
  transition:all 0.2s;
  letter-spacing:0.04em;
}
.ut-auth-social-btn:hover {
  border-color:rgba(201,169,110,0.35);
  color:var(--ut-text);
  background:rgba(201,169,110,0.04);
}
.ut-auth-social-btn i { font-size:16px;font-style:normal; }

/* Footer links */
.ut-auth-footer-links {
  display:flex;justify-content:space-between;
  margin-top:20px;
  flex-wrap:wrap;gap:8px;
}
.ut-auth-footer-links a {
  font-family:'Jost',sans-serif;font-size:11px;
  color:rgba(201,169,110,0.4);
  text-decoration:none;letter-spacing:0.08em;
  transition:color 0.2s;
}
.ut-auth-footer-links a:hover { color:var(--ut-gold); }

/* Step indicator (for OTP flow) */
.ut-auth-steps {
  display:flex;align-items:center;gap:8px;
  margin-bottom:28px;
}
.ut-auth-step {
  display:flex;align-items:center;gap:6px;
  font-family:'Jost',sans-serif;font-size:10px;
  color:rgba(250,246,240,0.28);letter-spacing:0.1em;
}
.ut-auth-step.active { color:var(--ut-gold); }
.ut-auth-step.done { color:rgba(123,200,123,0.7); }
.ut-auth-step-dot {
  width:20px;height:20px;border-radius:50%;
  border:1px solid currentColor;
  display:flex;align-items:center;justify-content:center;
  font-size:9px;flex-shrink:0;
}
.ut-auth-step.active .ut-auth-step-dot { background:rgba(201,169,110,0.15); }
.ut-auth-step.done .ut-auth-step-dot { background:rgba(40,120,40,0.2); }
.ut-auth-step-line {
  flex:1;height:1px;
  background:rgba(201,169,110,0.1);
}

/* Name row */
.ut-auth-name-row { display:grid;grid-template-columns:1fr 1fr;gap:12px; }
@media(max-width:440px){ .ut-auth-name-row{ grid-template-columns:1fr; } }

/* Terms checkbox */
.ut-auth-terms {
  display:flex;align-items:flex-start;gap:10px;
  margin:14px 0 4px;
  font-family:'Jost',sans-serif;
  font-size:11px;
  color:rgba(250,246,240,0.38);
  line-height:1.6;
  letter-spacing:0.04em;
}
.ut-auth-terms input { accent-color:var(--ut-gold);margin-top:3px;flex-shrink:0; }
.ut-auth-terms a { color:rgba(201,169,110,0.6);text-decoration:none; }
.ut-auth-terms a:hover { color:var(--ut-gold); }

/* Back to store */
.ut-auth-back {
  position:absolute;top:20px;right:24px;
  font-family:'Jost',sans-serif;font-size:11px;
  color:rgba(250,246,240,0.3);
  text-decoration:none;letter-spacing:0.1em;
  display:flex;align-items:center;gap:5px;
  transition:color 0.2s;
}
.ut-auth-back:hover { color:var(--ut-gold); }

/* Decorative dots */
.ut-auth-dots {
  position:absolute;bottom:32px;left:48px;
  display:flex;gap:6px;
}
.ut-auth-dot {
  width:6px;height:6px;border-radius:50%;
  background:rgba(201,169,110,0.15);
}
.ut-auth-dot:first-child { background:rgba(201,169,110,0.5); }

/* Password strength */
.ut-pw-strength { display:flex;gap:4px;margin-top:8px; }
.ut-pw-bar {
  flex:1;height:3px;border-radius:2px;
  background:rgba(201,169,110,0.1);
  transition:background 0.3s;
}
.ut-pw-bar.weak { background:var(--ut-rose); }
.ut-pw-bar.medium { background:var(--ut-gold); }
.ut-pw-bar.strong { background:var(--ut-success); }
.ut-pw-label {
  font-family:'Jost',sans-serif;font-size:9px;
  color:rgba(250,246,240,0.3);letter-spacing:0.1em;
  margin-top:5px;text-align:right;
}

/* Social login grid */
.ut-auth-socials-grid {
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
  margin-bottom:6px;
}
@media(max-width:480px){ .ut-auth-socials-grid{ grid-template-columns:1fr; } }
.ut-auth-social-btn {
  display:flex;align-items:center;justify-content:center;gap:9px;
  border:1px solid rgba(201,169,110,0.15);
  background:rgba(255,255,255,0.03);
  color:rgba(250,246,240,0.6);
  font-family:'Jost',sans-serif;
  font-size:12px;
  padding:11px 14px;
  cursor:pointer;
  transition:all 0.2s;
  letter-spacing:0.04em;
  width:100%;
}
.ut-auth-social-btn:hover {
  border-color:rgba(201,169,110,0.35);
  background:rgba(255,255,255,0.06);
  color:var(--ut-text);
  transform:translateY(-1px);
}
.ut-social-google:hover { border-color:rgba(66,133,244,0.5); }
.ut-social-apple { color:rgba(250,246,240,0.75); }
.ut-social-apple:hover { border-color:rgba(255,255,255,0.3); background:rgba(255,255,255,0.06); }
.ut-social-facebook:hover { border-color:rgba(24,119,242,0.5); }
.ut-social-whatsapp:hover { border-color:rgba(37,211,102,0.5); }
.ut-social-twitter { color:rgba(250,246,240,0.6); }
.ut-social-twitter:hover { border-color:rgba(255,255,255,0.25); }
.ut-social-phone:hover { border-color:rgba(201,169,110,0.5); color:var(--ut-gold); }

</style>

<div class="ut-auth-page">

  <!-- LEFT PANEL -->
  <div class="ut-auth-left">
    <a href="{{ routes.root_url }}" class="ut-auth-left-logo">Urban Trend</a>

    <div class="ut-auth-left-center">
      <div class="ut-auth-illustration">
        <span class="ut-auth-ill-icon">🌹</span>
        <!-- Decorative circles -->
        <div style="position:absolute;width:180px;height:180px;border-radius:50%;border:1px solid rgba(201,169,110,0.08);"></div>
        <div style="position:absolute;width:240px;height:240px;border-radius:50%;border:1px solid rgba(201,169,110,0.05);"></div>
        <div style="position:absolute;top:20px;right:24px;width:32px;height:32px;border-radius:50%;background:rgba(201,169,110,0.15);display:flex;align-items:center;justify-content:center;font-size:14px;">✦</div>
        <div style="position:absolute;bottom:28px;left:20px;width:24px;height:24px;border-radius:50%;background:rgba(139,58,82,0.2);"></div>
      </div>
      <h2 class="ut-auth-left-title">
        Your <em>Glow</em> Journey<br>Starts Here
      </h2>
      <p class="ut-auth-left-sub">
        Join 1,27,000+ beauty lovers who trust Urban Trend for luxury Indian skincare.
      </p>
    </div>

    <div class="ut-auth-benefits">
      <div class="ut-auth-benefit">
        <div class="ut-auth-benefit-icon">🎁</div>
        <span>₹300 welcome gift on first order</span>
      </div>
      <div class="ut-auth-benefit">
        <div class="ut-auth-benefit-icon">🚀</div>
        <span>Early access to new launches</span>
      </div>
      <div class="ut-auth-benefit">
        <div class="ut-auth-benefit-icon">♡</div>
        <span>Save wishlist & track orders</span>
      </div>
      <div class="ut-auth-benefit">
        <div class="ut-auth-benefit-icon">✨</div>
        <span>Earn Glow Points on every purchase</span>
      </div>
    </div>

    <div class="ut-auth-dots">
      <div class="ut-auth-dot"></div>
      <div class="ut-auth-dot"></div>
      <div class="ut-auth-dot"></div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="ut-auth-right">
    <a href="{{ routes.root_url }}" class="ut-auth-back">← Back to Store</a>

    <div class="ut-auth-right-inner">
      <a href="{{ routes.root_url }}" class="ut-auth-mobile-logo">Urban Trend</a>

      <!-- Tab switcher -->
      <div class="ut-auth-tabs">
        <button class="ut-auth-tab active" onclick="switchAuthTab('login',this)">Sign In</button>
        <button class="ut-auth-tab" onclick="switchAuthTab('register',this)">Create Account</button>
      </div>

      <!-- ===== LOGIN FORM ===== -->
      <div class="ut-auth-form active" id="authFormLogin">

        <!-- Step indicator -->
        <div class="ut-auth-steps" id="loginSteps">
          <div class="ut-auth-step active" id="step1">
            <div class="ut-auth-step-dot">1</div>
            <span>Details</span>
          </div>
          <div class="ut-auth-step-line"></div>
          <div class="ut-auth-step" id="step2">
            <div class="ut-auth-step-dot">2</div>
            <span>Verify</span>
          </div>
        </div>

        <h2 class="ut-auth-form-title">Welcome Back</h2>
        <p class="ut-auth-form-sub" id="loginSubText">Sign in to your Urban Trend account</p>

        <div class="ut-auth-error" id="loginError"></div>
        <div class="ut-auth-success" id="loginSuccess"></div>

        <!-- Step 1: Email/Phone + Password -->
        <div id="loginStep1">
          {% if form.errors %}
            <div class="ut-auth-error show">{{ form.errors | default_errors }}</div>
          {% endif %}

          {% form 'customer_login' %}
          <div class="ut-auth-field">
            <label class="ut-auth-label" for="loginEmail">Email Address</label>
            <input class="ut-auth-input" type="email" name="customer[email]" id="loginEmail"
              placeholder="your@email.com" autocomplete="email" required>
          </div>
          <div class="ut-auth-field">
            <label class="ut-auth-label" for="loginPassword">Password</label>
            <div class="ut-auth-field-wrap">
              <input class="ut-auth-input" type="password" name="customer[password]" id="loginPassword"
                placeholder="Enter your password" autocomplete="current-password" required
                style="padding-right:48px;">
              <button type="button" class="ut-auth-toggle-pw" onclick="togglePw('loginPassword',this)" tabindex="-1">👁</button>
            </div>
          </div>
          <div style="text-align:right;margin-bottom:18px;">
            <a href="{{ routes.account_recover_url }}" style="font-family:'Jost',sans-serif;font-size:11px;color:rgba(201,169,110,0.45);text-decoration:none;letter-spacing:0.08em;">Forgot Password?</a>
          </div>
          <button class="ut-auth-btn" type="submit">Sign In →</button>
          {% endform %}

          <div class="ut-auth-divider"><span>Or continue with</span></div>
