<script>
function submitAffForm(e) {
  e.preventDefault();
  var name = document.getElementById('affName').value;
  var phone = document.getElementById('affPhone').value;
  var email = document.getElementById('affEmail').value;
  var platform = document.getElementById('affPlatform').value;
  var followers = document.getElementById('affFollowers').value;
  var url = document.getElementById('affUrl').value;

  // WhatsApp message to owner
  var msg = encodeURIComponent(
    '🤝 *New Affiliate Application — Urban Trend*\n\n' +
    '👤 Name: ' + name + '\n' +
    '📱 WhatsApp: ' + phone + '\n' +
    '📧 Email: ' + email + '\n' +
    '📲 Platform: ' + platform + '\n' +
    '👥 Audience: ' + followers + '\n' +
    '🔗 URL: ' + (url || 'Not provided') + '\n\n' +
    'Please send affiliate link & onboarding details.'
  );

  // Send to owner WhatsApp — update number below
  window.open('https://wa.me/918901623093?text=' + msg, '_blank');

  // Show success
  document.getElementById('affFormWrap').style.display = 'none';
  document.getElementById('affSuccess').style.display = 'block';
}
</script>
