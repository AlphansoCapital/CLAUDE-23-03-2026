    <button class="ut-quick-btn" onclick="utQuickAsk('Skincare routine for Indian skin')">✨ Skincare Tips</button>
    <button class="ut-quick-btn" onclick="utQuickAsk('What is your return policy?')">↩️ Returns</button>
