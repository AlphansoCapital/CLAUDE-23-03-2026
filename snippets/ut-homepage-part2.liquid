<div id="ut-chatbot-window" role="dialog" aria-label="Urban Trend AI Assistant">

  <div class="ut-chat-header">
    <div class="ut-chat-avatar">✦</div>
    <div class="ut-chat-header-info">
      <span class="ut-chat-header-name">Priya — Urban Trend AI</span>
      <span class="ut-chat-header-status">Online · Replies instantly</span>
    </div>
    <button class="ut-chat-close" onclick="utChatToggle()" aria-label="Close chat">✕</button>
  </div>


  <div class="ut-chat-quick">
    <button class="ut-quick-btn" onclick="utQuickAsk('What are your bestsellers?')">🔥 Bestsellers</button>
