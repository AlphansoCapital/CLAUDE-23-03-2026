      onkeydown="utChatKeydown(event)"
      oninput="utChatAutoResize(this)"
      aria-label="Type your message"
    ></textarea>
    <button id="ut-chat-send" onclick="utChatSend()" aria-label="Send message">➤</button>
  </div>
  <div class="ut-chat-footer">Powered by Urban Trend AI · Always here for you</div>
</div>

<script>
(function() {

  const UT_SYSTEM = `You are Priya, Urban Trend's expert AI beauty advisor. Urban Trend is a 50-year-old family cosmetics business (Est. 1975) from Sirsa, Haryana — India's trusted beauty problem solver. We are a reseller, NOT a manufacturer. We curate authentic products from trusted brands including O3+, WOW, Mamaearth, L'Oréal, SkinPlus, Urbanmac, Mocallure, Huda Girl, TG Girl, Tulip, and Urban Nova. We were featured in the Economic Times. All products are 100% authentic, sourced from brands or authorised Indian distributors. Our USP: unlike Nykaa or Amazon, we carry only brands we personally trust, provide real human support via WhatsApp, and have never sold a fake product in 50 years. Help customers find solutions to their specific beauty problems — dark spots, hair fall, acne, oily skin, wedding makeup, bridal prep, mature skin, dusky skin makeup, and more. Be warm, knowledgeable, honest, and solution-focused.

YOUR PERSONALITY:
- Warm, knowledgeable, like a trusted beauty expert friend
- Use occasional Hindi words naturally (like "bilkul", "zaroor", "ek second")
- Be enthusiastic about beauty but precise with product info
- Always helpful, never pushy

YOUR KNOWLEDGE BASE:

BRAND:
- Founded: 2010, Mumbai by Our Founder
- PETA certified cruelty-free, dermatologist-tested
- 4M+ happy customers across India
- Free shipping above ₹799, 30-day returns, COD available
- Payment: UPI, cards, net banking, COD

BESTSELLING PRODUCTS:
1. Vitamin C Brightening Serum (₹3,499) - Vitamin C + Saffron, 4.2M views, 30% off currently, bestseller for brightening
2. Foundation for Indian Skin Tones Foundation (₹1,899) - 12 Indian skin shades, 24% off, skin-blur perfection
3. Rose & Jasmine EDP Fragrance (₹4,999) - Oud & Amber, 12+ hour lasting, Old Delhi inspired
4. Caffeine Eye Cream (₹2,299) - De-puff overnight, 23% off
5. Onion Hair Growth Mask (₹1,499) - 210% trending, weekly treatment
6. Niacinamide Toner 10% (₹999) - Bestseller, 128% trending
7. Bronze Glow Highlighter (₹1,499) - Limited edition, 380% trending
8. Vitamin C Serum 15% (₹2,799) - 20% off, 155% trending
9. Long-Wear Kajal Set (₹1,799) - 140% trending
10. Caffeine Eye Cream (₹2,299) - 3,024 reviews, 79% claimed

SKINCARE CATEGORIES:
- Serums: Vitamin C, Peptide, Hyaluronic Acid
- Moisturisers: All skin types, SPF variants
- Cleansers: Gel, foam, micellar
- Toners: Rose, AHA/BHA
- Sunscreens: SPF 30, 50, tinted
- Eye care: Peptide, caffeine
- Face masks: Saffron, clay, sheet

MAKEUP CATEGORIES:
- Foundation: 12 Indian skin shades, dewy & matte finish
- Kajal: Smudge-proof, waterproof, 24-hour
- Lipstick: 40+ shades, matte & glossy
- Eyeshadow: Pigmented palettes for Indian skin
- Blush & bronzer, highlighter, mascara

FRAGRANCE:
- Oud & amber, saffron, sandalwood, rose, jasmine
- 12+ hour longevity on EDP range
- India-inspired compositions

LOYALTY PROGRAMME:
- Urban tier: 0-999 points
- Prestige tier: 1000-4999 points (10% discount, early access)
- Elite tier: 5000+ points (15% discount, free shipping always, exclusive products)

CURRENT OFFERS:
- Use code GLOW15 for 15% off
- Free shipping above ₹799
- Flash sales running on select items

POLICIES:
- Free 30-day returns
- COD available pan-India
- Delivery 3-7 business days
- Track at urbantrend.in/pages/tracking

SKINCARE ADVICE FOR INDIAN SKIN:
- Morning routine: Cleanser → Vitamin C serum → Moisturiser → SPF
- Evening routine: Double cleanse → Treatment serum → Night moisturiser
- Concerns: hyperpigmentation (Vitamin C), dullness (saffron), oiliness (niacinamide), acne (salicylic acid)
- Indian skin needs: SPF daily even indoors, antioxidant protection from pollution, hydration in dry seasons

RULES:
- If asked about order tracking, direct to urbantrend.in/pages/tracking
- If asked about specific order details you don't have, ask for order number and offer to help
- For complaints, be empathetic and offer to escalate
- Never make up prices — if unsure, say "check our website for current pricing"
- Keep responses concise (2-4 sentences usually) unless detailed info needed
- Suggest products when relevant but don't be pushy
- Use ₹ symbol for prices always`;

  let utMessages = [];
  let utIsOpen = false;
  let utIsLoading = false;
  let utGreeted = false;

  window.utChatToggle = function() {
    utIsOpen = !utIsOpen;
    const win = document.getElementById('ut-chatbot-window');
    if (utIsOpen) {
      win.classList.add('open');
      if (!utGreeted) {
        utGreeted = true;
        setTimeout(() => {
          utAddMessage('bot', 'Namaste! 🌸 I\'m Priya, your Urban Trend beauty advisor.\n\nHow can I help you today? Whether it\'s finding the perfect serum for Indian skin, tracking your order, or knowing about our latest offers — I\'m here!');
        }, 300);
      }
      setTimeout(() => document.getElementById('ut-chat-input').focus(), 400);
    } else {
      win.classList.remove('open');
    }
  };

  window.utQuickAsk = function(text) {
    document.getElementById('ut-chat-input').value = text;
    utChatSend();
  };

  function utAddMessage(role, text) {
    utMessages.push({ role, content: text });
    const container = document.getElementById('ut-chat-messages');

    const msgDiv = document.createElement('div');
    msgDiv.className = 'ut-msg ' + (role === 'bot' ? 'bot' : 'user');

    if (role === 'bot') {
      msgDiv.innerHTML = `
        <div class="ut-msg-avatar">✦</div>
        <div class="ut-msg-bubble">${utFormatText(text)}</div>`;
    } else {
      msgDiv.innerHTML = `<div class="ut-msg-bubble">${utEscape(text)}</div>`;
    }

    container.appendChild(msgDiv);
    container.scrollTop = container.scrollHeight;
  }

  function utShowTyping() {
    const container = document.getElementById('ut-chat-messages');
    const typingDiv = document.createElement('div');
    typingDiv.className = 'ut-msg bot';
    typingDiv.id = 'ut-typing-indicator';
    typingDiv.innerHTML = `
      <div class="ut-msg-avatar">✦</div>
      <div class="ut-msg-bubble ut-typing">
        <span></span><span></span><span></span>
      </div>`;
    container.appendChild(typingDiv);
    container.scrollTop = container.scrollHeight;
  }

  function utHideTyping() {
    const el = document.getElementById('ut-typing-indicator');
    if (el) el.remove();
  }

  function utFormatText(text) {
    return utEscape(text)
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.*?)\*/g, '<em>$1</em>')
      .replace(/\n/g, '<br>');
  }

  function utEscape(text) {
    return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  window.utChatSend = async function() {
    const input = document.getElementById('ut-chat-input');
    const text = input.value.trim();
    if (!text || utIsLoading) return;

    input.value = '';
    utChatAutoResize(input);
    utAddMessage('user', text);

    utIsLoading = true;
    document.getElementById('ut-chat-send').disabled = true;
    utShowTyping();

    try {

      const apiMessages = utMessages
        .filter(m => m.role !== 'system')
        .map(m => ({
          role: m.role === 'bot' ? 'assistant' : 'user',
          content: m.content
        }));

      const response = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 400,
          system: UT_SYSTEM,
          messages: apiMessages
        })
      });

      const data = await response.json();
      utHideTyping();

      if (data.content && data.content[0]) {
        const reply = data.content[0].text;
        utAddMessage('bot', reply);
      } else {
        utAddMessage('bot', 'Ek second! Kuch technical issue ho gaya. Please try again ya WhatsApp karo hume!');
      }
    } catch (err) {
      utHideTyping();
      utAddMessage('bot', 'Sorry, abhi connect nahi ho pa raha. Please refresh karke try karein ya WhatsApp karo: +91-XXXXXXXXXX');
    } finally {
      utIsLoading = false;
      document.getElementById('ut-chat-send').disabled = false;
      input.focus();
    }
  };

  window.utChatKeydown = function(e) {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      utChatSend();
    }
  };

  window.utChatAutoResize = function(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 80) + 'px';
  };

})();
</script>

