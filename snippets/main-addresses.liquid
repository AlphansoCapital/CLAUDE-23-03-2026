<style>
.ut-addr-page{background:var(--ut-bg);min-height:100vh;padding:60px 32px 80px}
.ut-addr-wrap{max-width:800px;margin:0 auto}
.ut-addr-page-back{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.25em;color:rgba(250,246,240,.35);text-decoration:none;text-transform:uppercase;display:flex;align-items:center;gap:8px;margin-bottom:32px;transition:color .2s}
.ut-addr-page-back:hover{color:var(--ut-gold)}
.ut-addr-page-title{font-family:'Cinzel',serif;font-size:28px;color:var(--ut-text);font-weight:400;letter-spacing:.1em;margin-bottom:40px}
.ut-addr-new-btn{font-family:'Cinzel',serif;font-size:9px;letter-spacing:.3em;text-transform:uppercase;background:var(--ut-gold);color:var(--ut-bg);border:none;padding:14px 28px;cursor:pointer;transition:background .2s;text-decoration:none;display:inline-block;margin-bottom:32px}
.ut-addr-new-btn:hover{background:#E2C98A}
.ut-addr-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;margin-bottom:40px}
.ut-addr-item{border:1px solid rgba(201,169,110,.12);padding:24px;position:relative}
.ut-addr-item.default{border-color:rgba(201,169,110,.4)}
.ut-addr-default-tag{position:absolute;top:12px;right:12px;font-family:'Cinzel',serif;font-size:7px;letter-spacing:.2em;color:var(--ut-gold);border:1px solid rgba(201,169,110,.3);padding:3px 8px;text-transform:uppercase}
.ut-addr-item-name{font-family:'Cinzel',serif;font-size:14px;color:var(--ut-text);margin-bottom:10px}
.ut-addr-item-text{font-family:'Jost',sans-serif;font-size:13px;color:rgba(250,246,240,.55);line-height:1.8}
.ut-addr-item-actions{display:flex;gap:16px;margin-top:16px;flex-wrap:wrap}
.ut-addr-btn{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.2em;text-transform:uppercase;background:none;border:1px solid rgba(201,169,110,.2);color:rgba(250,246,240,.5);padding:8px 16px;cursor:pointer;transition:all .2s;text-decoration:none}
.ut-addr-btn:hover{color:var(--ut-gold);border-color:rgba(201,169,110,.5)}
.ut-addr-btn.danger:hover{color:#E57373;border-color:rgba(229,115,115,.4)}
/* Form */
.ut-addr-form-wrap{background:var(--ut-bg-2);border:1px solid rgba(201,169,110,.1);padding:32px;margin-bottom:32px;display:none}
.ut-addr-form-wrap.open{display:block}
.ut-addr-form-title{font-family:'Cinzel',serif;font-size:14px;letter-spacing:.2em;color:var(--ut-gold);text-transform:uppercase;margin-bottom:24px}
.ut-addr-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.ut-addr-field{display:flex;flex-direction:column;gap:6px}
.ut-addr-field.full{grid-column:1/-1}
.ut-addr-label{font-family:'Cinzel',serif;font-size:8px;letter-spacing:.25em;color:rgba(250,246,240,.35);text-transform:uppercase}
.ut-addr-input{background:none;border:1px solid rgba(201,169,110,.18);color:var(--ut-text);font-family:'Jost',sans-serif;font-size:14px;padding:12px 16px;outline:none;transition:border-color .2s;width:100%}
.ut-addr-input:focus{border-color:rgba(201,169,110,.5)}
.ut-addr-input::placeholder{color:rgba(250,246,240,.18)}
.ut-addr-form-actions{display:flex;gap:12px;margin-top:20px;flex-wrap:wrap}
@media(max-width:600px){.ut-addr-form-grid{grid-template-columns:1fr}.ut-addr-page{padding:40px 16px 60px}}
</style>

<div class="ut-addr-page">
  <div class="ut-addr-wrap">
    <a href="{{ routes.account_url }}" class="ut-addr-page-back">← Back to Account</a>
    <h1 class="ut-addr-page-title">Saved Addresses</h1>

    <button class="ut-addr-new-btn" onclick="utToggleAddrForm('new')">+ Add New Address</button>

    <!-- New Address Form -->
    <div class="ut-addr-form-wrap" id="ut-addr-form-new">
      <div class="ut-addr-form-title">New Address</div>
      {% form 'customer_address', customer.new_address %}
        <div class="ut-addr-form-grid">
          <div class="ut-addr-field">
            <label class="ut-addr-label">First Name</label>
            <input class="ut-addr-input" type="text" name="address[first_name]" placeholder="First name" autocomplete="given-name">
          </div>
          <div class="ut-addr-field">
            <label class="ut-addr-label">Last Name</label>
            <input class="ut-addr-input" type="text" name="address[last_name]" placeholder="Last name" autocomplete="family-name">
          </div>
          <div class="ut-addr-field full">
            <label class="ut-addr-label">Address Line 1</label>
            <input class="ut-addr-input" type="text" name="address[address1]" placeholder="House/Flat no., Street" autocomplete="address-line1">
          </div>
          <div class="ut-addr-field full">
            <label class="ut-addr-label">Address Line 2</label>
            <input class="ut-addr-input" type="text" name="address[address2]" placeholder="Area, Landmark" autocomplete="address-line2">
          </div>
          <div class="ut-addr-field">
            <label class="ut-addr-label">City</label>
            <input class="ut-addr-input" type="text" name="address[city]" placeholder="City" autocomplete="address-level2">
          </div>
          <div class="ut-addr-field">
            <label class="ut-addr-label">State</label>
            <input class="ut-addr-input" type="text" name="address[province]" placeholder="State" autocomplete="address-level1">
          </div>
          <div class="ut-addr-field">
            <label class="ut-addr-label">PIN Code</label>
            <input class="ut-addr-input" type="text" name="address[zip]" placeholder="110001" autocomplete="postal-code" maxlength="6" inputmode="numeric">
          </div>
          <div class="ut-addr-field">
            <label class="ut-addr-label">Phone</label>
            <input class="ut-addr-input" type="tel" name="address[phone]" placeholder="+91 98765 43210" autocomplete="tel">
          </div>
          <div class="ut-addr-field full">
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;">
              <input type="checkbox" name="address[default]" id="defaultAddress" style="accent-color:#C9A96E;">
              <span class="ut-addr-label" style="text-transform:none;font-size:12px;color:rgba(250,246,240,.6);">Set as default address</span>
            </label>
          </div>
        </div>
        <div class="ut-addr-form-actions">
          <button type="submit" class="ut-addr-new-btn" style="margin-bottom:0;">Save Address</button>
          <button type="button" class="ut-addr-btn" onclick="utToggleAddrForm('new')">Cancel</button>
        </div>
      {% endform %}
    </div>

    <!-- Existing Addresses -->
    <div class="ut-addr-list">
      {% for address in customer.addresses %}
      <div class="ut-addr-item {% if address == customer.default_address %}default{% endif %}">
        {% if address == customer.default_address %}<span class="ut-addr-default-tag">Default</span>{% endif %}
        <div class="ut-addr-item-name">{{ address.name }}</div>
        <div class="ut-addr-item-text">
          {{ address.address1 }}{% if address.address2 %}<br>{{ address.address2 }}{% endif %}<br>
          {{ address.city }}{% if address.province %}, {{ address.province }}{% endif %} {{ address.zip }}<br>
          {{ address.country }}{% if address.phone %}<br>📞 {{ address.phone }}{% endif %}
        </div>
        <div class="ut-addr-item-actions">
          <button class="ut-addr-btn" onclick="utToggleAddrForm('{{ address.id }}')">Edit</button>
          {% unless address == customer.default_address %}
          <form method="post" action="{{ routes.account_addresses_url }}/{{ address.id }}" style="display:inline;">
            {{ form.authenticity_token }}
            <input type="hidden" name="_method" value="put">
            <input type="hidden" name="address[default]" value="true">
            <button type="submit" class="ut-addr-btn">Set Default</button>
          </form>
          <form method="post" action="{{ routes.account_addresses_url }}/{{ address.id }}" style="display:inline;" onsubmit="return confirm('Delete this address?')">
            {{ form.authenticity_token }}
            <input type="hidden" name="_method" value="delete">
            <button type="submit" class="ut-addr-btn danger">Delete</button>
          </form>
          {% endunless %}
        </div>

        <!-- Edit Form -->
        <div class="ut-addr-form-wrap" id="ut-addr-form-{{ address.id }}">
          <div class="ut-addr-form-title">Edit Address</div>
          {% form 'customer_address', address %}
            <div class="ut-addr-form-grid">
              <div class="ut-addr-field">
                <label class="ut-addr-label">First Name</label>
                <input class="ut-addr-input" type="text" name="address[first_name]" value="{{ address.first_name }}" autocomplete="given-name">
              </div>
              <div class="ut-addr-field">
                <label class="ut-addr-label">Last Name</label>
                <input class="ut-addr-input" type="text" name="address[last_name]" value="{{ address.last_name }}" autocomplete="family-name">
              </div>
              <div class="ut-addr-field full">
                <label class="ut-addr-label">Address Line 1</label>
                <input class="ut-addr-input" type="text" name="address[address1]" value="{{ address.address1 }}" autocomplete="address-line1">
              </div>
              <div class="ut-addr-field full">
                <label class="ut-addr-label">Address Line 2</label>
                <input class="ut-addr-input" type="text" name="address[address2]" value="{{ address.address2 }}" autocomplete="address-line2">
              </div>
              <div class="ut-addr-field">
                <label class="ut-addr-label">City</label>
                <input class="ut-addr-input" type="text" name="address[city]" value="{{ address.city }}" autocomplete="address-level2">
              </div>
              <div class="ut-addr-field">
                <label class="ut-addr-label">State</label>
                <input class="ut-addr-input" type="text" name="address[province]" value="{{ address.province }}" autocomplete="address-level1">
              </div>
              <div class="ut-addr-field">
                <label class="ut-addr-label">PIN Code</label>
                <input class="ut-addr-input" type="text" name="address[zip]" value="{{ address.zip }}" maxlength="6" inputmode="numeric">
              </div>
              <div class="ut-addr-field">
                <label class="ut-addr-label">Phone</label>
                <input class="ut-addr-input" type="tel" name="address[phone]" value="{{ address.phone }}" autocomplete="tel">
              </div>
            </div>
            <div class="ut-addr-form-actions">
              <button type="submit" class="ut-addr-new-btn" style="margin-bottom:0;">Update Address</button>
              <button type="button" class="ut-addr-btn" onclick="utToggleAddrForm('{{ address.id }}')">Cancel</button>
            </div>
          {% endform %}
        </div>
      </div>
      {% else %}
      <div style="grid-column:1/-1;text-align:center;padding:40px;font-family:'Jost',sans-serif;font-size:13px;color:rgba(250,246,240,.35);">No saved addresses yet</div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
function utToggleAddrForm(id) {
  var form = document.getElementById('ut-addr-form-' + id);
  if (!form) return;
  var isOpen = form.classList.contains('open');
  document.querySelectorAll('.ut-addr-form-wrap').forEach(function(f) { f.classList.remove('open'); });
  if (!isOpen) {
    form.classList.add('open');
    form.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
}
</script>
{% schema %}{"name":"Addresses","tag":"section","settings":[]}{% endschema %}
